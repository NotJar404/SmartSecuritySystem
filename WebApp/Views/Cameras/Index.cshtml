@model List<WebApp.Models.Camera>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/camera.css" />

<div class="camera-page">

    <!-- HEADER -->
    <div class="camera-topbar">
        <div>
            <h1>Live Monitoring</h1>
            <p>@Model.Count active cameras</p>
        </div>

        <div class="top-actions">
            <button onclick="showGrid()">Grid</button>
            <button onclick="showFocus()">Focus</button>
            <button class="add-btn" onclick="openModal()">+ Add Camera</button>
        </div>
    </div>

    <!-- GRID VIEW -->
    <div id="gridView" class="live-grid">

        @foreach (var cam in Model)
        {
            <div class="live-card"
                 onclick="openFromGrid('@cam.Id','@cam.Name','@cam.Location','@cam.IpAddress','@cam.Port')">

                <div class="live-top">
                    <span>@cam.Name</span>
                    <span class="status">LIVE</span>
                </div>

                <div class="live-body">
                    <i class="fa fa-camera"></i>
                    <div>@cam.Location</div>
                </div>

                <div class="live-footer">
                    <span>AI Monitoring</span>
                </div>
            </div>
        }

    </div>

    <!-- FOCUS VIEW -->
    <div id="focusView" class="camera-layout" style="display:none;">

        <!-- LEFT LIST -->
        <div class="camera-list">
            @foreach (var cam in Model)
            {
                <div class="camera-card"
                     onclick="openFromGrid('@cam.Id','@cam.Name','@cam.Location','@cam.IpAddress','@cam.Port')">
                    <strong>@cam.Name</strong><br />
                    <small>@cam.Location</small>
                </div>
            }
        </div>

        <!-- RIGHT VIEW -->
        <div class="camera-view" id="cameraView">

            <div class="view-header">
                <div>
                    <h2 id="camTitle">Select Camera</h2>
                    <p id="camSubtitle"></p>
                </div>

                <button onclick="toggleFullscreen()">⤢</button>
                <button onclick="editSelectedCamera()">Edit</button>
            </div>

            <div class="video-container">
                <div class="live-badge">● LIVE</div>

                <div class="camera-placeholder">
                    <i class="fa fa-camera"></i>
                </div>

                <div class="camera-overlay">
                    <strong id="overlayName"></strong><br />
                    <span id="overlayLocation"></span><br />
                    <span id="overlayIp"></span>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- MODAL -->
<div id="cameraModal" class="modal" onclick="outsideClick(event)">
    <form method="post"
          id="cameraForm"
          asp-controller="Cameras"
          asp-action="Add"
          class="modal-content modern-modal"
          onclick="event.stopPropagation()">

        <!-- HIDDEN ID -->
        <input type="hidden" name="Id" id="camId" />

        <!-- HEADER -->
        <div class="modal-header">
            <h2 id="modalTitle">Add New Camera</h2>
            <span class="close" onclick="closeModal()">&times;</span>
        </div>

        <!-- BODY -->
        <div class="modal-body">

            <h4 class="section-title">Basic Information</h4>

            <label>Camera Name *</label>
            <input type="text" id="camName" name="Name" required />

            <label>Location *</label>
            <input type="text" id="camLocation" name="Location" required />

            <hr />

            <h4 class="section-title">Network Configuration</h4>

            <div class="grid-2">
                <div>
                    <label>IP Address</label>
                    <input type="text" id="camIp" name="IpAddress" />
                </div>

                <div>
                    <label>Port</label>
                    <input type="number" id="camPort" name="Port" value="554" />
                </div>
            </div>

        </div>

        <!-- FOOTER -->
        <div class="modal-footer">
            <button type="button" class="cancel" onclick="closeModal()">Cancel</button>
            <button type="submit" class="save" id="saveBtn">Add Camera</button>
        </div>

    </form>
</div>

@section Scripts {
<script>
    // STORE selected camera globally
    let selectedCamera = null;

    // VIEW SWITCH
    function showGrid() {
        document.getElementById("gridView").style.display = "grid";
        document.getElementById("focusView").style.display = "none";
    }

    function showFocus() {
        document.getElementById("gridView").style.display = "none";
        document.getElementById("focusView").style.display = "flex";
    }

    // SELECT CAMERA FOR DISPLAY
    function selectCamera(cam) {
        selectedCamera = cam;

        document.getElementById("camTitle").innerText = cam.Name;
        document.getElementById("camSubtitle").innerText = cam.Location;

        document.getElementById("overlayName").innerText = cam.Name;
        document.getElementById("overlayLocation").innerText = cam.Location;
        document.getElementById("overlayIp").innerText = cam.IpAddress || "No IP";
    }

    // CLICK GRID OR LIST → FOCUS + SELECT
    function openFromGrid(id, name, location, ip, port) {
        showFocus();

        selectCamera({ Id: id, Name: name, Location: location, IpAddress: ip, Port: port });
    }

    // EDIT SELECTED CAMERA
    function editSelectedCamera() {
        if (!selectedCamera) return;

        document.getElementById("cameraForm").action = "/Cameras/Edit";
        document.getElementById("modalTitle").innerText = "Edit Camera";
        document.getElementById("saveBtn").innerText = "Save Changes";

        document.getElementById("camId").value = selectedCamera.Id;
        document.getElementById("camName").value = selectedCamera.Name;
        document.getElementById("camLocation").value = selectedCamera.Location;
        document.getElementById("camIp").value = selectedCamera.IpAddress;
        document.getElementById("camPort").value = selectedCamera.Port;

        document.getElementById("cameraModal").style.display = "flex";
    }

    // ADD NEW CAMERA
    function openModal() {
        selectedCamera = null;

        document.getElementById("cameraForm").action = "/Cameras/Add";
        document.getElementById("modalTitle").innerText = "Add New Camera";
        document.getElementById("saveBtn").innerText = "Add Camera";

        document.getElementById("camId").value = "";
        document.getElementById("camName").value = "";
        document.getElementById("camLocation").value = "";
        document.getElementById("camIp").value = "";
        document.getElementById("camPort").value = 554;

        document.getElementById("cameraModal").style.display = "flex";
    }

    // FULLSCREEN
    function toggleFullscreen() {
        const view = document.getElementById("cameraView");
        if (!document.fullscreenElement) view.requestFullscreen();
        else document.exitFullscreen();
    }

    // CLOSE MODAL
    function closeModal() {
        document.getElementById("cameraModal").style.display = "none";
    }

    function outsideClick(e) {
        if (e.target.id === "cameraModal") closeModal();
    }

</script>
}