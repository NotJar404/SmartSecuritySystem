@model List<WebApp.Models.Camera>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";

    var rooms = ViewBag.Rooms as List<WebApp.Models.Room>;
    var occupancyCounts = ViewBag.OccupancyCounts as Dictionary<int,int> ?? new Dictionary<int,int>();
    var cameraAlerts = ViewBag.CameraAlerts as HashSet<int> ?? new HashSet<int>();
    var roomCapacities = ViewBag.RoomCapacities as Dictionary<int,int> ?? new Dictionary<int,int>();
    var alertSeverities = ViewBag.AlertSeverities as Dictionary<int,WebApp.Models.SeverityLevel> ?? new Dictionary<int,WebApp.Models.SeverityLevel>();
    var latestDetections = ViewBag.LatestDetections as Dictionary<int,WebApp.Models.DetectionLog> ?? new Dictionary<int,WebApp.Models.DetectionLog>();
}

<link rel="stylesheet" href="~/css/camera.css" />
<link rel="stylesheet" href="~/css/camera-ai.css" />
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="~/js/webcam-stream-loader.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/@@vladmandic/face-api@@1.7.12/dist/face-api.min.js"></script>
<script defer src="~/js/camera-detect.js"></script>

<div class="monitoring-page">

    <!-- TOP BAR -->
    <div class="topbar">
        <div class="topbar-left">
            <div class="app-icon">
                <i class="fa fa-video-camera"></i>
            </div>

            <div>
                <h1>Live Monitoring</h1>
                <p>AI-assisted real-time surveillance system</p>
            </div>
        </div>

        <div class="topbar-right">

            @if (User.IsInRole("Admin"))
            {
                <button type="button" class="btn-add" onclick="openModal()">+ Add Camera</button>
            }

            <div class="view-toggle">
                <button type="button" onclick="showGrid()"><i class="fa fa-th-large"></i></button>
                <button type="button" onclick="showFocus()"><i class="fa fa-columns"></i></button>
            </div>

            <span class="live-pill">● LIVE</span>
            <span class="count-pill">@(Model?.Count ?? 0) Cameras</span>
        </div>
    </div>

    <!-- VALIDATION -->
    <div class="validation-summary text-danger">
        @Html.ValidationSummary(false)
    </div>

    <!-- GRID VIEW -->
    <div id="gridView" class="grid-view">

        @if (Model != null && Model.Any())
        {
            foreach (var cam in Model)
            {
                var safeName = (cam.Name ?? "").Replace("'", "\\'");
                var safeUrl = (cam.StreamUrl ?? "").Replace("'", "\\'");
                var safeLoc = (cam.Location ?? "").Replace("'", "\\'");
                var occupancy = occupancyCounts.ContainsKey(cam.Id) ? occupancyCounts[cam.Id] : 0;
                var hasAlert = cameraAlerts.Contains(cam.RoomId);
                var maxCap = roomCapacities.ContainsKey(cam.RoomId) ? roomCapacities[cam.RoomId] : 0;
                var capPercent = maxCap > 0 ? Math.Min((occupancy * 100) / maxCap, 100) : 0;

                // Tri-state status
                var secStatus = "SAFE";
                if (alertSeverities.ContainsKey(cam.RoomId))
                {
                    secStatus = alertSeverities[cam.RoomId] == WebApp.Models.SeverityLevel.CRITICAL ? "ALERT" : "WARNING";
                }

                // Face status
                var faceStatus = "none";
                if (latestDetections.ContainsKey(cam.Id))
                {
                    var det = latestDetections[cam.Id];
                    var age = (DateTime.UtcNow - det.Timestamp).TotalSeconds;
                    if (age < 30)
                    {
                        faceStatus = (det.DetectionType?.ToLower()) switch
                        {
                            "face_verified" => "verified",
                            "unknown_face" => "unknown",
                            "face_obstruction" => "obstructed",
                            _ => "detected"
                        };
                    }
                }

                <div class="grid-card @(secStatus == "ALERT" ? "status-alert" : secStatus == "WARNING" ? "status-warning" : "")"
                     data-camera-id="@cam.Id"
                     data-room-id="@cam.RoomId"
                     onclick="openFromGrid(@cam.Id, '@safeName', '@safeUrl', '@safeLoc', @cam.RoomId)">

                    @if (User.IsInRole("Admin"))
                    {
                        <button type="button" class="card-delete-btn" title="Delete Camera"
                                onclick="event.stopPropagation(); deleteCamera(@cam.Id, '@safeName');">
                            <i class="fas fa-times"></i>
                        </button>
                    }

                    <div class="grid-header">
                        <span class="grid-title">@cam.Name</span>
                        <span class="security-badge badge-@(secStatus.ToLower())" data-field="securityBadge">
                            @if (secStatus == "ALERT") { <text><i class="fas fa-exclamation-triangle"></i> ALERT</text> }
                            else if (secStatus == "WARNING") { <text><i class="fas fa-exclamation-circle"></i> WARNING</text> }
                            else { <text><i class="fas fa-shield-alt"></i> SAFE</text> }
                        </span>
                    </div>

                    <div class="grid-body">
                        <i class="fa fa-camera"></i>
                        <video class="grid-preview" muted autoplay playsinline data-src="@cam.StreamUrl"></video>
                    </div>

                    <!-- Capacity Bar -->
                    @if (maxCap > 0)
                    {
                        <div class="capacity-bar-wrap">
                            <div class="capacity-bar" data-field="capacityBar" style="width: @(capPercent)%; background: @(capPercent > 80 ? "var(--alert)" : capPercent > 50 ? "var(--warning-amber)" : "var(--status-active)")"></div>
                        </div>
                    }

                    <div class="grid-meta">
                        <div class="meta-item people-counter" title="People Detected">
                            <i class="fas fa-users"></i>
                            <span data-field="peopleCount">@occupancy</span>
                            @if (maxCap > 0) { <small class="cap-label">/ @maxCap</small> }
                        </div>
                        <div class="meta-item" title="Face Recognition">
                            <span class="face-indicator face-@faceStatus" data-field="faceStatus">
                                @if (faceStatus == "verified") { <text><i class="fas fa-user-check"></i> Verified</text> }
                                else if (faceStatus == "unknown") { <text><i class="fas fa-user-times"></i> Unknown</text> }
                                else if (faceStatus == "obstructed") { <text><i class="fas fa-user-slash"></i> Obstructed</text> }
                                else if (faceStatus == "detected") { <text><i class="fas fa-user"></i> Detected</text> }
                                else { <text><i class="far fa-user"></i> No Face</text> }
                            </span>
                        </div>
                        <div class="meta-item" title="Status">
                            <span class="cam-status-dot @(cam.Status == "active" ? "online" : "offline")"></span>
                            <span>@(cam.Status == "active" ? "Online" : "Offline")</span>
                        </div>
                    </div>

                    <div class="grid-footer">
                        <span>@cam.Location</span>
                        <span>@cam.Room?.RoomName</span>
                    </div>
                </div>
            }
        }

    </div>

    <!-- FOCUS VIEW -->
    <div id="focusView" class="focus-layout" style="display:none;">

        <div class="sidebar">
            <div class="sidebar-title">CAMERAS</div>

            @if (Model != null && Model.Any())
            {
                foreach (var cam in Model)
                {
                    var safeName = (cam.Name ?? "").Replace("'", "\\'");
                    var safeUrl = (cam.StreamUrl ?? "").Replace("'", "\\'");
                    var safeLoc = (cam.Location ?? "").Replace("'", "\\'");

                    <div class="camera-item"
                         onclick="openFromGrid(@cam.Id, '@safeName', '@safeUrl', '@safeLoc', @cam.RoomId)">

                        <div class="camera-item-header">
                            <i class="fa fa-camera"></i>
                            <span>@cam.Name</span>
                        </div>

                        <div class="camera-location">@cam.Location</div>
                    </div>
                }
            }
        </div>

        <div class="viewer">

            <div class="viewer-header">
                <div>
                    <h2 id="camTitle">Select Camera</h2>
                    <p id="camSubtitle"></p>
                </div>

                <div class="viewer-actions">
                    @if (User.IsInRole("Admin"))
                    {
                        <button type="button" onclick="editSelectedCamera()">Edit</button>
                    }
                    <button type="button" onclick="toggleFullscreen()">⤢</button>
                </div>
            </div>

            <div class="viewer-body" style="position:relative;">
                <div class="rec-badge">● REC</div>
                <div class="timestamp" id="camTime"></div>

                <video id="videoPlayer"
                       autoplay
                       controls
                       playsinline
                       style="width:100%; height:100%; background:black;">
                </video>

                <!-- Detection overlay canvas (bounding boxes + labels) -->
                <canvas id="detectOverlay"
                        style="position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:5;">
                </canvas>

                <div class="overlay">
                    <strong id="overlayName"></strong><br />
                    <span id="overlayLocation"></span><br />
                    <span id="overlaySource"></span>
                </div>
            </div>

            <!-- AI STATUS PANEL (Focus View) -->
            <div class="ai-status-panel" id="aiStatusPanel">
                <div class="ai-panel-row">
                    <div class="ai-stat">
                        <div class="ai-stat-icon people"><i class="fas fa-users"></i></div>
                        <div class="ai-stat-info">
                            <span class="ai-stat-label">People Detected</span>
                            <span class="ai-stat-value" id="focusPeopleCount">0</span>
                        </div>
                    </div>
                    <div class="ai-stat">
                        <div class="ai-stat-icon face"><i class="fas fa-user-shield"></i></div>
                        <div class="ai-stat-info">
                            <span class="ai-stat-label">Face Recognition</span>
                            <span class="ai-stat-value" id="focusFaceStatus">No Face</span>
                        </div>
                    </div>
                    <div class="ai-stat">
                        <div class="ai-stat-icon threat"><i class="fas fa-shield-alt"></i></div>
                        <div class="ai-stat-info">
                            <span class="ai-stat-label">Threat Level</span>
                            <span class="ai-stat-value" id="focusThreatLevel">SAFE</span>
                        </div>
                    </div>
                    <div class="ai-stat">
                        <div class="ai-stat-icon alert"><i class="fas fa-bell"></i></div>
                        <div class="ai-stat-info">
                            <span class="ai-stat-label">Active Alerts</span>
                            <span class="ai-stat-value" id="focusAlertCount">0</span>
                        </div>
                    </div>
                </div>
                <div class="ai-detection-feed" id="detectionFeed">
                    <span class="feed-placeholder"><i class="fas fa-satellite-dish"></i> Awaiting AI detection data...</span>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- MODAL -->
<div id="cameraModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post"
              id="cameraForm"
              asp-controller="Cameras"
              asp-action="Add"
              class="modal-content">

            @Html.AntiForgeryToken()

            <input type="hidden" id="camId" name="Id" value="0" />
            <input type="hidden" name="Status" value="active" />

            <div class="modal-header">
                <h5 id="modalTitle">Add Camera</h5>
                <button type="button" class="close" onclick="closeModal()" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label>Camera Name</label>
                    <input type="text" id="camName" name="Name" required />
                </div>

                <div class="form-group">
                    <label>Location</label>
                    <input type="text" id="camLocation" name="Location" required />
                </div>

                <div class="form-group">
                    <label>Room</label>
                    <select id="camRoom" name="RoomId" required>
                        <option value="">-- Select Room --</option>
                        @if (rooms != null && rooms.Count > 0)
                        {
                            foreach (var room in rooms)
                            {
                                <option value="@room.RoomId">@room.RoomName</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Stream URL</label>

                    <input type="text"
                        id="camSource"
                        name="StreamUrl"
                        placeholder="Enter Raspberry Pi / IP camera URL (or leave empty for webcam test)"
                        />

                    <small>
                        ✔ Raspberry Pi: http://192.168.x.x:xxxx<br />
                        ✔ IP Camera / OBS stream supported<br />
                        ✔ Leave EMPTY for laptop webcam (TEST MODE ONLY)
                    </small>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" onclick="closeModal()">Cancel</button>

                @if (User.IsInRole("Admin"))
                {
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                }
                else
                {
                    <button type="button" class="btn btn-primary btn-sm" disabled>Save</button>
                }
            </div>

        </form>
    </div>
</div>

<script>

let selectedCamera = null;
let clockInterval = null;
let pollingInterval = null;

function el(id) {
    return document.getElementById(id);
}

const gridView = el("gridView");
const focusView = el("focusView");
const camTitle = el("camTitle");
const camSubtitle = el("camSubtitle");
const camTime = el("camTime");
const overlayName = el("overlayName");
const overlayLocation = el("overlayLocation");
const overlaySource = el("overlaySource");
const video = el("videoPlayer");

// =====================================================
// VIEW SWITCHING
// =====================================================
function showGrid() {
    gridView.style.display = "grid";
    focusView.style.display = "none";
}

function showFocus() {
    gridView.style.display = "none";
    focusView.style.display = "flex";
}

function openFromGrid(id, name, streamUrl, location, roomId) {
    showFocus();
    selectCamera({ Id: id, Name: name, StreamUrl: streamUrl, Location: location, RoomId: roomId });
}

// =====================================================
// CAMERA SELECTION
// =====================================================
function selectCamera(cam) {
    selectedCamera = cam;

    camTitle.innerText = cam.Name || "";
    camSubtitle.innerText = cam.Location || "";
    overlayName.innerText = cam.Name || "";
    overlayLocation.innerText = cam.Location || "";

    startClock();

    if (cam.StreamUrl && cam.StreamUrl.trim() !== "") {
        // === REAL STREAM (Raspberry Pi / IP camera) ===
        overlaySource.innerText = "Raspberry Pi / Stream";
        stopDetection();
        stopWebcamVideo(video);
        video.srcObject = null;

        // Clean up any test mode MJPEG stream
        var mjpeg = document.getElementById('mjpegTestStream');
        if (mjpeg) { mjpeg.src = ''; mjpeg.style.display = 'none'; }
        video.style.display = 'block';
        fetch('http://localhost:5050/stop', { mode: 'no-cors' }).catch(() => {});

        loadVideoStream(video, cam.StreamUrl, {
            enableHLS: true,
            fallbackToWebcam: true,
            onSuccess: (info) => {
                console.log('[CAMERA] Stream loaded:', info.type);
            },
            onError: (error) => {
                console.error('[CAMERA] Stream error:', error);
            },
            onWebcam: () => {
                console.log('[CAMERA] Webcam fallback activated');
                overlaySource.innerText = "Local Webcam (TEST MODE - AI Detection Active)";
                initWebcamDetection(video, cam.Id, cam.RoomId);
            }
        });
    } else {
        // === TEST MODE: Use Python stream_server.py (same pipeline as Pi) ===
        // Bounding boxes are rendered by Python backend, NOT browser-side
        overlaySource.innerText = "AI Pipeline Stream (TEST MODE)";
        stopDetection();
        stopWebcamVideo(video);
        video.srcObject = null;

        // Tell stream_server.py to start the webcam
        const STREAM_BASE = 'http://localhost:5050';
        fetch(STREAM_BASE + '/start', { mode: 'no-cors' }).catch(() => {});

        // Use an <img> tag for MJPEG stream (bounding boxes burned into frames)
        let mjpegImg = document.getElementById('mjpegTestStream');
        if (!mjpegImg) {
            mjpegImg = document.createElement('img');
            mjpegImg.id = 'mjpegTestStream';
            mjpegImg.style.cssText = 'width:100%;height:100%;object-fit:contain;background:black;position:absolute;top:0;left:0;z-index:1;';
            video.parentElement.insertBefore(mjpegImg, video);
        }

        // Hide the <video> element, show the MJPEG <img>
        video.style.display = 'none';
        mjpegImg.style.display = 'block';
        mjpegImg.src = STREAM_BASE + '/video?t=' + Date.now();

        mjpegImg.onerror = function() {
            console.warn('[CAMERA] Python stream_server.py not running — falling back to browser webcam');
            // Fallback: if Python server isn't running, use browser webcam
            mjpegImg.style.display = 'none';
            video.style.display = 'block';
            overlaySource.innerText = "Local Webcam (TEST MODE - No AI Overlays)";

            loadVideoStream(video, null, {
                fallbackToWebcam: true,
                onSuccess: (info) => {
                    console.log('[CAMERA] Browser webcam loaded (no overlays):', info.type);
                },
                onError: (error) => {
                    console.error('[CAMERA] Webcam error:', error);
                }
            });
        };
    }
}

function startClock() {
    if (clockInterval) clearInterval(clockInterval);
    clockInterval = setInterval(() => {
        camTime.innerText = new Date().toLocaleString();
    }, 1000);
}

function toggleFullscreen() {
    if (!document.fullscreenElement) {
        focusView.requestFullscreen();
    } else {
        document.exitFullscreen();
    }
}

// =====================================================
// REAL-TIME POLLING ENGINE (5 SECOND INTERVAL)
// =====================================================
function startPolling() {
    if (pollingInterval) clearInterval(pollingInterval);
    pollingInterval = setInterval(fetchCameraStatus, 5000);
    fetchCameraStatus(); // initial fetch
}

function fetchCameraStatus() {
    fetch('/Cameras/Status')
        .then(r => r.json())
        .then(data => {
            if (!Array.isArray(data)) return;
            data.forEach(cam => updateCameraCard(cam));
            if (selectedCamera) {
                const focused = data.find(c => c.cameraId === selectedCamera.Id);
                if (focused) updateFocusPanel(focused);
            }
        })
        .catch(err => console.log("[POLL ERROR]", err));
}

// =====================================================
// UPDATE GRID CARD (REAL-TIME)
// =====================================================
function updateCameraCard(cam) {
    const card = document.querySelector(`.grid-card[data-camera-id="${cam.cameraId}"]`);
    if (!card) return;

    // People count
    const countEl = card.querySelector('[data-field="peopleCount"]');
    if (countEl && countEl.textContent !== String(cam.peopleCount)) {
        countEl.textContent = cam.peopleCount;
        countEl.classList.add('count-flip');
        setTimeout(() => countEl.classList.remove('count-flip'), 400);
    }

    // Security badge
    const badge = card.querySelector('[data-field="securityBadge"]');
    if (badge) {
        badge.className = 'security-badge badge-' + cam.securityStatus.toLowerCase();
        const icons = { SAFE: 'fa-shield-alt', WARNING: 'fa-exclamation-circle', ALERT: 'fa-exclamation-triangle' };
        badge.innerHTML = `<i class="fas ${icons[cam.securityStatus] || 'fa-shield-alt'}"></i> ${cam.securityStatus}`;
    }

    // Card status class
    card.classList.remove('status-alert', 'status-warning');
    if (cam.securityStatus === 'ALERT') card.classList.add('status-alert');
    else if (cam.securityStatus === 'WARNING') card.classList.add('status-warning');

    // Face status
    const faceEl = card.querySelector('[data-field="faceStatus"]');
    if (faceEl) {
        faceEl.className = 'face-indicator face-' + cam.faceStatus;
        const faceMap = {
            verified: '<i class="fas fa-user-check"></i> Verified',
            unknown: '<i class="fas fa-user-times"></i> Unknown',
            obstructed: '<i class="fas fa-user-slash"></i> Obstructed',
            detected: '<i class="fas fa-user"></i> Detected',
            none: '<i class="far fa-user"></i> No Face'
        };
        faceEl.innerHTML = faceMap[cam.faceStatus] || faceMap.none;
    }

    // Capacity bar
    if (cam.maxCapacity > 0) {
        const capBar = card.querySelector('[data-field="capacityBar"]');
        if (capBar) {
            const pct = Math.min((cam.peopleCount * 100) / cam.maxCapacity, 100);
            capBar.style.width = pct + '%';
            capBar.style.background = pct > 80 ? 'var(--alert)' : pct > 50 ? 'var(--warning-amber)' : 'var(--status-active)';
        }
    }
}

// =====================================================
// UPDATE FOCUS PANEL (AI STATUS)
// =====================================================
function updateFocusPanel(cam) {
    const pc = el('focusPeopleCount');
    if (pc) pc.textContent = cam.peopleCount;

    const fs = el('focusFaceStatus');
    if (fs) {
        const labels = { verified: 'Verified ✅', unknown: 'Unknown ⚠', obstructed: 'Obstructed 🚫', detected: 'Detected', none: 'No Face' };
        fs.textContent = labels[cam.faceStatus] || 'No Face';
        fs.className = 'ai-stat-value face-text-' + cam.faceStatus;
    }

    const tl = el('focusThreatLevel');
    if (tl) {
        tl.textContent = cam.securityStatus;
        tl.className = 'ai-stat-value threat-text-' + cam.securityStatus.toLowerCase();
    }

    const ac = el('focusAlertCount');
    if (ac) ac.textContent = cam.alertCount;

    const feed = el('detectionFeed');
    if (feed && cam.latestAlert) {
        feed.innerHTML = `<div class="feed-item feed-${cam.latestAlert.severity.toLowerCase()}">
            <i class="fas fa-exclamation-circle"></i>
            <span>${cam.latestAlert.description || cam.latestAlert.type}</span>
            <small>${cam.latestAlert.minutesAgo}m ago</small>
        </div>`;
    }
}

// =====================================================
// MODAL FUNCTIONS
// =====================================================
function openModal() {
    document.getElementById("cameraForm").reset();
    document.getElementById("modalTitle").innerText = "Add Camera";
    document.getElementById("cameraForm").action = "/Cameras/Add";
    document.getElementById("camId").value = "0";
    
    const modal = document.getElementById('cameraModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    const modal = document.getElementById('cameraModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

function editSelectedCamera() {
    if (!selectedCamera) return;

    const form = document.getElementById("cameraForm");
    form.action = "/Cameras/Edit";
    
    document.getElementById("modalTitle").innerText = "Edit Camera";
    document.getElementById("camId").value = selectedCamera.Id || 0;
    document.getElementById("camName").value = selectedCamera.Name || "";
    document.getElementById("camLocation").value = selectedCamera.Location || "";
    document.getElementById("camSource").value = selectedCamera.StreamUrl || "";
    document.getElementById("camRoom").value = selectedCamera.RoomId || "";

    const modal = document.getElementById('cameraModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// Delete camera with confirmation
function deleteCamera(id, name) {
    SecureConfirm.confirmDelete(name || 'Camera', function() {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/Cameras/Delete';
        form.innerHTML = `
            <input type="hidden" name="id" value="${id}" />
            <input type="hidden" name="__RequestVerificationToken" value="${document.querySelector('[name=__RequestVerificationToken]').value}" />
        `;
        document.body.appendChild(form);
        form.submit();
    });
}

// =====================================================
// INIT
// =====================================================
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('cameraModal');
    const closeBtn = document.querySelector('#cameraModal .close');
    const cancelBtn = document.querySelector('#cameraModal .btn-light');
    
    if (closeBtn) {
        closeBtn.addEventListener('click', function(e) { e.preventDefault(); closeModal(); });
    }
    
    if (cancelBtn) {
        cancelBtn.addEventListener('click', function(e) { e.preventDefault(); closeModal(); });
    }
    
    // Close on backdrop click
    modal.addEventListener('click', function(e) {
        if (e.target === modal) { closeModal(); }
    });

    // Intercept camera form with two-step confirmation
    SecureConfirm.interceptForm('cameraForm', 'Confirm Camera Configuration', 'cameraModal');

    // Init grid video previews — NO webcam fallback (prevents getUserMedia from
    // locking the webcam before Python stream_server.py can access it)
    document.querySelectorAll('.grid-preview').forEach(function(video) {
        const url = video.getAttribute('data-src');
        loadVideoStream(video, url, {
            enableHLS: true,
            fallbackToWebcam: false,
            onSuccess: (info) => {
                console.log('[CAMERA GRID] Loaded:', info.type);
            }
        });
    });

    // START REAL-TIME POLLING
    startPolling();

    // =====================================================
    // PAGE-LEAVE CLEANUP: Release webcam when user leaves
    // Uses sendBeacon (guaranteed delivery even during page close)
    // =====================================================
    function cleanupCamera() {
        stopDetection();
        stopAllWebcamStreams();

        // Clear MJPEG stream
        var mjpeg = document.getElementById('mjpegTestStream');
        if (mjpeg) mjpeg.src = '';

        // Also clear any dynamically created MJPEG imgs
        document.querySelectorAll('.mjpeg-stream-img').forEach(function(img) { img.src = ''; });

        // sendBeacon is GUARANTEED to complete even during page close
        // (unlike fetch which browsers cancel on unload)
        if (navigator.sendBeacon) {
            navigator.sendBeacon('http://localhost:5050/stop');
        } else {
            fetch('http://localhost:5050/stop', { mode: 'no-cors', keepalive: true }).catch(() => {});
        }
    }

    window.addEventListener('beforeunload', cleanupCamera);
    window.addEventListener('pagehide', cleanupCamera);  // iOS/mobile backup
});

</script>