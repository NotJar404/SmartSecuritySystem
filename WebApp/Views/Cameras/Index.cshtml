@model List<WebApp.Models.Camera>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="camera-page">

    <!-- HEADER -->
    <div class="camera-topbar">
        <div>
            <h1>Live Monitoring</h1>
            <p>@Model.Count active cameras</p>
        </div>

        <div class="top-actions">
            <button onclick="showGrid()">Grid</button>
            <button onclick="showFocus()">Focus</button>
            <button class="add-btn" onclick="openModal()">+ Add Camera</button>
        </div>
    </div>

    <!-- ================= GRID VIEW ================= -->
    <div id="gridView" class="live-grid">

        @foreach (var cam in Model)
        {
            <div class="live-card"
                 onclick="openFromGrid('@cam.Name','@cam.Location','@cam.IpAddress')">

                <div class="live-top">
                    <span>@cam.Name</span>
                    <span class="status">LIVE</span>
                </div>

                <div class="live-body">
                    <i class="fa fa-camera"></i>
                    <div>@cam.Location</div>
                </div>

                <div class="live-footer">
                    <span>AI Monitoring</span>
                </div>
            </div>
        }

    </div>

    <!-- ================= FOCUS VIEW ================= -->
    <div id="focusView" class="camera-layout" style="display:none;">

        <!-- LEFT LIST -->
        <div class="camera-list">
            @foreach (var cam in Model)
            {
                <div class="camera-card"
                     onclick="selectCamera('@cam.Name','@cam.Location','@cam.IpAddress')">
                    <strong>@cam.Name</strong><br />
                    <small>@cam.Location</small>
                </div>
            }
        </div>

        <!-- RIGHT VIEW -->
        <div class="camera-view" id="cameraView">

            <div class="view-header">
                <div>
                    <h2 id="camTitle">Select Camera</h2>
                    <p id="camSubtitle"></p>
                </div>

                <button onclick="toggleFullscreen()">⤢</button>
            </div>

            <div class="video-container">
                <div class="live-badge">● LIVE</div>

                <div class="camera-placeholder">
                    <i class="fa fa-camera"></i>
                </div>

                <div class="camera-overlay">
                    <strong id="overlayName"></strong><br />
                    <span id="overlayLocation"></span><br />
                    <span id="overlayIp"></span>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ================= MODAL ================= -->
<div id="cameraModal" class="modal" onclick="outsideClick(event)">
    <form method="post" asp-controller="Cameras" asp-action="Add"
          class="modal-content modern-modal" onclick="event.stopPropagation()">

        <!-- HEADER -->
        <div class="modal-header">
            <h2>Add New Camera</h2>
            <span class="close" onclick="closeModal()">&times;</span>
        </div>

        <!-- BODY -->
        <div class="modal-body">

            <!-- BASIC INFO -->
            <h4 class="section-title">Basic Information</h4>

            <label>Camera Name <span class="required">*</span></label>
            <input type="text" name="Name" placeholder="e.g., Main Entrance, Parking Lot" required />

            <label>Location <span class="required">*</span></label>
            <input type="text" name="Location" placeholder="e.g., Front Door, North Side" required />

            <hr />

            <!-- NETWORK -->
            <h4 class="section-title">Network Configuration</h4>

            <div class="grid-2">
                <div>
                    <label>IP Address</label>
                    <input type="text" name="IpAddress" placeholder="192.168.1.100" />
                </div>

                <div>
                    <label>Port</label>
                    <input type="number" name="Port" value="554" />
                </div>
            </div>

            <hr />

            <!-- VIDEO -->
            <h4 class="section-title">Video Settings</h4>

            <div class="grid-2">
                <div>
                    <label>Resolution</label>
                    <select name="Resolution">
                        <option>1920x1080 (Full HD)</option>
                        <option>1280x720 (HD)</option>
                    </select>
                </div>

                <div>
                    <label>Frame Rate (FPS)</label>
                    <select name="Fps">
                        <option>30 FPS</option>
                        <option>60 FPS</option>
                    </select>
                </div>
            </div>

            <hr />

            <!-- FEATURES -->
            <h4 class="section-title">Features</h4>

            <label class="checkbox">
                <input type="checkbox" name="Recording" checked />
                <span>
                    Enable Recording<br />
                    <small>Automatically record camera feed</small>
                </span>
            </label>

            <label class="checkbox">
                <input type="checkbox" name="Motion" checked />
                <span>
                    Motion Detection<br />
                    <small>Trigger alerts on motion detection</small>
                </span>
            </label>

        </div>

        <!-- FOOTER -->
        <div class="modal-footer">
            <button type="button" class="cancel" onclick="closeModal()">Cancel</button>
            <button type="submit" class="save">Add Camera</button>
        </div>

    </form>
</div>

@section Scripts {
<script>
    // SWITCH VIEWS
    function showGrid() {
        document.getElementById("gridView").style.display = "grid";
        document.getElementById("focusView").style.display = "none";
    }

    function showFocus() {
        document.getElementById("gridView").style.display = "none";
        document.getElementById("focusView").style.display = "flex";
    }

    // CLICK FROM GRID → OPEN FOCUS
    function openFromGrid(name, location, ip) {
        showFocus();
        selectCamera(name, location, ip);
    }

    // SELECT CAMERA
    function selectCamera(name, location, ip) {
        document.getElementById("camTitle").innerText = name;
        document.getElementById("camSubtitle").innerText = location;

        document.getElementById("overlayName").innerText = name;
        document.getElementById("overlayLocation").innerText = location;
        document.getElementById("overlayIp").innerText = ip || "No IP";
    }

    // FULLSCREEN
    function toggleFullscreen() {
        const view = document.getElementById("cameraView");

        if (!document.fullscreenElement) {
            view.requestFullscreen();
        } else {
            document.exitFullscreen();
        }
    }

    // MODAL
    function openModal() {
        document.getElementById("cameraModal").style.display = "flex";
    }

    function closeModal() {
        document.getElementById("cameraModal").style.display = "none";
    }

    function outsideClick(e) {
        if (e.target.id === "cameraModal") closeModal();
    }
</script>
}