<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SecureVision</title>
    
    <link rel="stylesheet" href="~/css/layouts.css" />
    <link rel="stylesheet" href="~/css/shared.css" />
    <link rel="stylesheet" href="~/css/modal-system.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" />
</head>
<body>
    <!-- ═══════════════════════════════════════════════════════════════ -->
<!-- GLOBAL LOCKDOWN BANNER — shown on every page when lockdown     -->
<!-- active. Polls /api/system/status every 4s. Outside all panels. -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<div id="globalLockdownBanner" style="
    display:none; position:fixed; top:0; left:0; width:100%; z-index:19999;
    background:linear-gradient(90deg,#7f0000,#dc2626,#7f0000);
    background-size:200% 100%; animation:lockdownSlide 3s linear infinite;
    color:#fff; font-weight:700; font-size:.88rem; letter-spacing:.04em;
    padding:9px 16px; display:none; align-items:center; gap:10px;
    box-shadow:0 4px 18px rgba(220,38,38,.55);
" role="alert">
    <i class="fas fa-lock" style="font-size:1rem;"></i>
    <span>🔒 LOCKDOWN ACTIVE — All Entry Points Secured</span>
    <span id="globalLockdownReason" style="font-weight:400;opacity:.85;margin-left:6px;"></span>
    <span style="flex:1"></span>
    <button onclick="globalResolveLockdown()" style="
        background:rgba(255,255,255,.18); border:1px solid rgba(255,255,255,.4);
        color:#fff; border-radius:5px; padding:2px 11px; font-size:.8rem; cursor:pointer;
        font-weight:600; letter-spacing:.03em;
    ">🔓 Resolve</button>
</div>

<!-- GLOBAL ALARM BANNER — shown when Pi pushes an active alarm     -->
<div id="globalAlarmBanner" style="
    display:none; position:fixed; top:0; left:0; width:100%; z-index:19998;
    background:linear-gradient(90deg,#92400e,#f59e0b,#92400e);
    background-size:200% 100%; animation:lockdownSlide 2s linear infinite;
    color:#fff; font-weight:700; font-size:.88rem; letter-spacing:.04em;
    padding:9px 16px; align-items:center; gap:10px;
    box-shadow:0 4px 18px rgba(245,158,11,.5);
" role="alert">
    <i class="fas fa-triangle-exclamation" style="font-size:1rem;"></i>
    <span id="globalAlarmLabel">⚠️ ALARM ACTIVE</span>
    <span style="flex:1"></span>
    <button onclick="globalDeactivateAlarm()" style="
        background:rgba(255,255,255,.18); border:1px solid rgba(255,255,255,.4);
        color:#fff; border-radius:5px; padding:2px 11px; font-size:.8rem; cursor:pointer;
        font-weight:600;
    ">✖ Deactivate</button>
</div>

<style>
    @@keyframes lockdownSlide {
        0%   { background-position: 0% 50%; }
        100% { background-position: 200% 50%; }
    }
    /* Push page content down when banners are visible */
    body.lockdown-active  .dashboard-wrapper { margin-top: 41px; }
    body.alarm-active     .dashboard-wrapper { margin-top: 41px; }
    body.lockdown-active.alarm-active .dashboard-wrapper { margin-top: 82px; }
</style>

<div class="dashboard-wrapper">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon"><i class="fa fa-shield-halved"></i></div>
                <div class="logo-text">
                    <h2>SecureVision</h2>
                    <p>Quezon City University</p>
                </div>
            </div>

            <a asp-controller="Profile" asp-action="Index" class="profile-preview">
                <div class="avatar-box">
                    @{
                        var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User";
                        var initial = !string.IsNullOrEmpty(fullName) ? fullName.Substring(0, 1).ToUpper() : "U";
                    }
                    @initial
                </div>
                <div class="profile-meta">
                    <strong>@fullName</strong>
                    <small>@(User.IsInRole("Admin") ? "Administrator" : "Security Personnel")</small>
                </div>
            </a>

            <nav class="sidebar-nav">
                @{
                    var mustChangePw = User.HasClaim("MustChangePassword", "true");
                }
                <ul>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "") @(mustChangePw ? "nav-disabled" : "")">
                            <a asp-controller="Admin" asp-action="Index"><i class="fa fa-chart-line"></i> Dashboard</a>
                        </li>
                        <li class="nav-item @(mustChangePw ? "nav-disabled" : "")">
                            <a asp-controller="Cameras" asp-action="Index"><i class="fa fa-camera"></i> Camera Config</a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Personnel" ? "active" : "") @(mustChangePw ? "nav-disabled" : "")">
                            <a asp-controller="Admin" asp-action="Personnel"><i class="fa fa-user-plus"></i> User Management</a>
                        </li>
                        <li class="nav-item @(mustChangePw ? "nav-disabled" : "")">
                            <a asp-controller="Admin" asp-action="Analytics"><i class="fa fa-chart-bar"></i> Analytics Report</a>
                        </li>
                        <li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" ? "active" : "") @(mustChangePw ? "nav-disabled" : "")">
                            <a asp-controller="Logs" asp-action="Index"><i class="fa fa-history"></i> Activity Logs</a>
                        </li>
                        <li class="nav-item @(mustChangePw ? "nav-disabled" : "")">
                            <a asp-controller="Admin" asp-action="System"><i class="fa fa-gear"></i> System Settings</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item active @(mustChangePw ? "nav-disabled" : "")"><a asp-controller="Dashboard" asp-action="Index"><i class="fa fa-home"></i> Dashboard</a></li>
                        <li class="nav-item @(mustChangePw ? "nav-disabled" : "")"><a asp-controller="Cameras" asp-action="Index"><i class="fa fa-video"></i> Live Monitoring</a></li>
                        <li class="nav-item @(mustChangePw ? "nav-disabled" : "")"><a asp-controller="Access" asp-action="Index"><i class="fa fa-door-open"></i> Access Monitoring</a></li>
                        <li class="nav-item alert-nav @(mustChangePw ? "nav-disabled" : "")"><a asp-controller="Alerts" asp-action="Index"><i class="fa fa-triangle-exclamation"></i> Security Alert</a></li>
                        <li class="nav-item @(mustChangePw ? "nav-disabled" : "")"><a asp-controller="Logs" asp-action="Index"><i class="fa fa-history"></i> Activity Logs</a></li>
                    }
                </ul>
            </nav>

            <div class="sidebar-footer">
                <a href="javascript:void(0)" onclick="confirmLogout()" class="logout-link">
                    <i class="fa fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </aside>

        <main class="main-viewport">
            <header class="topbar">
                <div class="top-info">
                    <h3>@ViewData["Title"]</h3>
                    <div class="date-display d-none d-md-block">
                        @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                    </div>
                </div>

                <div class="top-actions">
                    <div class="clock-box" id="liveTime"></div>

                    <div class="theme-switcher" onclick="toggleTheme()">
                        <i id="themeIcon" class="fa fa-moon"></i>
                    </div>

                    <!-- 🔔 REAL-TIME NOTIFICATION BADGE -->
                    <div class="notif-bell" onclick="toggleNotifPanel()" style="cursor: pointer; position: relative;">
                        <i class="fa fa-bell"></i>
                        <span class="badge" id="notifBadge">0</span>
                    </div>
                </div>
            </header>

            <section class="page-content">
                @{
                    var mustChangePass = User.HasClaim("MustChangePassword", "true");
                    var isProfilePage = ViewContext.RouteData.Values["controller"]?.ToString() == "Profile";
                    var isAuthPage = ViewContext.RouteData.Values["controller"]?.ToString() == "Auth";
                }

                @if (mustChangePass && !isProfilePage && !isAuthPage)
                {
                    <!-- FULL BLOCK: Redirect to Profile — user cannot access any page until password changed -->
                    <div class="force-password-banner">
                        <i class="fas fa-shield-alt"></i>
                        <span>You must change your temporary password before accessing the system.</span>
                        <a href="/Profile/Index" class="banner-btn">Change Password Now</a>
                    </div>
                    <script>
                        // Auto-redirect to Profile page
                        window.location.href = '/Profile/Index';
                    </script>
                }
                else
                {
                    @if (mustChangePass && isProfilePage)
                    {
                        <div class="force-password-banner">
                            <i class="fas fa-shield-alt"></i>
                            <span>You must change your temporary password before accessing the system. Please update your password below.</span>
                        </div>
                    }

                    @RenderBody()
                }
            </section>
        </main>

        <div class="notification-overlay" id="notifOverlay" onclick="toggleNotifPanel()"></div>

        <aside class="notification-panel" id="notifPanel">
            <div class="notif-header">
                <div class="header-top">
                    <h4>System Activity</h4>
                    <button class="close-notif" onclick="toggleNotifPanel()">&times;</button>
                </div>
                <p class="notif-subtitle">Real-time Security & System Updates</p>
            </div>

            <div class="notif-content" id="notifContent">
                <p>Loading...</p>
            </div>

        </aside>
    </div>

    <script src="~/js/confirmation-modal.js"></script>
    @RenderSection("Scripts", required: false)

    <script>
        // =========================
        // CLOCK
        // =========================
        function updateTime() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });
            const el = document.getElementById("liveTime");
            if (el) el.textContent = timeStr;
        }
        setInterval(updateTime, 1000);
        updateTime();

        // =========================
        // NOTIFICATIONS (REAL TIME)
        // =========================
        async function updateNotifBadge() {
            try {
                const res = await fetch('/Notifications/GetUnreadCount');
                const count = await res.json();

                document.getElementById("notifBadge").textContent = count ?? 0;
            } catch {
                document.getElementById("notifBadge").textContent = 0;
            }
        }

        async function loadNotifications() {
            try {
                const res = await fetch('/Notifications/GetLatest');
                const data = await res.json();

                const container = document.getElementById("notifContent");
                container.innerHTML = "";

                data.forEach(n => {
                    container.innerHTML += `
                        <div class="notif-item ${n.severity ?? 'info'}">
                            <div class="notif-info">
                                <p><strong>${n.title}</strong></p>
                                <small>${n.message}</small>
                            </div>
                        </div>
                    `;
                });

            } catch {
                document.getElementById("notifContent").innerHTML =
                    "<p>Failed to load notifications</p>";
            }
        }

        function toggleNotifPanel() {
            document.getElementById("notifPanel").classList.toggle("open");
            document.getElementById("notifOverlay").classList.toggle("active");

            // mark as read
            fetch('/Notifications/MarkAsRead', { method: 'POST' });

            document.getElementById("notifBadge").textContent = "0";
        }

        setInterval(updateNotifBadge, 3000);
        setInterval(loadNotifications, 5000);

        updateNotifBadge();
        loadNotifications();

        // =========================
        // THEME
        // =========================
        function applyTheme(theme) {
            const body = document.body;
            const icon = document.getElementById("themeIcon");

            if (theme === "light") {
                body.classList.remove("dark-mode");
                icon.className = "fa fa-sun";
            } else {
                body.classList.add("dark-mode");
                icon.className = "fa fa-moon";
            }

            localStorage.setItem("selected-theme", theme);
        }

        function toggleTheme() {
            const isDark = document.body.classList.contains("dark-mode");
            applyTheme(isDark ? "light" : "dark");
        }

        (function init() {
            applyTheme(localStorage.getItem("selected-theme") || "light");
        })();

        // =========================
        // LOGOUT
        // =========================
        function confirmLogout() {
            SecureConfirm.show({
                title: 'Confirm Logout',
                icon: 'fas fa-right-from-bracket',
                fields: [
                    { label: 'Action', value: 'Sign out of SecureVision' },
                    { label: 'Session', value: 'Your current session will be terminated' }
                ],
                confirmText: 'Logout',
                confirmClass: 'btn-danger',
                onConfirm: function() {
                    window.location.href = '/Auth/Logout';
                }
            });
        }
    </script>
    <script>
        // ═════════════════════════════════════════════════════════════════════
        // GLOBAL LOCKDOWN + ALARM POLLER — runs on every page
        // Polls /api/system/status every 4s and shows/hides banners.
        // ═════════════════════════════════════════════════════════════════════
        (function initGlobalStatusPoller() {
            const lockdownBanner = document.getElementById('globalLockdownBanner');
            const lockdownReason = document.getElementById('globalLockdownReason');
            const alarmBanner    = document.getElementById('globalAlarmBanner');
            const alarmLabel     = document.getElementById('globalAlarmLabel');

            const ALARM_LABELS = {
                intrusion:   '🚨 INTRUDER ALERT — Lockdown in effect',
                fire:        '🔥 FIRE ALARM — Evacuate immediately',
                earthquake:  '🌍 EARTHQUAKE DRILL — Take cover',
                forcedentry: '📢 EMERGENCY DRILL — Follow evacuation plan',
                medical:     '🏥 MEDICAL EMERGENCY — Clearing access'
            };

            let _lastLockdown = false;
            let _lastAlarm    = false;

            function pollGlobalStatus() {
                fetch('/api/system/status')
                .then(r => r.json())
                .then(data => {
                    // ── Lockdown banner ──
                    if (data.lockdown && !_lastLockdown) {
                        lockdownBanner.style.display = 'flex';
                        document.body.classList.add('lockdown-active');
                        if (lockdownReason) lockdownReason.textContent =
                            data.lockdownReason ? '— ' + data.lockdownReason : '';
                    } else if (!data.lockdown && _lastLockdown) {
                        lockdownBanner.style.display = 'none';
                        document.body.classList.remove('lockdown-active');
                    }
                    _lastLockdown = !!data.lockdown;

                    // ── Alarm banner ──
                    if (data.alarmActive && !_lastAlarm) {
                        const label = ALARM_LABELS[data.alarmType] ||
                                      '⚠️ ALARM ACTIVE: ' + data.alarmType.toUpperCase();
                        if (alarmLabel) alarmLabel.textContent = label;
                        alarmBanner.style.display = 'flex';
                        document.body.classList.add('alarm-active');
                    } else if (!data.alarmActive && _lastAlarm) {
                        alarmBanner.style.display = 'none';
                        document.body.classList.remove('alarm-active');
                    }
                    _lastAlarm = !!data.alarmActive;
                })
                .catch(() => {});
            }

            // First poll immediately, then every 4 seconds
            pollGlobalStatus();
            setInterval(pollGlobalStatus, 4000);
        })();

        function globalResolveLockdown() {
            if (!confirm('🔓 Resolve lockdown and restore normal access?')) return;
            fetch('/api/system/lockdown/resolve', { method: 'POST' })
            .then(r => r.json())
            .then(() => {
                document.getElementById('globalLockdownBanner').style.display = 'none';
                document.body.classList.remove('lockdown-active');
                // Sync page-level banners if they exist
                const pgBanner = document.getElementById('lockdownBanner');
                if (pgBanner) pgBanner.style.display = 'none';
            })
            .catch(() => alert('❌ Failed to resolve lockdown.'));
        }

        function globalDeactivateAlarm() {
            if (!confirm('Deactivate the active alarm?')) return;
            fetch('/api/system/alarm/resolve', { method: 'POST' })
            .then(r => r.json())
            .then(() => {
                document.getElementById('globalAlarmBanner').style.display = 'none';
                document.body.classList.remove('alarm-active');
            })
            .catch(() => alert('❌ Failed to deactivate alarm.'));
        }
    </script>
</body>
</html>