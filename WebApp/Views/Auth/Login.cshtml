@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>

<div class="page-wrapper">

    <!-- LEFT PANEL -->
    <div class="left-panel">
        <div class="left-content">
            <div class="logo-circle">QCU</div>

            <h1>SecureVision</h1>
            <h3>Quezon City University</h3>

            <div class="underline"></div>

            <p class="desc">
                Advanced AI-Assisted Security & Intruder Detection Monitoring System
            </p>

            <div class="feature-box">
                <i class="fa fa-shield"></i>
                <div>
                    <strong>Real-Time Monitoring</strong>
                    <p>24/7 surveillance with instant alerts</p>
                </div>
            </div>

            <div class="feature-box">
                <i class="fa fa-lock"></i>
                <div>
                    <strong>Secure Access Control</strong>
                    <p>Role-based authentication system</p>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="right-panel">
        <div class="login-container">

            <!-- LOGIN FORM -->
            <div id="loginForm">
                <h2>Sign In</h2>
                <p class="subtitle">Enter your credentials to access the system</p>

                <form method="post" asp-action="Login">

                    <label>Username</label>
                    <div class="input-group">
                        <i class="fa fa-user"></i>
                        <input type="text" name="username" placeholder="Enter your username" required />
                    </div>

                    <label>Password</label>
                    <div class="input-group">
                        <i class="fa fa-lock"></i>
                        <input type="password" id="password" name="password" placeholder="Enter your password" required />
                        <i class="fa fa-eye right-icon" onclick="togglePassword()"></i>
                    </div>

                    <!-- Error message display (below password) -->
                    @if (ViewBag.LoginError != null)
                    {
                        <p class="error">@ViewBag.LoginError</p>
                    }

                    <div class="options">
                        <label class="remember-me">
                            <input type="checkbox" name="rememberMe" />
                            <span>Remember me</span>
                        </label>

                        <a href="#" onclick="showForgot()">Forgot password?</a>
                    </div>

                    <button type="submit">
                        <i class="fa fa-lock"></i> Sign In
                    </button>
                </form>

            </div>

            <!-- FORGOT PASSWORD FORM -->
            <div id="forgotForm" style="display:none;">
                <h2>Forgot Password</h2>
                <p class="subtitle">
                    Enter your email and we’ll send you a reset link
                </p>

                <form method="post" asp-action="ForgotPassword">

                    <label>Email</label>
                    <div class="input-group">
                        <i class="fa fa-envelope"></i>
                        <input type="email" name="email" placeholder="Enter your email" required />
                    </div>

                    <button type="submit">
                        <i class="fa fa-paper-plane"></i> Send Reset Link
                    </button>
                </form>

                <div class="options" style="margin-top:15px;">
                    <a href="#" onclick="showLogin()">← Back to Login</a>
                </div>

                @if (ViewBag.Message != null)
                {
                    <p style="color:lightgreen">@ViewBag.Message</p>
                }

                @if (ViewBag.Error != null)
                {
                    <p class="error">@ViewBag.Error</p>
                }
            </div>

        </div>
    </div>

</div>

<script>
    function togglePassword() {
        const input = document.getElementById("password");
        input.type = input.type === "password" ? "text" : "password";
    }

    function showForgot() {
        document.getElementById("loginForm").style.display = "none";
        document.getElementById("forgotForm").style.display = "block";
    }

    function showLogin() {
        document.getElementById("loginForm").style.display = "block";
        document.getElementById("forgotForm").style.display = "none";
    }

    // Optional: auto-switch if coming from ForgotPassword with message/error
    window.onload = function () {
        const hasMessage = '@ViewBag.Message';
        if (hasMessage) {
            showForgot();
        }
    }
</script>

</body>
</html>