@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - Smart Security System</title>
    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="stylesheet" href="/lib/fontawesome/css/all.min.css" />
</head>
<body>
    <div class="page-wrapper">
        <div class="login-container">
            <h2><i class="fa fa-key"></i> Update Password</h2>
            <p class="subtitle">Your account is currently using a temporary password. Please set a new one to continue.</p>

            <form asp-action="ForcedChangePassword" method="post">
                <!-- Hidden input para sa UserId -->
                <input type="hidden" name="userId" value="@ViewBag.UserId" />

                <div class="form-group">
                    <label>New Password</label>
                    <div class="input-group">
                        <i class="fa fa-lock"></i>
                        <input type="password" name="newPassword" placeholder="Enter new password" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Confirm New Password</label>
                    <div class="input-group">
                        <i class="fa fa-lock"></i>
                        <input type="password" name="confirmPassword" placeholder="Confirm new password" required />
                    </div>
                </div>

                @if (ViewBag.Error != null)
                {
                    <p class="error-text" style="color: red; font-size: 0.9rem; margin-bottom: 10px;">
                        <i class="fa fa-exclamation-circle"></i> @ViewBag.Error
                    </p>
                }

                <button type="submit" class="btn-login">
                    <i class="fa fa-save"></i> Save and Login
                </button>
            </form>
        </div>
    </div>
</body>
</html>