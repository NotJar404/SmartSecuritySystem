@model List<WebApp.Models.LogEntry>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Activity Logs";
}

<link rel="stylesheet" href="~/css/logs.css" />
<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="dashboard-container">

    <!-- ===================== -->
    <!-- HEADER -->
    <!-- ===================== -->
    <header class="cmd-header d-flex justify-content-between align-items-center mb-3">

        <div>
            <h2 class="mb-0">Activity Logs</h2>
            <small class="text-muted">System activity and user actions</small>
        </div>

        <div>
            <span class="live-badge">● SYSTEM ACTIVE</span>
        </div>

    </header>

<div class="logs-container">

    @foreach (var log in Model)
    {
        <div class="log-card">

            <!-- ICON -->
            <div class="log-icon">
                📝
            </div>

            <!-- CONTENT -->
            <div class="log-content">
                <h3>@log.Action</h3>
                <p>@log.Details</p>

                <div class="log-meta">
                    👤 @log.User
                    • 🌐 @log.IpAddress
                    • ⏱ @((DateTime.Now - log.Timestamp).Minutes)m ago
                </div>
            </div>

            <!-- TIME -->
            <div class="log-time">
                @log.Timestamp.ToString("g")
            </div>

        </div>
    }

</div>

</div>