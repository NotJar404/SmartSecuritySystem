@model SmartSecuritySystem.ViewModels.PersonnelManagementViewModel
@{
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";
}

<link rel="stylesheet" href="~/css/personnel.css" />

<div class="dashboard-container">

    <header class="cmd-header d-flex justify-content-between align-items-center mb-3">

        <div>
            <h2 class="mb-0">Personnel Management</h2>
            <small class="text-muted">Manage system access and employee profiles</small>
        </div>

        <div>
            <button class="btn-export"
                    data-toggle="modal"
                    data-target="#userModal"
                    onclick="openAddModal()">
                <i class="fa fa-user-plus"></i> Register Account
            </button>
        </div>

    </header>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="stat-icon-circle" style="background: rgba(212,163,115,0.15); color: var(--accent);">
                    <i class="fas fa-users-cog"></i>
                </div>
                <div>
                    <h3>@Model.SystemUsers.Count()</h3>
                    <small>System Operators</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="stat-icon-circle" style="background: rgba(196,48,43,0.15); color: var(--status-locked);">
                    <i class="fas fa-id-badge"></i>
                </div>
                <div>
                    <h3>@Model.CampusMembers.Count()</h3>
                    <small>Authorized Members</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="stat-icon-circle" style="background: rgba(45,122,86,0.15); color: var(--status-active);">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div>
                    <h3>@Model.CampusMembers.Count(m => m.Department != null)</h3>
                    <small>Departments Active</small>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================ -->
    <!-- TABLES — STACKED VERTICALLY (FULL WIDTH)     -->
    <!-- ============================================ -->
    <div class="row personnel-tables">

        <!-- DASHBOARD OPERATORS TABLE -->
        <div class="col-xl-12 mb-4">
            <div class="card">

                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Dashboard Operators</h5>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="staffSearch" class="form-control form-control-sm" placeholder="Search operators..." onkeyup="liveSearch('staffTable', 'staffSearch')">
                    </div>
                </div>

                <div style="max-height:420px; overflow-y:auto;">
                    <table class="table table-hover mb-0" id="staffTable">

                        <thead>
                            <tr>
                                <th>User</th>
                                <th class="text-center">Status</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var user in Model.SystemUsers)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm mr-2">
                                                @user.FullName.Substring(0,1).ToUpper()
                                            </div>
                                            <div>
                                                <div class="font-weight-bold">@user.FullName</div>
                                                <small class="text-muted search-meta">@user.Username | @user.Role</small>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        <span class="status-pill @user.Status.ToLower()">
                                            @user.Status
                                        </span>
                                    </td>

                                    <td class="text-right">
                                        <button class="btn btn-link btn-sm"
                                                onclick='openEditStaff(
                                                    @user.Id,
                                                    @Html.Raw(Json.Serialize(user.FullName)),
                                                    @Html.Raw(Json.Serialize(user.Username)),
                                                    @Html.Raw(Json.Serialize(user.Email)))'>
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        @if (user.Role != "Admin")
                                        {
                                            <form method="post" asp-action="Delete" asp-controller="Personnel" style="display:inline;" id="deleteStaff-@user.Id">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="button"
                                                        class="btn btn-link text-danger btn-sm"
                                                        onclick="SecureConfirm.confirmDelete('@user.FullName', function() { document.getElementById('deleteStaff-@user.Id').submit(); })">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>

        <!-- AUTHORIZED PERSONNEL TABLE -->
        <div class="col-xl-12 mb-4">
            <div class="card">

                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Authorized Personnel</h5>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="memberSearch" class="form-control form-control-sm" placeholder="Search members..." onkeyup="liveSearch('memberTable', 'memberSearch')">
                    </div>
                </div>

                <div style="max-height:420px; overflow-y:auto;">
                    <table class="table table-hover mb-0" id="memberTable">

                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Dept / RFID</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var m in Model.CampusMembers)
                            {
                                <tr>
                                    <td>
                                        <div class="font-weight-bold">@m.FullName</div>
                                        <small class="text-muted search-meta">@m.Email</small>
                                    </td>

                                    <td>
                                        <small class="d-block search-meta">@m.Department</small>
                                        <code>@m.RfidTag</code>
                                    </td>

                                    <td class="text-right">
                                        <button class="btn btn-link btn-sm"
                                                onclick='openEditMember(
                                                    @m.Id,
                                                    @Html.Raw(Json.Serialize(m.FullName)),
                                                    @Html.Raw(Json.Serialize(m.Email)),
                                                    @Html.Raw(Json.Serialize(m.Department)),
                                                    @Html.Raw(Json.Serialize(m.RfidTag)),
                                                    @Html.Raw(Json.Serialize(m.Phone)))'>
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        <form method="post" asp-action="DeleteMember" asp-controller="Personnel" style="display:inline;" id="deleteMember-@m.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@m.Id" />
                                            <button type="button"
                                                    class="btn btn-link text-danger btn-sm"
                                                    onclick="SecureConfirm.confirmDelete('@m.FullName', function() { document.getElementById('deleteMember-@m.Id').submit(); })">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>

    </div>
</div>

<!-- ============================================ -->
<!-- ADD MODAL (UNCHANGED STRUCTURE)              -->
<!-- ============================================ -->
<div class="modal fade" id="userModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">

        <div class="modal-content">

            <form method="post" id="userForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="userId" name="Id" />
                <input type="hidden" id="personIdField" name="personId" />
                <input type="hidden" id="formMode" value="add" />

                <div class="modal-header d-flex justify-content-between align-items-center">

                    <h5 id="modalTitle" class="mb-0">Register Account</h5>

                    <button type="button"
                            class="close"
                            data-dismiss="modal"
                            aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>

                </div>

                <div class="modal-body">

                    <div class="form-group">
                        <label>Account Type</label>
                        <select id="RegType" name="RegType" class="form-control" onchange="toggleFields()">
                            <option value="staff">System Operator</option>
                            <option value="campus">Authorized Personnel (RFID)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Full Name</label>
                        <input id="fullName" name="FullName" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Email <small style="color:var(--accent);">(Gmail only)</small></label>
                        <input id="email" name="Email" type="email" class="form-control" placeholder="name@gmail.com" required pattern=".*@@gmail\.com$" title="Only Gmail addresses are accepted" />
                    </div>

                    <div id="staffFields" style="display:none;">
                        <div class="form-group">
                            <label>Username</label>
                            <input id="username" name="Username" class="form-control" />
                        </div>
                        <div class="form-group" style="background:var(--bg-input);padding:12px;border-radius:var(--radius-sm);">
                            <small style="color:var(--text-dim);">
                                <i class="fas fa-info-circle" style="color:var(--accent);"></i>
                                A secure temporary password will be auto-generated and sent to the provided Gmail address.
                                The user must change it upon first login.
                            </small>
                        </div>
                    </div>

                    <div id="campusFields" style="display:none;">
                        <div class="form-group">
                            <label>Profile Image</label>
                            <input id="profileImage" name="ProfileImage" type="file" accept="image/*" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>RFID Tag</label>
                            <input id="rfidTag" name="RfidTag" class="form-control" placeholder="Enter RFID tag ID" />
                        </div>
                        <div class="form-group">
                            <label>Department</label>
                            <input id="department" name="Department" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input id="phoneNumber" name="Phone" type="tel" class="form-control" />
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light btn-sm" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
<script>
// =====================================================
// SEARCH FUNCTIONALITY
// =====================================================
function liveSearch(tableId, inputId) {
    const input = document.getElementById(inputId);
    const filter = input.value.toUpperCase();
    const table = document.getElementById(tableId);
    const tr = table.getElementsByTagName("tr");

    for (let i = 1; i < tr.length; i++) {
        const rowText = tr[i].textContent || tr[i].innerText;
        if (rowText.toUpperCase().indexOf(filter) > -1) {
            tr[i].style.display = "";
        } else {
            tr[i].style.display = "none";
        }
    }
}

// =====================================================
// SHORTCUT FILTER
// =====================================================
function applyQuickFilter(tableId, term) {
    const searchInputId = tableId === 'staffTable' ? 'staffSearch' : 'memberSearch';
    const input = document.getElementById(searchInputId);
    input.value = term;
    liveSearch(tableId, searchInputId);
}

// =====================================================
// ADD MODAL (NEW RECORD)
// =====================================================
function openAddModal() {
    document.getElementById("userForm").reset();
    document.getElementById("modalTitle").innerText = "Register Account";
    document.getElementById("userForm").action = "/Personnel/Add";
    document.getElementById("userId").value = "0";
    document.getElementById("personIdField").value = "0";
    document.getElementById("formMode").value = "add";
    document.getElementById("RegType").value = "staff";
    document.getElementById("RegType").disabled = false;
    toggleFields();
    
    // Show modal
    const modal = document.getElementById('userModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// =====================================================
// EDIT STAFF (SYSTEM OPERATOR)
// =====================================================
function openEditStaff(id, name, user, email) {
    document.getElementById("userForm").reset();
    document.getElementById("modalTitle").innerText = "Edit System Operator";
    document.getElementById("userForm").action = "/Personnel/Edit";
    document.getElementById("userId").value = id;
    document.getElementById("personIdField").value = "";
    document.getElementById("formMode").value = "editStaff";
    document.getElementById("fullName").value = name;
    document.getElementById("email").value = email;
    document.getElementById("RegType").value = "staff";
    document.getElementById("RegType").disabled = true;

    if (document.getElementById("username")) {
        document.getElementById("username").value = user || "";
    }

    toggleFields();

    // Show modal
    const modal = document.getElementById('userModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// =====================================================
// EDIT MEMBER (AUTHORIZED PERSONNEL)
// =====================================================
function openEditMember(id, name, email, dept, rfid, phone) {
    document.getElementById("userForm").reset();
    document.getElementById("modalTitle").innerText = "Edit Authorized Personnel";
    document.getElementById("userForm").action = "/Personnel/EditMember";
    document.getElementById("userId").value = "";
    document.getElementById("personIdField").value = id;
    document.getElementById("formMode").value = "editMember";
    document.getElementById("fullName").value = name;
    document.getElementById("email").value = email || "";
    document.getElementById("RegType").value = "campus";
    document.getElementById("RegType").disabled = true;

    if (document.getElementById("department")) {
        document.getElementById("department").value = dept || "";
    }
    if (document.getElementById("rfidTag")) {
        document.getElementById("rfidTag").value = rfid || "";
    }
    if (document.getElementById("phoneNumber")) {
        document.getElementById("phoneNumber").value = phone || "";
    }

    toggleFields();

    // Show modal
    const modal = document.getElementById('userModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// =====================================================
// TOGGLE FIELDS BASED ON TYPE
// =====================================================
function toggleFields() {
    const type = document.getElementById("RegType").value;
    document.getElementById("staffFields").style.display = (type === "staff") ? "block" : "none";
    document.getElementById("campusFields").style.display = (type === "campus") ? "block" : "none";
}

// =====================================================
// CLOSE MODAL
// =====================================================
function closeModal() {
    const modal = document.getElementById('userModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
    // Re-enable RegType in case it was disabled
    document.getElementById("RegType").disabled = false;
}

// =====================================================
// EVENT LISTENERS
// =====================================================
document.addEventListener('DOMContentLoaded', function() {
    const closeBtn = document.querySelector('#userModal .close');
    if (closeBtn) {
        closeBtn.addEventListener('click', closeModal);
    }
    
    const cancelBtn = document.querySelector('#userModal .modal-footer .btn-light');
    if (cancelBtn) {
        cancelBtn.addEventListener('click', closeModal);
    }
    
    const modal = document.getElementById('userModal');
    modal.addEventListener('click', function(event) {
        if (event.target === modal) {
            closeModal();
        }
    });

    // Intercept personnel form with two-step confirmation
    SecureConfirm.interceptForm('userForm', 'Confirm Personnel Action', 'userModal');
});
</script>
}