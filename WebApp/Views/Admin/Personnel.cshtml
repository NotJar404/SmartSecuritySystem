@model SmartSecuritySystem.ViewModels.PersonnelManagementViewModel
@{
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";
}

<link rel="stylesheet" href="~/css/personnel.css" />

<div class="dashboard-container">

    <header class="cmd-header d-flex justify-content-between align-items-center mb-3">

        <div>
            <h2 class="mb-0">Personnel Management</h2>
            <small class="text-muted">Manage system access and employee profiles</small>
        </div>

        <div>
            <button class="btn-export"
                    data-toggle="modal"
                    data-target="#userModal"
                    onclick="openAddModal()">
                <i class="fa fa-user-plus"></i> Register Account
            </button>
        </div>

    </header>

    @if (TempData["Warning"] != null)
    {
        <div class="alert-banner" style="background:rgba(243,156,18,0.12);border:1px solid rgba(243,156,18,0.3);border-radius:8px;padding:14px 18px;margin-bottom:16px;color:#f39c12;font-size:13px;">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Warning"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert-banner" style="background:rgba(46,204,113,0.12);border:1px solid rgba(46,204,113,0.3);border-radius:8px;padding:14px 18px;margin-bottom:16px;color:#2ecc71;font-size:13px;">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-banner" style="background:rgba(231,76,60,0.12);border:1px solid rgba(231,76,60,0.3);border-radius:8px;padding:14px 18px;margin-bottom:16px;color:#e74c3c;font-size:13px;">
            <i class="fas fa-times-circle me-2"></i>@TempData["Error"]
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="stat-icon-circle" style="background: rgba(212,163,115,0.15); color: var(--accent);">
                    <i class="fas fa-users-cog"></i>
                </div>
                <div>
                    <h3 id="statOperators">@Model.SystemUsers.Count()</h3>
                    <small>System Operators</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="stat-icon-circle" style="background: rgba(196,48,43,0.15); color: var(--status-locked);">
                    <i class="fas fa-id-badge"></i>
                </div>
                <div>
                    <h3 id="statMembers">@Model.CampusMembers.Count()</h3>
                    <small>Authorized Members</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="stat-icon-circle" style="background: rgba(45,122,86,0.15); color: var(--status-active);">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div>
                    <h3 id="statDepartments">@Model.CampusMembers.Select(m => m.Department).Where(d => !string.IsNullOrEmpty(d)).Distinct().Count()</h3>
                    <small>Departments Active</small>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================ -->
    <!-- TABLES — STACKED VERTICALLY (FULL WIDTH)     -->
    <!-- ============================================ -->
    <div class="row personnel-tables">

        <!-- DASHBOARD OPERATORS TABLE -->
        <div class="col-xl-12 mb-4">
            <div class="card">

                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Dashboard Operators</h5>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="staffSearch" class="form-control form-control-sm" placeholder="Search operators..." onkeyup="liveSearch('staffTable', 'staffSearch')">
                    </div>
                </div>

                <div class="table-scroll-wrap">
                    <table class="table table-hover mb-0" id="staffTable">

                        <thead>
                            <tr>
                                <th>User</th>
                                <th class="text-center">Status</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var user in Model.SystemUsers)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm mr-2">
                                                @user.FullName.Substring(0,1).ToUpper()
                                            </div>
                                            <div>
                                                <div class="font-weight-bold">@user.FullName</div>
                                                <small class="text-muted search-meta">@user.Username | @user.Role</small>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        <span class="status-pill @user.Status.ToLower()">
                                            @user.Status
                                        </span>
                                    </td>

                                    <td class="text-right">
                                        <button class="btn btn-link btn-sm"
                                                onclick='openEditStaff(
                                                    @user.Id,
                                                    @Html.Raw(Json.Serialize(user.FullName)),
                                                    @Html.Raw(Json.Serialize(user.Username)),
                                                    @Html.Raw(Json.Serialize(user.Email)))'>
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        @if (user.Role != "Admin")
                                        {
                                            <form method="post" asp-action="Delete" asp-controller="Personnel" style="display:inline;" id="deleteStaff-@user.Id">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="button"
                                                        class="btn btn-link text-danger btn-sm"
                                                        onclick="SecureConfirm.confirmDelete('@user.FullName', function() { document.getElementById('deleteStaff-@user.Id').submit(); })">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>

        <!-- AUTHORIZED PERSONNEL TABLE -->
        <div class="col-xl-12 mb-4">
            <div class="card">

                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Authorized Personnel</h5>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="memberSearch" class="form-control form-control-sm" placeholder="Search members..." onkeyup="liveSearch('memberTable', 'memberSearch')">
                    </div>
                </div>

                <div class="table-scroll-wrap">
                    <table class="table table-hover mb-0" id="memberTable">

                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Dept / RFID</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var m in Model.CampusMembers)
                            {
                                <tr>
                                    <td>
                                        <div class="font-weight-bold">
                                            @* Profile photo avatar *@
                                            @if (!string.IsNullOrEmpty(m.ProfileImagePath))
                                            {
                                                <img src="@m.ProfileImagePath" alt="@m.FullName"
                                                     style="width:32px;height:32px;border-radius:50%;object-fit:cover;
                                                            border:2px solid var(--accent);margin-right:8px;vertical-align:middle;" />
                                            }
                                            else
                                            {
                                                <span class="avatar-sm mr-2" style="width:32px;height:32px;font-size:13px;">
                                                    @m.FullName.Substring(0, 1).ToUpper()
                                                </span>
                                            }
                                            @m.FullName
                                        </div>
                                        <small class="text-muted search-meta">@m.Email</small>
                                        @if (m.HasFaceData)
                                        {
                                            <span id="face-badge-@m.Id"
                                                  style="display:inline-block;padding:1px 6px;border-radius:3px;font-size:10px;font-weight:600;background:rgba(46,204,113,0.15);color:#2ecc71;">
                                                <i class="fas fa-user-check"></i> Face ✓
                                            </span>
                                        }
                                        else
                                        {
                                            <span id="face-badge-@m.Id"
                                                  style="display:inline-block;padding:1px 6px;border-radius:3px;font-size:10px;font-weight:600;background:rgba(243,156,18,0.15);color:#f39c12;">
                                                <i class="fas fa-exclamation-triangle"></i> No Face
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <small class="d-block search-meta">@m.Department</small>
                                        <code>@m.RfidTag</code>
                                        @if (m.RoomCount == 0)
                                        {
                                            <span id="room-badge-@m.Id"
                                                  style="display:inline-block;margin-left:6px;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;background:rgba(243,156,18,0.15);color:#f39c12;"
                                                  title="No room access assigned — will be denied at all doors">
                                                <i class="fas fa-exclamation-triangle me-1"></i>No rooms
                                            </span>
                                        }
                                        else
                                        {
                                            <span id="room-badge-@m.Id"
                                                  style="display:inline-block;margin-left:6px;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;background:rgba(46,204,113,0.15);color:#2ecc71;">
                                                <i class="fas fa-door-open me-1"></i>@m.RoomCount room@(m.RoomCount > 1 ? "s" : "")
                                            </span>
                                        }
                                    </td>

                                    <td class="text-right">
                                        <button class="btn btn-link btn-sm" title="Room Access"
                                                onclick='openRoomAccess(@m.Id, @Html.Raw(Json.Serialize(m.FullName)))'>
                                            <i class="fas fa-door-open" style="color:var(--accent);"></i>
                                        </button>
                                        <button class="btn btn-link btn-sm"
                                                onclick='openEditMember(
                                                    @m.Id,
                                                    @Html.Raw(Json.Serialize(m.FullName)),
                                                    @Html.Raw(Json.Serialize(m.Email)),
                                                    @Html.Raw(Json.Serialize(m.Department)),
                                                    @Html.Raw(Json.Serialize(m.RfidTag)),
                                                    @Html.Raw(Json.Serialize(m.Phone)),
                                                    @Html.Raw(Json.Serialize(m.ProfileImagePath ?? "")))'>
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        <form method="post" asp-action="DeleteMember" asp-controller="Personnel" style="display:inline;" id="deleteMember-@m.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@m.Id" />
                                            <button type="button"
                                                    class="btn btn-link text-danger btn-sm"
                                                    onclick="SecureConfirm.confirmDelete('@m.FullName', function() { document.getElementById('deleteMember-@m.Id').submit(); })">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>

    </div>
</div>

<!-- ============================================ -->
<!-- ADD MODAL (UNCHANGED STRUCTURE)              -->
<!-- ============================================ -->
<div class="modal fade" id="userModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">

        <div class="modal-content">

            <form method="post" id="userForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" id="userId" name="Id" />
                <input type="hidden" id="personIdField" name="personId" />
                <input type="hidden" id="formMode" value="add" />

                <div class="modal-header d-flex justify-content-between align-items-center">

                    <h5 id="modalTitle" class="mb-0">Register Account</h5>

                    <button type="button"
                            class="close"
                            data-dismiss="modal"
                            aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>

                </div>

                <div class="modal-body">

                    <div class="form-group">
                        <label>Account Type</label>
                        <select id="RegType" name="RegType" class="form-control" onchange="toggleFields()">
                            <option value="staff">System Operator</option>
                            <option value="campus">Authorized Personnel (RFID)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Full Name</label>
                        <input id="fullName" name="FullName" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Email <small style="color:var(--accent);">(Gmail only)</small></label>
                        <input id="email" name="Email" type="email" class="form-control" placeholder="name@gmail.com" required pattern=".*@@gmail\.com$" title="Only Gmail addresses are accepted" />
                    </div>

                    <div id="staffFields" style="display:none;">
                        <div class="form-group">
                            <label>Username</label>
                            <input id="username" name="Username" class="form-control" />
                        </div>
                        <div class="form-group" style="background:var(--bg-input);padding:12px;border-radius:var(--radius-sm);">
                            <small style="color:var(--text-dim);">
                                <i class="fas fa-info-circle" style="color:var(--accent);"></i>
                                A secure temporary password will be auto-generated and sent to the provided Gmail address.
                                The user must change it upon first login.
                            </small>
                        </div>
                    </div>

                    <div id="campusFields" style="display:none;">
                        <div class="form-group">
                            <label>Profile Photo <small style="color:var(--accent);">(Required for face verification)</small></label>

                            <!-- Photo source tab switcher -->
                            <div style="display:flex;gap:6px;margin-bottom:10px;">
                                <button type="button" id="tabUpload" onclick="setPhotoTab('upload')"
                                        style="flex:1;padding:6px 10px;border-radius:6px;border:1.5px solid var(--accent);background:var(--accent);color:#fff;font-size:12px;cursor:pointer;">
                                    📁 Upload File
                                </button>
                                <button type="button" id="tabCamera" onclick="setPhotoTab('camera')"
                                        style="flex:1;padding:6px 10px;border-radius:6px;border:1.5px solid var(--accent);background:transparent;color:var(--accent);font-size:12px;cursor:pointer;">
                                    📷 Use Pi Camera
                                </button>
                            </div>

                            <!-- Preview (shared) -->
                            <div id="photoPreviewWrap" style="display:none;margin-bottom:8px;text-align:center;">
                                <img id="photoPreview" src="" alt="Preview"
                                     style="width:90px;height:90px;border-radius:50%;object-fit:cover;
                                            border:2px solid var(--accent);" />
                            </div>

                            <!-- Upload panel -->
                            <div id="panelUpload">
                                <input id="profileImage" name="ProfileImage" type="file" accept="image/*"
                                       class="form-control"
                                       onchange="previewPhoto(this)" />
                                <small style="color:var(--text-dim);display:block;margin-top:4px;">
                                    Upload a clear, front-facing photo for face recognition.
                                </small>
                            </div>

                            <!-- Pi Camera capture panel -->
                            <div id="panelCamera" style="display:none;">
                                <div style="margin-bottom:6px;display:flex;gap:6px;align-items:center;">
                                    <input id="piStreamUrl" type="text" class="form-control"
                                           value="http://raspberrypi.local:5050/video"
                                           placeholder="Pi stream URL (e.g. http://192.168.x.x:5050/video)"
                                           style="font-size:11px;flex:1;" />
                                    <button type="button" onclick="startEnrollStream()"
                                            style="padding:5px 10px;border-radius:6px;background:var(--accent);color:#fff;border:none;white-space:nowrap;cursor:pointer;font-size:12px;">
                                        ▶ Connect
                                    </button>
                                </div>

                                <!-- Live stream display with face guide -->
                                <div style="position:relative;display:inline-block;width:100%;max-width:320px;">
                                    <img id="enrollStreamImg" src="" alt="Connecting..."
                                         style="width:100%;border-radius:8px;border:2px solid var(--border);display:block;background:#111;min-height:180px;" />
                                    <!-- Oval face guide overlay -->
                                    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-55%);
                                                width:90px;height:110px;border:2px dashed rgba(255,200,100,0.75);
                                                border-radius:50%;pointer-events:none;"></div>
                                    <div style="position:absolute;bottom:6px;left:0;right:0;text-align:center;
                                                font-size:10px;color:rgba(255,255,255,0.7);">
                                        Align face within the oval then capture
                                    </div>
                                </div>
                                <canvas id="enrollCanvas" style="display:none;"></canvas>

                                <div style="margin-top:8px;display:flex;gap:6px;">
                                    <button type="button" id="btnCapture" onclick="captureEnrollFrame()" disabled
                                            style="flex:1;padding:6px;border-radius:6px;background:#2ecc71;color:#fff;border:none;cursor:pointer;font-size:12px;">
                                        📷 Capture
                                    </button>
                                    <button type="button" id="btnEnrollNow" onclick="enrollNow()" disabled
                                            style="flex:1;padding:6px;border-radius:6px;background:#3498db;color:#fff;border:none;cursor:pointer;font-size:12px;">
                                        ✅ Enroll Now
                                    </button>
                                </div>
                                <div id="enrollMsg" style="margin-top:6px;font-size:11px;color:var(--text-dim);"></div>
                                <!-- Hidden input carries captured image into normal form POST -->
                                <input type="hidden" id="capturedImageData" name="CapturedImageData" value="" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>RFID Tag</label>
                            <input id="rfidTag" name="RfidTag" class="form-control" placeholder="Enter RFID tag ID" />
                        </div>
                        <div class="form-group">
                            <label>Department</label>
                            <input id="department" name="Department" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input id="phoneNumber" name="Phone" type="tel" class="form-control" />
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light btn-sm" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>

            </form>

        </div>

    </div>
</div>

<!-- ============================================ -->
<!-- ROOM ACCESS ASSIGNMENT MODAL                 -->
<!-- ============================================ -->
<div class="modal fade" id="roomAccessModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">

        <div class="modal-content">

            <div class="modal-header d-flex justify-content-between align-items-center">

                <h5 id="roomModalTitle" class="mb-0">Room Access Assignment</h5>

                <button type="button"
                        class="close"
                        onclick="closeRoomModal()"
                        aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>

            </div>

            <div class="modal-body" style="max-height:70vh; overflow-y:auto;">
                <input type="hidden" id="roomPersonId" />

                <div class="form-group" style="background:var(--bg-input);padding:12px;border-radius:var(--radius-sm);margin-bottom:16px;">
                    <small style="color:var(--text-dim);">
                        <i class="fas fa-user me-1" style="color:var(--accent);"></i>
                        Managing access for: <strong id="roomPersonName" style="color:var(--text-main);"></strong>
                    </small>
                </div>

                <div class="form-group">
                    <label>Select Room</label>
                    <select id="roomSelect" class="form-control"></select>
                </div>

                <div class="form-group">
                    <button class="btn btn-primary btn-sm w-100" onclick="assignRoom()">
                        <i class="fa fa-plus me-1"></i>Assign Room Access
                    </button>
                </div>

                <hr style="border-color:var(--border); margin: 16px 0;" />

                <div class="form-group">
                    <label>Currently Assigned Rooms</label>
                    <div id="roomMsg" style="display:none;font-size:12px;font-weight:600;margin-top:4px;"></div>
                    <div id="roomList" style="min-height:60px; margin-top:8px;">
                        <p class="text-muted small text-center">Loading...</p>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" onclick="closeRoomModal()">Close</button>
            </div>

        </div>

    </div>
</div>

@section Scripts {
<script>
// =====================================================
// SEARCH FUNCTIONALITY
// =====================================================
function liveSearch(tableId, inputId) {
    const input = document.getElementById(inputId);
    const filter = input.value.toUpperCase();
    const table = document.getElementById(tableId);
    const tr = table.getElementsByTagName("tr");

    for (let i = 1; i < tr.length; i++) {
        const rowText = tr[i].textContent || tr[i].innerText;
        if (rowText.toUpperCase().indexOf(filter) > -1) {
            tr[i].style.display = "";
        } else {
            tr[i].style.display = "none";
        }
    }
}

// =====================================================
// SHORTCUT FILTER
// =====================================================
function applyQuickFilter(tableId, term) {
    const searchInputId = tableId === 'staffTable' ? 'staffSearch' : 'memberSearch';
    const input = document.getElementById(searchInputId);
    input.value = term;
    liveSearch(tableId, searchInputId);
}

// =====================================================
// ADD MODAL (NEW RECORD)
// =====================================================
function openAddModal() {
    document.getElementById("userForm").reset();
    document.getElementById("modalTitle").innerText = "Register Account";
    document.getElementById("userForm").action = "/Personnel/Add";
    document.getElementById("userId").value = "0";
    document.getElementById("personIdField").value = "0";
    document.getElementById("formMode").value = "add";
    document.getElementById("RegType").value = "staff";
    document.getElementById("RegType").disabled = false;

    // Restore email validation for new registrations
    const emailEl = document.getElementById('email');
    emailEl.setAttribute('required', '');
    emailEl.setAttribute('pattern', '.*@@gmail\\.com$');

    // Reset photo preview
    const wrap = document.getElementById('photoPreviewWrap');
    const preview = document.getElementById('photoPreview');
    if (wrap) wrap.style.display = 'none';
    if (preview) preview.src = '';

    toggleFields();
    
    // Show modal
    const modal = document.getElementById('userModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// =====================================================
// EDIT STAFF (SYSTEM OPERATOR)
// =====================================================
function openEditStaff(id, name, user, email) {
    document.getElementById("userForm").reset();
    document.getElementById("modalTitle").innerText = "Edit System Operator";
    document.getElementById("userForm").action = "/Personnel/Edit";
    document.getElementById("userId").value = id;
    document.getElementById("personIdField").value = "";
    document.getElementById("formMode").value = "editStaff";
    document.getElementById("fullName").value = name;
    document.getElementById("email").value = email;
    document.getElementById("RegType").value = "staff";
    document.getElementById("RegType").disabled = true;

    if (document.getElementById("username")) {
        document.getElementById("username").value = user || "";
    }

    toggleFields();

    // Show modal
    const modal = document.getElementById('userModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// =====================================================
// EDIT MEMBER (AUTHORIZED PERSONNEL)
// =====================================================
function openEditMember(id, name, email, dept, rfid, phone, profileImgSrc) {
    document.getElementById("userForm").reset();
    document.getElementById("modalTitle").innerText = "Edit Authorized Personnel";
    document.getElementById("userForm").action = "/Personnel/EditMember";
    document.getElementById("userId").value = "";
    document.getElementById("personIdField").value = id;
    document.getElementById("formMode").value = "editMember";
    document.getElementById("fullName").value = name;
    document.getElementById("email").value = email || "";
    document.getElementById("RegType").value = "campus";
    document.getElementById("RegType").disabled = true;

    // Email is optional for campus members — remove HTML5 validation so Save is never blocked
    const emailEl = document.getElementById('email');
    emailEl.removeAttribute('required');
    emailEl.removeAttribute('pattern');

    if (document.getElementById("department")) {
        document.getElementById("department").value = dept || "";
    }
    if (document.getElementById("rfidTag")) {
        document.getElementById("rfidTag").value = rfid || "";
    }
    if (document.getElementById("phoneNumber")) {
        document.getElementById("phoneNumber").value = phone || "";
    }

    // Show existing profile photo if available
    const wrap = document.getElementById('photoPreviewWrap');
    const preview = document.getElementById('photoPreview');
    if (profileImgSrc && wrap && preview) {
        preview.src = profileImgSrc;
        wrap.style.display = 'block';
    } else if (wrap) {
        wrap.style.display = 'none';
        if (preview) preview.src = '';
    }

    toggleFields();

    // Show modal
    const modal = document.getElementById('userModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

// =====================================================
// PHOTO PREVIEW
// =====================================================
function previewPhoto(input) {
    const wrap = document.getElementById('photoPreviewWrap');
    const preview = document.getElementById('photoPreview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            wrap.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    } else {
        wrap.style.display = 'none';
        preview.src = '';
    }
}

// =====================================================
// TOGGLE FIELDS BASED ON TYPE
// =====================================================
function toggleFields() {
    const type = document.getElementById("RegType").value;
    document.getElementById("staffFields").style.display = (type === "staff") ? "block" : "none";
    document.getElementById("campusFields").style.display = (type === "campus") ? "block" : "none";
}

// =====================================================
// CLOSE MODAL
// =====================================================
function closeModal() {
    const modal = document.getElementById('userModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
    // Re-enable RegType in case it was disabled
    document.getElementById("RegType").disabled = false;
}

// =====================================================
// EVENT LISTENERS
// =====================================================
document.addEventListener('DOMContentLoaded', function() {
    const closeBtn = document.querySelector('#userModal .close');
    if (closeBtn) {
        closeBtn.addEventListener('click', closeModal);
    }
    
    const cancelBtn = document.querySelector('#userModal .modal-footer .btn-light');
    if (cancelBtn) {
        cancelBtn.addEventListener('click', closeModal);
    }
    
    const modal = document.getElementById('userModal');
    modal.addEventListener('click', function(event) {
        if (event.target === modal) {
            closeModal();
        }
    });

    // Intercept personnel form with two-step confirmation
    SecureConfirm.interceptForm('userForm', 'Confirm Personnel Action', 'userModal');

    // Close room modal on backdrop click
    const roomModal = document.getElementById('roomAccessModal');
    if (roomModal) {
        roomModal.addEventListener('click', function(e) { if (e.target === roomModal) closeRoomModal(); });
    }
});

// =====================================================
// ROOM ACCESS MANAGEMENT
// =====================================================
let _currentRoomPersonId = null;

function openRoomAccess(personId, personName) {
    _currentRoomPersonId = personId;
    document.getElementById('roomPersonId').value = personId;
    document.getElementById('roomPersonName').innerText = personName;

    // Load available rooms
    fetch('/api/access/rooms')
        .then(r => r.ok ? r.json() : Promise.reject('Auth error — please refresh'))
        .then(rooms => {
            const sel = document.getElementById('roomSelect');
            sel.innerHTML = rooms.map(r => `<option value="${r.roomId}">${r.roomName}</option>`).join('');
        })
        .catch(err => showRoomMsg('Could not load rooms: ' + err, 'error'));

    // Load current assignments
    loadRoomAssignments(personId);

    // Show modal
    const modal = document.getElementById('roomAccessModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeRoomModal() {
    const modal = document.getElementById('roomAccessModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

function showRoomMsg(msg, type) {
    const el = document.getElementById('roomMsg');
    if (!el) return;
    el.textContent = msg;
    el.style.color = type === 'error' ? '#e74c3c' : '#2ecc71';
    el.style.display = 'block';
    setTimeout(() => { el.style.display = 'none'; }, 3000);
}

function updatePersonBadge(personId, count) {
    const badge = document.getElementById('room-badge-' + personId);
    if (!badge) return;
    if (count === 0) {
        badge.style.background = 'rgba(243,156,18,0.15)';
        badge.style.color = '#f39c12';
        badge.title = 'No room access assigned — will be denied at all doors';
        badge.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i>No rooms';
    } else {
        badge.style.background = 'rgba(46,204,113,0.15)';
        badge.style.color = '#2ecc71';
        badge.title = '';
        badge.innerHTML = '<i class="fas fa-door-open me-1"></i>' + count + ' room' + (count > 1 ? 's' : '');
    }
}

function loadRoomAssignments(personId) {
    fetch(`/api/access/room-list?personId=${personId}`)
        .then(r => r.ok ? r.json() : Promise.reject('Auth error'))
        .then(list => {
            const container = document.getElementById('roomList');
            if (!list.length) {
                container.innerHTML = '<p class="text-muted small text-center">No rooms assigned — access will be denied at all doors.</p>';
            } else {
                container.innerHTML = list.map(a => `
                    <div class="d-flex justify-content-between align-items-center mb-2" style="padding:8px 10px;background:var(--bg-input);border-radius:6px;border:1px solid var(--border);">
                        <div>
                            <strong style="font-size:13px;">${a.roomName}</strong>
                            <small class="text-muted d-block">${a.accessLevel} &bull; Since ${a.createdAt}</small>
                        </div>
                        <button class="btn btn-link text-danger btn-sm" onclick="revokeRoom(${personId}, ${a.roomId})">
                            <i class="fas fa-times-circle"></i>
                        </button>
                    </div>
                `).join('');
            }
            // Live-update the badge in the personnel table row
            updatePersonBadge(personId, list.length);
        })
        .catch(err => {
            document.getElementById('roomList').innerHTML =
                '<p class="text-danger small text-center">Failed to load assignments. ' + err + '</p>';
        });
}

function assignRoom() {
    const personId = document.getElementById('roomPersonId').value;
    const roomId = document.getElementById('roomSelect').value;
    const btn = document.querySelector('[onclick="assignRoom()"]');

    if (!roomId) { showRoomMsg('Please select a room first.', 'error'); return; }

    // Anti-dedup: disable button during request
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin me-1"></i>Assigning...'; }

    fetch('/api/access/room-assign', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ personId: parseInt(personId), roomId: parseInt(roomId) })
    })
    .then(r => r.json())
    .then(data => {
        showRoomMsg(data.message, data.success ? 'ok' : 'error');
        if (data.success) {
            loadRoomAssignments(personId);
            refreshPersonnelCounts();
        }
    })
    .catch(err => showRoomMsg('Assignment failed: ' + err.message, 'error'))
    .finally(() => {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-plus me-1"></i>Assign Room Access'; }
    });
}

function revokeRoom(personId, roomId) {
    if (!confirm('Revoke access to this room?')) return;
    fetch('/api/access/room-revoke', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ personId, roomId })
    })
    .then(r => r.json())
    .then(data => {
        showRoomMsg(data.message, data.success ? 'ok' : 'error');
        if (data.success) {
            loadRoomAssignments(personId);
            refreshPersonnelCounts();
        }
    })
    .catch(err => showRoomMsg('Revoke failed: ' + err, 'error'));
}

// ==============================================
// REAL-TIME STAT CARD POLLING (30s)
// ==============================================
function refreshPersonnelCounts() {
    fetch('/Admin/PersonnelCounts')
        .then(r => r.json())
        .then(data => {
            const ops = document.getElementById('statOperators');
            const mem = document.getElementById('statMembers');
            const dep = document.getElementById('statDepartments');
            if (ops) ops.textContent = data.operators;
            if (mem) mem.textContent = data.members;
            if (dep) dep.textContent = data.departments;
        })
        .catch(() => {});
}

// Poll every 30 seconds
setInterval(refreshPersonnelCounts, 30000);

// ==============================================
// PI CAMERA ENROLLMENT
// ==============================================
let _capturedBase64 = '';

function setPhotoTab(tab) {
    const isCamera = tab === 'camera';
    document.getElementById('panelUpload').style.display = isCamera ? 'none' : 'block';
    document.getElementById('panelCamera').style.display = isCamera ? 'block' : 'none';
    document.getElementById('tabUpload').style.background = isCamera ? 'transparent' : 'var(--accent)';
    document.getElementById('tabUpload').style.color      = isCamera ? 'var(--accent)' : '#fff';
    document.getElementById('tabCamera').style.background = isCamera ? 'var(--accent)' : 'transparent';
    document.getElementById('tabCamera').style.color      = isCamera ? '#fff' : 'var(--accent)';
    if (!isCamera) { var img = document.getElementById('enrollStreamImg'); if (img) img.src = ''; }
}

function startEnrollStream() {
    var urlInput = document.getElementById('piStreamUrl');
    var img      = document.getElementById('enrollStreamImg');
    var btnCap   = document.getElementById('btnCapture');
    var msg      = document.getElementById('enrollMsg');
    var base = urlInput.value.trim().replace(/\/video$/, '');
    img.src = base + '/video?t=' + Date.now();
    img.onerror = function() { msg.textContent = 'Cannot connect — check Pi URL and ensure main.py is running.'; msg.style.color = '#e74c3c'; };
    img.onload  = function() { msg.textContent = 'Stream connected. Align face within the oval, then click Capture.'; msg.style.color = '#2ecc71'; };
    btnCap.disabled = false;
    msg.textContent = 'Connecting...';
    msg.style.color = 'var(--text-dim)';
}

function captureEnrollFrame() {
    var urlInput = document.getElementById('piStreamUrl');
    var msg      = document.getElementById('enrollMsg');

    // Build snapshot URL from the stream URL
    var base = urlInput.value.trim().replace(/\/video(\?.*)?$/, '');
    var snapshotUrl = base + '/snapshot?t=' + Date.now();

    msg.textContent = 'Requesting snapshot from Pi camera...';
    msg.style.color = 'var(--text-dim)';
    document.getElementById('btnCapture').disabled = true;

    // Use fetch() so the JPEG comes as a clean Blob — avoids MJPEG canvas CORS taint
    fetch(snapshotUrl)
        .then(function(r) {
            if (!r.ok) throw new Error('Pi returned HTTP ' + r.status + ' — is main.py running?');
            return r.blob();
        })
        .then(function(blob) {
            var reader = new FileReader();
            reader.onload = function(e) {
                _capturedBase64 = e.target.result;  // data:image/jpeg;base64,...

                document.getElementById('photoPreview').src = _capturedBase64;
                document.getElementById('photoPreviewWrap').style.display = 'block';

                var hidden = document.getElementById('capturedImageData');
                if (hidden) hidden.value = _capturedBase64;

                document.getElementById('btnCapture').disabled = false;
                document.getElementById('btnEnrollNow').disabled = false;
                msg.textContent = 'Snapshot captured! Click Enroll Now to save immediately.';
                msg.style.color = '#2ecc71';
            };
            reader.readAsDataURL(blob);
        })
        .catch(function(e) {
            document.getElementById('btnCapture').disabled = false;
            msg.textContent = 'Capture failed: ' + e.message;
            msg.style.color = '#e74c3c';
        });
}

function enrollNow() {
    var msg      = document.getElementById('enrollMsg');
    var pidEl    = document.getElementById('personIdField');
    var personId = pidEl ? pidEl.value : '';
    if (!_capturedBase64) { msg.textContent = 'No frame captured yet.'; msg.style.color = '#e74c3c'; return; }
    if (!personId || personId === '0') { msg.textContent = 'Save the person record first, then use Enroll Now.'; msg.style.color = '#f39c12'; return; }
    msg.textContent = 'Enrolling...';
    msg.style.color = 'var(--text-dim)';
    var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
    var token   = tokenEl ? tokenEl.value : '';
    var form    = new FormData();
    form.append('personId', personId);
    form.append('imageData', _capturedBase64);
    form.append('__RequestVerificationToken', token);
    fetch('/Personnel/CaptureEnrollmentPhoto', { method: 'POST', body: form })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            msg.textContent = (data.success ? '✅ ' : '❌ ') + data.message;
            msg.style.color = data.success ? '#2ecc71' : '#e74c3c';
            if (data.success) {
                // Live-update the Face ✓ badge in the personnel table row — no page reload needed
                var badge = document.getElementById('face-badge-' + personId);
                if (badge) {
                    badge.style.background = 'rgba(46,204,113,0.15)';
                    badge.style.color = '#2ecc71';
                    badge.innerHTML = '<i class="fas fa-user-check"></i> Face ✓';
                }
                // Also update the photo preview with the captured image
                var prev = document.getElementById('photoPreview');
                var wrap = document.getElementById('photoPreviewWrap');
                if (prev) { prev.src = _capturedBase64; }
                if (wrap) { wrap.style.display = 'block'; }
            }
        })
        .catch(function(e) { msg.textContent = 'Network error: ' + e.message; msg.style.color = '#e74c3c'; });
}
</script>
}