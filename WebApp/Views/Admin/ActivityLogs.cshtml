using Microsoft.AspNetCore.Mvc;
using SmartSecuritySystem.Models;
using System;
using System.Collections.Generic;
using System.Linq;
using WebApp.Models;

namespace WebApp.Controllers
{
    public class AdminController : Controller
    {
        // GET: /Admin/Index
        public IActionResult Index()
        {
            var model = new AdminDashboardViewModel
            {
                TotalPersonnel = 3,
                ActiveUsers = 3,
                InactiveUsers = 0,
                RecentLogins = 0,

                RecentPersonnel = new List<User>
                {
                    new User
                    {
                        Name = "John Doe",
                        Username = "johndoe",
                        Email = "john.doe@securevision.com",
                        Status = "Active",
                        LastLogin = DateTime.Now.AddHours(-5)
                    },
                    new User
                    {
                        Name = "Jane Smith",
                        Username = "janesmith",
                        Email = "jane.smith@securevision.com",
                        Status = "Active",
                        LastLogin = DateTime.Now.AddDays(-1)
                    }
                }
            };

            return View(model);
        }

        // GET: /Admin/ActivityLogs
        public IActionResult ActivityLogs(string search)
        {
            var adminUsername = "admin"; // Replace with actual logged-in username
            var adminIp = "192.168.1.100"; // Replace with real IP retrieval logic

            var logs = new List<ActivityLog>
            {
                new ActivityLog
                {
                    Description = "Admin user logged in",
                    Actor = adminUsername,
                    Target = null,
                    IpAddress = adminIp,
                    Date = DateTime.Now,
                    ActionType = ActivityActionType.Login
                },
                new ActivityLog
                {
                    Description = "Created security personnel account for John Doe",
                    Actor = adminUsername,
                    Target = "johndoe",
                    IpAddress = adminIp,
                    Date = DateTime.Now.AddHours(-2),
                    ActionType = ActivityActionType.Create
                },
                new ActivityLog
                {
                    Description = "Created security personnel account for Sarah Miller",
                    Actor = adminUsername,
                    Target = "sarahmiller",
                    IpAddress = adminIp,
                    Date = DateTime.Now.AddDays(-1),
                    ActionType = ActivityActionType.Create
                }
            };

            if (!string.IsNullOrWhiteSpace(search))
            {
                logs = logs.Where(l =>
                    l.Description.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (l.Actor?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (l.Target?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false))
                    .ToList();
            }

            return View(logs);
        }
    }

    // ViewModel for Admin Dashboard
    public class AdminDashboardViewModel
    {
        public int TotalPersonnel { get; set; }
        public int ActiveUsers { get; set; }
        public int InactiveUsers { get; set; }
        public int RecentLogins { get; set; }
        public List<User> RecentPersonnel { get; set; }
    }

    // Simplified User Model
    public class User
    {
        public string Name { get; set; } // Full name
        public string Username { get; set; }
        public string Email { get; set; }
        public string Status { get; set; } // Active / Inactive
        public DateTime LastLogin { get; set; }
    }

    // Enum for Activity Log Action Types
    public enum ActivityActionType
    {
        Login,
        Create,
        Update,
        Delete
    }

    // Activity Log Model
    public class ActivityLog
    {
        public string Description { get; set; }
        public string Actor { get; set; } // e.g. admin
        public string Target { get; set; } // e.g. johndoe or null
        public string IpAddress { get; set; }
        public DateTime Date { get; set; }
        public ActivityActionType ActionType { get; set; }
    }
}