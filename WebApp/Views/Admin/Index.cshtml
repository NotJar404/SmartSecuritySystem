@model WebApp.Models.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";
}

<link rel="stylesheet" href="~/css/dashboard.css" />
<link rel="stylesheet" href="~/css/logs.css" />

<!-- LIBRARIES -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<div class="dashboard-container">

    <!-- ===================== -->
    <!-- HEADER -->
    <!-- ===================== -->
    <header class="cmd-header d-flex justify-content-between align-items-center mb-3">

        <div>
            <h2 class="mb-0">Admin Command Center</h2>
            <small class="text-muted">System configuration, monitoring & audit control</small>
        </div>

        <div>
            <span class="live-badge">● SYSTEM ACTIVE</span>
        </div>

    </header>

    <!-- ===================== -->
    <!-- STATS -->
    <!-- ===================== -->
    <section class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa fa-users"></i></div>
            <div class="stat-content">
                <span>Active Personnel</span>
                <h3>@Model.ActivePersonnelCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fa fa-video"></i></div>
            <div class="stat-content">
                <span>Active Cameras</span>
                <h3>@Model.ActiveCameraCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon red"><i class="fa fa-exclamation-triangle"></i></div>
            <div class="stat-content">
                <span>Active Alerts</span>
                <h3>@Model.ActiveIncidentCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green"><i class="fa fa-chart-bar"></i></div>
            <div class="stat-content">
                <span>Detections Today</span>
                <h3>@Model.TodayDetectionCount</h3>
            </div>
        </div>
    </section>

    <!-- ===================== -->
    <!-- QUICK ACTIONS -->
    <!-- ===================== -->
    <section class="panel">
        <div class="panel-header">
            <h4>Administrative Actions</h4>
            <small>Direct system management tasks</small>
        </div>

        <div class="quick-actions-row">

            <a href="#" class="quick-card" data-toggle="modal" data-target="#userModal">
                <i class="fa fa-user-plus"></i>
                <div class="quick-info">
                    <strong>Add Personnel</strong>
                    <small>Create and manage accounts</small>
                </div>
            </a>

            <a href="#" class="quick-card" data-toggle="modal" data-target="#rfidModal">
                <i class="fa fa-id-card"></i>
                <div class="quick-info">
                    <strong>RFID Enrollment</strong>
                    <small>Register authorized access tags</small>
                </div>
            </a>

            <a href="#" class="quick-card" data-toggle="modal" data-target="#cameraModal">
                <i class="fa fa-tools"></i>
                <div class="quick-info">
                    <strong>Camera Configuration</strong>
                    <small>Calibration & sensitivity</small>
                </div>
            </a>

            <a href="#" class="quick-card" data-toggle="modal" data-target="#exportModal">
                <i class="fa fa-file-export"></i>
                <div class="quick-info">
                    <strong>Export Reports</strong>
                    <small>Generate audit reports (PDF/CSV/Charts)</small>
                </div>
            </a>

        </div>
    </section>

    <!-- ===================== -->
    <!-- CRITICAL AUDIT STREAM -->
    <!-- ===================== -->
    <section class="panel">
        <div class="panel-header">
            <h5>Critical Audit Stream</h5>
            <small>Recent system and admin activity</small>
            <a href="/Logs/Index?filter=@(ViewBag.IsAdmin == true ? "all" : "alert")" class="view-more-link">View More <i class="fas fa-arrow-right"></i></a>
        </div>

        <div class="logs-container" style="max-height: 360px;">

            @if (Model.AuditLogs?.Any() == true)
            {
                foreach (var log in Model.AuditLogs)
                {
                    var actionName = log.Action?.ToLower() ?? "";
                    var iconClass = "fa-history";

                    if (actionName.Contains("alert")) { iconClass = "fa-exclamation-triangle"; }
                    else if (actionName.Contains("detection")) { iconClass = "fa-eye"; }
                    else if (actionName.Contains("access")) { iconClass = "fa-id-badge"; }
                    else if (actionName.Contains("login")) { iconClass = "fa-sign-in-alt"; }

                    <div class="log-card">
                        <div class="log-icon">
                            <i class="fa @iconClass"></i>
                        </div>
                        <div class="log-content">
                            <h3>@log.Action</h3>
                            <p>@log.Description</p>
                            <div class="log-meta">
                                <span><i class="fa fa-clock"></i> @log.Timestamp.ToString("MMM dd, yyyy")</span>
                                @if (!string.IsNullOrEmpty(log.User))
                                {
                                    <span><i class="fa fa-user"></i> @log.User</span>
                                }
                            </div>
                        </div>
                        <div class="log-time">@log.Timestamp.ToString("hh:mm tt")</div>
                    </div>
                }
            }
            else
            {
                <div class="log-card">
                    <div class="log-icon">
                        <i class="fa fa-info-circle"></i>
                    </div>
                    <div class="log-content">
                        <h3>No audit data</h3>
                        <p>System activity will appear here once actions are logged.</p>
                    </div>
                    <div class="log-time">—</div>
                </div>
            }

        </div>
    </section>

    <!-- ===================== -->
    <!-- CHARTS -->
    <!-- ===================== -->
    <section class="charts-grid">
        <div class="panel chart-panel">
            <div class="panel-header">
                <h5>Alert Trends by Type</h5>
                <small>Alerts by day of week stacked by type</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="alertTypeChart"></canvas>
            </div>
        </div>

        <div class="panel chart-panel">
            <div class="panel-header">
                <h5>Access Security Posture</h5>
                <small>Access results: Authorized, Suspicious, Unauthorized</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="accessResultChart"></canvas>
            </div>
        </div>
    </section>

    <section class="charts-grid mt-4">
        <div class="panel chart-panel">
            <div class="panel-header">
                <h5>Detection Type Distribution</h5>
                <small>Detections by type — Person, Face, Motion, etc.</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="detectionTypeChart"></canvas>
            </div>
        </div>

        <div class="panel chart-panel">
            <div class="panel-header">
                <h5>Facility Occupancy by Room</h5>
                <small>Total occupancy count per room</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="occupancyRoomChart"></canvas>
            </div>
        </div>
    </section>

</div>



<!-- ===================================================== -->
<!-- MODALS (STANDARDIZED) -->
<!-- ===================================================== -->

<!-- PERSONNEL MODAL (MIRRORED FROM PERSONNEL.CSHTML) -->
<div class="modal fade" id="userModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form method="post" id="userForm" asp-controller="Personnel" asp-action="Add">
                @Html.AntiForgeryToken()
                <input type="hidden" id="userId" name="Id" value="0" />

                <div class="modal-header d-flex justify-content-between align-items-center">
                    <h5 id="userModalTitle" class="mb-0">Add Personnel</h5>
                    <button type="button" class="close" onclick="closeUserModal()" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        <label>Account Type</label>
                        <select id="adminRegType" name="RegType" class="form-control" onchange="adminToggleFields()">
                            <option value="staff">System Operator</option>
                            <option value="campus">Authorized Personnel (RFID)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Full Name</label>
                        <input id="adminFullName" name="FullName" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Email <small style="color:var(--accent);">(Gmail only)</small></label>
                        <input id="adminEmail" name="Email" type="email" class="form-control" placeholder="name@gmail.com" required pattern=".*@@gmail\.com$" title="Only Gmail addresses are accepted" />
                    </div>

                    <div id="adminStaffFields" style="display:none;">
                        <div class="form-group">
                            <label>Username</label>
                            <input id="adminUsername" name="Username" class="form-control" />
                        </div>
                        <div class="form-group" style="background:var(--bg-hover);padding:12px;border-radius:8px;">
                            <small style="color:var(--text-muted);">
                                <i class="fas fa-info-circle" style="color:var(--accent);"></i>
                                A secure temporary password will be auto-generated and sent to the provided Gmail address.
                                The user must change it upon first login.
                            </small>
                        </div>
                    </div>

                    <div id="adminCampusFields" style="display:none;">
                        <div class="form-group">
                            <label>Profile Image</label>
                            <input id="adminProfileImage" name="ProfileImage" type="file" accept="image/*" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>RFID Tag</label>
                            <input id="adminRfidTag" name="RfidTag" class="form-control" placeholder="Enter RFID tag ID" />
                        </div>
                        <div class="form-group">
                            <label>Department</label>
                            <input id="adminDepartment" name="Department" class="form-control" placeholder="Enter department" />
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input id="adminPhone" name="PhoneNumber" type="tel" class="form-control" placeholder="Enter phone number" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light btn-sm" onclick="closeUserModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- RFID MODAL (POSTS TO PERSONNEL/ADD WITH CAMPUS TYPE) -->
<div class="modal fade" id="rfidModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form method="post" id="rfidForm" asp-controller="Personnel" asp-action="Add">
                @Html.AntiForgeryToken()
                <input type="hidden" name="RegType" value="campus" />
                <input type="hidden" name="Id" value="0" />

                <div class="modal-header d-flex justify-content-between align-items-center">
                    <h5 id="rfidModalTitle" class="mb-0">RFID Enrollment</h5>
                    <button type="button" class="close" onclick="closeRfidModal()" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        <label>Profile Image</label>
                        <input id="profileImage" name="ProfileImage" type="file" accept="image/*" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Full Name</label>
                        <input id="rfidFullName" name="FullName" class="form-control" placeholder="Enter full name" required />
                    </div>
                    <div class="form-group">
                        <label>Email <small style="color:var(--accent);">(Gmail only)</small></label>
                        <input id="rfidEmail" name="Email" type="email" class="form-control" placeholder="name@gmail.com" required pattern=".*@@gmail\.com$" title="Only Gmail addresses are accepted" />
                    </div>
                    <div class="form-group">
                        <label>RFID Tag</label>
                        <input id="rfidTag" name="RfidTag" class="form-control" placeholder="Enter RFID tag ID" required />
                    </div>
                    <div class="form-group">
                        <label>Department</label>
                        <input id="rfidDepartment" name="Department" class="form-control" placeholder="Enter department" />
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input id="rfidPhone" name="Phone" type="tel" class="form-control" placeholder="Enter phone number" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light btn-sm" onclick="closeRfidModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- CAMERA MODAL (MIRRORED FROM CAMERAS/INDEX.CSHTML) -->
<div class="modal fade" id="cameraModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form method="post" id="cameraForm" asp-controller="Cameras" asp-action="Add">
                @Html.AntiForgeryToken()
                <input type="hidden" id="camId" name="Id" value="0" />
                <input type="hidden" name="Status" value="active" />

                <div class="modal-header d-flex justify-content-between align-items-center">
                    <h5 id="cameraModalTitle" class="mb-0">Camera Configuration</h5>
                    <button type="button" class="close" onclick="closeCameraModal()" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        <label>Camera Name</label>
                        <input id="camName" name="Name" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Location</label>
                        <input id="camLocation" name="Location" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Room</label>
                        <select id="camRoom" name="RoomId" class="form-control" required>
                            <option value="">-- Select Room --</option>
                            @{
                                var adminRooms = ViewBag.Rooms as List<WebApp.Models.Room>;
                                if (adminRooms != null)
                                {
                                    foreach (var room in adminRooms)
                                    {
                                        <option value="@room.RoomId">@room.RoomName</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Stream URL</label>
                        <input id="camSource" name="StreamUrl" type="text" class="form-control" placeholder="Enter Raspberry Pi / IP camera URL or leave empty for webcam test" />
                        <small style="color:var(--text-muted); font-size:12px; margin-top:6px; display:block;">
                            ✔ Raspberry Pi: http://192.168.x.x:xxxx<br />
                            ✔ IP Camera / OBS stream supported<br />
                            ✔ Leave EMPTY for laptop webcam (TEST MODE ONLY)
                        </small>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light btn-sm" onclick="closeCameraModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EXPORT PDF MODAL (STANDARDIZED) -->
<div id="exportModal" class="modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="modalTitle" class="mb-0">Export Admin Report</h5>
                <button type="button" class="close" onclick="closeExportModal()" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                
                <!-- Date Range -->
                <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" id="exportStartDate" class="form-control" />
                </div>

                <div class="form-group">
                    <label>End Date</label>
                    <input type="date" id="exportEndDate" class="form-control" />
                </div>

                <!-- Filters -->
                <div class="form-group">
                    <label>Location</label>
                    <select id="exportLocation" class="form-control">
                        <option value="">All Rooms</option>
                        @if (ViewBag.AvailableRooms != null)
                        {
                            foreach (var room in ViewBag.AvailableRooms)
                            {
                                <option value="@room.RoomName">@room.RoomName</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Event Type</label>
                    <select id="exportEventType" class="form-control">
                        <option value="">All Events</option>
                        <option>Alert</option>
                        <option>Access</option>
                    </select>
                </div>

                <!-- Paper Size -->
                <div class="form-group">
                    <label>Paper Size</label>
                    <select id="paperSize" class="form-control">
                        <option value="a4">A4</option>
                        <option value="letter">Letter (8.5" x 11")</option>
                        <option value="landscape">A4 Landscape</option>
                    </select>
                </div>

                <!-- Include Sections -->
                <div class="form-group">
                    <label>Include in Report</label>
                    <div class="checkbox-group">
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeCharts" checked />
                            <label for="includeCharts">Charts & Graphs</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeSummary" checked />
                            <label for="includeSummary">Summary Statistics</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeLogs" />
                            <label for="includeLogs">Activity Logs</label>
                        </div>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" onclick="closeExportModal()">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="generateExportPDF()">Export PDF</button>
            </div>

        </div>
    </div>
</div>

<!-- ===================== -->
<!-- SCRIPT (UPDATED) -->
<!-- ===================== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
const { jsPDF } = window.jspdf;

/* ============================= */
/* DATA — ENHANCED CHART DATA */
/* ============================= */
const alertsByType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertsByType ?? new Dictionary<string, int>()));
const alertTrendsByDayAndType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertTrendsByDayAndType ?? new Dictionary<string, Dictionary<string, int>>()));
const accessByResult = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AccessByResult ?? new Dictionary<string, int>()));
const detectionsByType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DetectionsByType ?? new Dictionary<string, int>()));
const occupancyRoomLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyRoomLabels ?? new List<string>()));
const occupancyRoomCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyRoomCounts ?? new List<int>()));

const colorPalette = [
    '#ef4444', '#f97316', '#eab308', '#22c55e', '#06b6d4', '#3b82f6', '#8b5cf6', '#ec4899'
];

/* ============================= */
/* MODAL FUNCTIONS (STANDARDIZED) */
/* ============================= */

// Personnel Modal
function closeUserModal() {
    const modal = document.getElementById('userModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

// RFID Modal
function closeRfidModal() {
    const modal = document.getElementById('rfidModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

// Camera Modal
function closeCameraModal() {
    const modal = document.getElementById('cameraModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

// Export Modal
function closeExportModal() {
    const modal = document.getElementById('exportModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

/* Toggle conditional fields for Admin Personnel modal */
function adminToggleFields() {
    const type = document.getElementById('adminRegType').value;
    document.getElementById('adminStaffFields').style.display = (type === 'staff') ? 'block' : 'none';
    document.getElementById('adminCampusFields').style.display = (type === 'campus') ? 'block' : 'none';
}

/* Modal backdrop click handlers */
document.addEventListener('DOMContentLoaded', function() {
    const modals = ['userModal', 'rfidModal', 'cameraModal', 'exportModal'];
    
    modals.forEach(modalId => {
        const modal = document.getElementById(modalId);
        if (!modal) return;
        
        // Click on backdrop to close
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                modal.classList.remove('show');
                document.body.style.overflow = 'auto';
            }
        });
        
        // Close button handler
        const closeBtn = modal.querySelector('.close');
        if (closeBtn) {
            closeBtn.addEventListener('click', function() {
                modal.classList.remove('show');
                document.body.style.overflow = 'auto';
            });
        }
        
        // Cancel button handler
        const cancelBtn = modal.querySelector('.btn-light');
        if (cancelBtn) {
            cancelBtn.addEventListener('click', function() {
                modal.classList.remove('show');
                document.body.style.overflow = 'auto';
            });
        }
    });
    
    // Override quick-action clicks to show modals properly
    document.querySelectorAll('.quick-card').forEach(card => {
        card.addEventListener('click', function(e) {
            e.preventDefault();
            const target = this.getAttribute('data-target');
            if (target) {
                const modalId = target.replace('#', '');
                const modal = document.getElementById(modalId);
                if (modal) {
                    // Reset forms when opening
                    if (modalId === 'userModal') {
                        document.getElementById('userForm').reset();
                        document.getElementById('adminRegType').value = 'staff';
                        adminToggleFields();
                    }
                    modal.classList.add('show');
                    document.body.style.overflow = 'hidden';
                }
            }
        });
    });

    // Initialize conditional fields
    adminToggleFields();

    // Intercept forms with two-step confirmation
    SecureConfirm.interceptForm('userForm', 'Confirm Personnel Action', 'userModal');
    SecureConfirm.interceptForm('rfidForm', 'Confirm RFID Enrollment', 'rfidModal');
    SecureConfirm.interceptForm('cameraForm', 'Confirm Camera Configuration', 'cameraModal');
});

/* ============================= */
/* QUICK FEATURE FALLBACK */
/* ============================= */
function notifyFeature(feature) {
    alert(feature + " is not yet available.");
}

/* ============================= */
/* CHARTS — ENHANCED */
/* ============================= */

// 1. ALERT TRENDS BY DAY AND TYPE (Stacked Bar Chart)
const alertTypeCtx = document.getElementById('alertTypeChart');
if (alertTypeCtx) {
    // Get all unique alert types
    const allAlertTypes = new Set();
    Object.values(alertTrendsByDayAndType).forEach(dayData => {
        Object.keys(dayData).forEach(type => allAlertTypes.add(type));
    });
    const alertTypes = Array.from(allAlertTypes);
    
    // Create datasets for each alert type
    const dayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const datasets = alertTypes.map((type, index) => ({
        label: type,
        data: dayLabels.map(day => alertTrendsByDayAndType[day]?.[type] || 0),
        backgroundColor: colorPalette[index % colorPalette.length],
        borderColor: colorPalette[index % colorPalette.length],
        borderWidth: 1
    }));

    new Chart(alertTypeCtx, {
        type: 'bar',
        data: {
            labels: dayLabels,
            datasets: datasets
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    stacked: true,
                    ticks: { font: { size: 10 } }
                },
                y: {
                    stacked: true,
                    beginAtZero: true,
                    ticks: { font: { size: 9 } }
                }
            },
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { font: { size: 11 }, padding: 15 }
                }
            }
        }
    });
}

// 2. ACCESS RESULT BREAKDOWN (Doughnut Chart)
const accessResultCtx = document.getElementById('accessResultChart');
if (accessResultCtx) {
    const accessColors = {
        'AUTHORIZED': '#22c55e',
        'SUSPICIOUS': '#f97316',
        'UNAUTHORIZED': '#ef4444'
    };
    const accessBgColors = Object.keys(accessByResult).map(key =>
        accessColors[key] || '#95a5a6'
    );

    new Chart(accessResultCtx, {
        type: 'doughnut',
        data: {
            labels: Object.keys(accessByResult),
            datasets: [{
                data: Object.values(accessByResult),
                backgroundColor: accessBgColors,
                borderColor: '#fff',
                borderWidth: 2
            }]
        },
        options: {
