/* ============================= */

function loadImageAsBase64(url) {
    return new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = function() {
            const canvas = document.createElement('canvas');
            canvas.width = img.naturalWidth;
            canvas.height = img.naturalHeight;
            canvas.getContext('2d').drawImage(img, 0, 0);
            resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = function() { resolve(null); };
        img.src = url;
    });
}

async function generateExportPDF(){
    const startDate = document.getElementById('exportStartDate').value || 'N/A';
    const endDate = document.getElementById('exportEndDate').value || 'N/A';
    const location = document.getElementById('exportLocation').value || 'All Rooms';
    const eventType = document.getElementById('exportEventType').value || 'All Events';
    const paperSize = document.getElementById('paperSize').value;
    const includeCharts = document.getElementById('includeCharts').checked;
    const includeSummary = document.getElementById('includeSummary').checked;

    const [qcuLogo, ccistLogo] = await Promise.all([
        loadImageAsBase64('/images/qcu-logo.png'),
        loadImageAsBase64('/images/ccist-logo.png')
    ]);

    const isLandscape = paperSize === 'landscape';
    const pdf = new jsPDF({
        orientation: isLandscape ? 'l' : 'p',
        unit: 'mm',
        format: paperSize === 'letter' ? 'letter' : 'a4'
    });

    const pageWidth = pdf.internal.pageSize.getWidth();
    const centerX = pageWidth / 2;
    let y = 12;

    // LETTERHEAD WITH LOGOS
    if (qcuLogo) { try { pdf.addImage(qcuLogo, 'PNG', 25, y - 4, 18, 18); } catch(e) {} }
    if (ccistLogo) { try { pdf.addImage(ccistLogo, 'PNG', pageWidth - 43, y - 4, 18, 18); } catch(e) {} }

    pdf.setFontSize(13);
    pdf.setFont('helvetica', 'bold');
    pdf.text('QUEZON CITY UNIVERSITY', centerX, y, { align: 'center' });
    y += 5;
    pdf.setFontSize(9);
    pdf.setFont('helvetica', 'normal');
    pdf.text('COLLEGE OF COMPUTER SCIENCE AND INFORMATION TECHNOLOGY', centerX, y, { align: 'center' });
    y += 4;
    pdf.setFontSize(8);
    pdf.text('San Bartolome  |  San Francisco  |  Batasan Hills', centerX, y, { align: 'center' });
    y += 5;

    pdf.setDrawColor(180, 130, 80);
    pdf.setLineWidth(0.8);
    pdf.line(20, y, pageWidth - 20, y);
    pdf.setLineWidth(0.3);
    pdf.line(20, y + 1.5, pageWidth - 20, y + 1.5);
    y += 8;

    // REPORT TITLE
    pdf.setFontSize(15);
    pdf.setFont('helvetica', 'bold');
    pdf.text('ADMIN DASHBOARD REPORT', centerX, y, { align: 'center' });
    y += 7;

    pdf.setFontSize(9);
    pdf.setFont('helvetica', 'normal');
    const genDate = new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
    pdf.text(`Generated: ${genDate}`, 25, y);
    y += 4;
    pdf.text(`Date Range: ${startDate} to ${endDate}`, 25, y);
    y += 4;
    pdf.text(`Location: ${location}   |   Event Type: ${eventType}`, 25, y);
    y += 8;

    // SUMMARY STATISTICS
    if (includeSummary) {
        pdf.setFillColor(250, 245, 238);
        pdf.setDrawColor(200, 160, 110);
        pdf.roundedRect(20, y, pageWidth - 40, 28, 2, 2, 'FD');

        pdf.setFontSize(10);
        pdf.setFont('helvetica', 'bold');
        pdf.text('SUMMARY STATISTICS', 25, y + 6);

        pdf.setFontSize(9);
        pdf.setFont('helvetica', 'normal');
        const col1 = 28, col2 = centerX + 5;
        pdf.text('Active Personnel: @Model.ActivePersonnelCount', col1, y + 13);
        pdf.text('Active Cameras: @Model.ActiveCameraCount', col2, y + 13);
        pdf.text('Active Alerts: @Model.ActiveIncidentCount', col1, y + 19);
        pdf.text('Detections Today: @Model.TodayDetectionCount', col2, y + 19);
        y += 34;
    }

    // CHARTS
    if (includeCharts) {
        pdf.setFontSize(11);
        pdf.setFont('helvetica', 'bold');
        pdf.text('CHARTS & ANALYTICS', 25, y);
        y += 6;

        const chartIds = ['alertTypeChart', 'accessResultChart', 'occupancyChart'];
        const chartImgs = chartIds.map(id => {
            const c = document.getElementById(id);
            return c ? c.toDataURL('image/png') : null;
        }).filter(Boolean);

        const chartW = (pageWidth - 60) / 2;
        const chartH = 75;
        for (let i = 0; i < chartImgs.length; i++) {
            const col = (i % 2);
            const row = Math.floor(i / 2);
            const cx = 22 + col * (chartW + 10);
            const cy = y + row * (chartH + 8);

            if (cy + chartH > pdf.internal.pageSize.getHeight() - 15) {
                pdf.addPage();
                y = 15;
            }
            pdf.addImage(chartImgs[i], 'PNG', cx, cy, chartW, chartH);
        }
        y += Math.ceil(chartImgs.length / 2) * (chartH + 8) + 5;
    }

    // FOOTER
    const totalPages = pdf.internal.getNumberOfPages();
    for (let p = 1; p <= totalPages; p++) {
        pdf.setPage(p);
        const ph = pdf.internal.pageSize.getHeight();
        pdf.setFontSize(7);
        pdf.setFont('helvetica', 'italic');
        pdf.setTextColor(150);
        pdf.text('SecureVision AI-Assisted Smart Security System  —  Quezon City University', centerX, ph - 8, { align: 'center' });
        pdf.text(`Page ${p} of ${totalPages}`, pageWidth - 25, ph - 8);
        pdf.setTextColor(0);
    }

    const fileName = `QCU_Admin_${new Date().toISOString().split('T')[0]}.pdf`;
    pdf.save(fileName);
    closeExportModal();
}

