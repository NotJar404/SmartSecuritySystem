@model WebApp.Models.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="dashboard-container">

    <!-- ===================== -->
    <!-- STATS -->
    <!-- ===================== -->
    <div class="stats">

        <div class="stat-card">
            <div class="stat-icon blue">
                <i class="fa fa-users"></i>
            </div>
            <div>
                <h2>@Model.ActivePersonnelCount</h2>
                <p>Active Personnel</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow">
                <i class="fa fa-video"></i>
            </div>
            <div>
                <h2>@Model.ActiveCameraCount</h2>
                <p>Active Cameras</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon red">
                <i class="fa fa-exclamation-triangle"></i>
            </div>
            <div>
                <h2>@Model.ActiveIncidentCount</h2>
                <p>Active Alerts</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green">
                <i class="fa fa-chart-bar"></i>
            </div>
            <div>
                <h2>@Model.TodayDetectionCount</h2>
                <p>Today Detections</p>
            </div>
        </div>

    </div>

<!-- ===================== -->
<!-- QUICK ACTIONS -->
<!-- ===================== -->
<div class="section">

    <div class="section-header">
        <h3>Quick Actions</h3>
    </div>

    <div class="quick-grid">

        <div class="quick-card">
            <div class="quick-icon"><i class="fa fa-user-plus"></i></div>
            <div class="quick-text">
                <h4>Add Personnel</h4>
                <p>Create security account</p>
            </div>
        </div>

        <div class="quick-card">
            <div class="quick-icon"><i class="fa fa-video"></i></div>
            <div class="quick-text">
                <h4>Monitor Cameras</h4>
                <p>View live feeds</p>
            </div>
        </div>

        <div class="quick-card">
            <div class="quick-icon"><i class="fa fa-bell"></i></div>
            <div class="quick-text">
                <h4>View Alerts</h4>
                <p>Security incidents</p>
            </div>
        </div>

        <div class="quick-card">
            <div class="quick-icon"><i class="fa fa-chart-line"></i></div>
            <div class="quick-text">
                <h4>Analytics</h4>
                <p>System reports</p>
            </div>
        </div>

    </div>
</div>

    <!-- ===================== -->
    <!-- CHARTS -->
    <!-- ===================== -->
    <div class="grid-2">

        <div class="panel chart-panel">
            <h4>Alert Trends</h4>
            <div class="chart-wrapper">
                <canvas id="alertChart"></canvas>
            </div>
        </div>

        <div class="panel chart-panel">
            <h4>Access Activity</h4>
            <div class="chart-wrapper">
                <canvas id="accessChart"></canvas>
            </div>
        </div>

        <div class="panel chart-panel">
            <h4>Detection Activity</h4>
            <div class="chart-wrapper">
                <canvas id="motionChart"></canvas>
            </div>
        </div>

        <div class="panel chart-panel">
            <h4>Room Occupancy</h4>
            <div class="chart-wrapper">
                <canvas id="occupancyChart"></canvas>
            </div>
        </div>

    </div>

</div>

<!-- ===================== -->
<!-- CHART.JS -->
<!-- ===================== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Labels ?? new List<string>()));

    const alertData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertWeekly ?? new List<int>()));
    const accessData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AccessWeekly ?? new List<int>()));
    const motionData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MotionWeekly ?? new List<int>()));
    const occupancyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyWeekly ?? new List<int>()));

    function createChart(id, type, label, data, color) {
        const ctx = document.getElementById(id);
        if (!ctx) return;

        new Chart(ctx, {
            type: type,
            data: {
                labels: labels,
                datasets: [{
                    label: label,
                    data: data,
                    backgroundColor: color + "55",
                    borderColor: color,
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { precision: 0 }
                    }
                }
            }
        });
    }

    createChart("alertChart", "line", "Alerts", alertData, "#ef4444");
    createChart("accessChart", "bar", "Access Logs", accessData, "#3b82f6");
    createChart("motionChart", "bar", "Detections", motionData, "#a855f7");

    new Chart(document.getElementById("occupancyChart"), {
        type: "bar",
        data: {
            labels: ["Lobby", "Floor 1", "Server Room", "Admin", "Parking"],
            datasets: [{
                label: "Occupancy",
                data: occupancyData,
                backgroundColor: "#22c55e"
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });
</script>