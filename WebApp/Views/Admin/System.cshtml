@using WebApp.Models
@{
    ViewData["Title"] = "System Control Center";
    // We are now using AlarmSetting instead of Alert to power the toggles
    var alarmSettings = ViewBag.Alarms as List<WebApp.Models.AlarmSetting> ?? new List<WebApp.Models.AlarmSetting>();
}

<link rel="stylesheet" href="~/css/System.css" />
<link rel="stylesheet" href="~/css/dashboard.css" />

<div class="dashboard-container">

    <header class="cmd-header d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">System Control Center</h2>
            <small class="text-muted">Monitor and configure system operations</small>
        </div>
        <div>
            <span class="live-badge">● SYSTEM ACTIVE</span>
        </div>
    </header>

    <div class="settings-wrapper">
        <div class="control-grid">

            <div class="control-card">
                <div class="card-title-area">
                    <h5><i class="fa fa-desktop me-2"></i>Global Settings</h5>
                    <span class="status-indicator-dot online"></span>
                </div>
                
                <div class="setting-row">
                    <div class="label-desc">
                        <label>Master Arm</label>
                        <small>Enable/Disable AI monitoring</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="armSystem" checked onchange="handleToggle('Security Engine', this.checked)">
                        <span class="slider round"></span>
                    </label>
                </div>

                <div class="setting-row">
                    <div class="label-desc">
                        <label>Eye-Strain Protection</label>
                        <small>Apply warm UI color profile</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked onchange="updateTheme(this.checked)">
                        <span class="slider round"></span>
                    </label>
                </div>

                <div class="setting-row">
                    <div class="label-desc">
                        <label>Auto-Maintenance</label>
                        <small>Purge old logs every 30 days</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider round"></span>
                    </label>
                </div>
            </div>

            <div class="control-card">
                <h5><i class="fa fa-brain me-2"></i>AI Intelligence</h5>
                <div class="setting-row">
                    <label>Motion Sensitivity</label>
                    <select class="warm-select">
                        <option value="1">Low (Ignore Shadows)</option>
                        <option value="2" selected>Medium (Balanced)</option>
                        <option value="3">High (Strict)</option>
                    </select>
                </div>
                <div class="setting-row mt-3">
                    <label>Face Accuracy</label>
                    <div class="input-group-custom">
                        <input type="number" class="warm-num-input" value="80" min="50" max="100" />
                        <span class="unit-tag">%</span>
                    </div>
                </div>
                <div class="progress-container mt-2" style="height: 4px;">
                    <div class="progress-bar-fill" style="width:80%; background: var(--accent);"></div>
                </div>
                <small class="text-muted extra-small mt-2 d-block">Minimum confidence for a positive match.</small>
            </div>

            <div class="control-card">
                <h5><i class="fa fa-bell me-2"></i>Alert Protocols</h5>
                <div class="setting-row">
                    <div class="label-desc">
                        <label>Email Reports</label>
                        <small>Send snapshots of threats</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider round"></span>
                    </label>
                </div>
                <div class="setting-row">
                    <div class="label-desc">
                        <label>Hardware Siren</label>
                        <small>Enable physical Pi buzzer</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider round"></span>
                    </label>
                </div>
            </div>

            <div class="control-card">
                <h5><i class="fa fa-shield-alt me-2"></i>Access Control</h5>
                <div class="setting-row">
                    <label>Gate Hold-Open</label>
                    <div class="input-group-custom">
                        <input type="number" class="warm-num-input" value="5" />
                        <span class="unit-tag">sec</span>
                    </div>
                </div>
                <div class="setting-row mt-3">
                    <div class="label-desc">
                        <label>Biometric Lock</label>
                        <small>Face match required to open</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider round"></span>
                    </label>
                </div>
            </div>

            <div class="control-card">
                <h5><i class="fa fa-microchip me-2"></i>Pi Maintenance</h5>
                
                <div class="storage-display mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="fw-bold">SD Card Storage</small>
                        <small class="text-success">25% Used</small>
                    </div>
                    <div class="progress-container" style="height: 6px;">
                        <div class="progress-bar-fill" style="width:25%"></div>
                    </div>
                </div>

                <button class="btn btn-warm-warning w-100 mb-2 py-2" onclick="triggerAction('Optimize Database')">
                    <i class="fa fa-broom me-2"></i>Optimize Database
                </button>

                <button class="btn btn-warm-dark w-100 py-2" onclick="handleArchive()">
                    <i class="fa fa-hdd me-2"></i>Transfer to Archive
                </button>
            </div>

            <div class="system-card control-card">
                <div class="card-title-area">
                    <h5><i class="fa fa-exclamation-triangle text-danger me-2"></i>Emergency Alarm</h5>
                </div>

                <div class="alarm-list mt-3">
                    @if (alarmSettings != null && alarmSettings.Any())
                    {
                        @foreach (var setting in alarmSettings)
                        {
                            <div class="alarm-item @(setting.IsEnabled ? "active" : "") d-flex justify-content-between align-items-center mb-3">
                                <div class="alarm-info d-flex align-items-center">
                                    <div class="alarm-icon me-3 @setting.Type.ToLower()">
                                        <i class="fa @(setting.Type.ToLower() == "intrusion" ? "fa-user-secret" :
                                                      setting.Type.ToLower() == "fire" ? "fa-fire" :
                                                      setting.Type.ToLower() == "earthquake" ? "fa-globe" :
                                                      "fa-ambulance")"></i>
                                    </div>
                                    <div>
                                        <strong class="d-block">@setting.Name</strong>
                                        <p class="alarm-desc text-muted mb-0 extra-small">Hardware trigger for @setting.Type protocol.</p>
                                    </div>
                                </div>
                                <label class="switch">
                                    <input type="checkbox" @(setting.IsEnabled ? "checked" : "") 
                                           onchange="confirmToggle(this, '@setting.Name', @setting.SettingId)">
                                    <span class="slider round"></span>
                                </label>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small text-center">No alarm protocols found in database.</p>
                    }
                </div>
            </div>

        </div>

        <div class="mt-5 border-top pt-4 text-center">
            <button class="btn btn-warm-dark px-5 py-3 shadow-lg rounded-pill" onclick="saveGlobalSettings()">
                <i class="fa fa-cloud-upload-alt me-2"></i>Deploy Changes to Raspberry Pi
            </button>
            <p class="text-muted extra-small mt-2">Changes will be pushed via SQL bridge to the AI engine.</p>
        </div>

    </div>
</div>

@section Scripts {
<script>
    function handleToggle(feature, state) {
        const status = state ? "ARMED" : "DISARMED";
        console.log(`Hardware Command: ${feature} set to ${status}`);
    }

    function updateTheme(isWarm) {
        document.body.classList.toggle('warm-theme-mode', isWarm);
    }

    function confirmToggle(checkbox, alarmName, settingId) {
        const isChecked = checkbox.checked;
        const action = isChecked ? "ACTIVATE" : "DEACTIVATE";
        
        if (confirm(`HCI SAFETY CHECK: Are you sure you want to ${action} the ${alarmName}?`)) {
            // Updated to perform an actual background update
            fetch('/Dashboard/UpdateAlarmStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${settingId}&isEnabled=${isChecked}`
            })
            .then(response => {
                if(!response.ok) throw new Error('Database Sync Failed');
                console.log(`Sync Successful: ${alarmName} is now ${isChecked}`);
            })
            .catch(error => {
                alert("Hardware Sync Error: Could not reach the database.");
                checkbox.checked = !isChecked; // Revert UI if DB fails
            });
        } else {
            checkbox.checked = !isChecked; // Revert if user clicks 'Cancel'
        }
    }

    function handleArchive() {
        if(confirm("HARDWARE REQUIRED: Is the USB storage device connected to the Raspberry Pi?")) {
            alert("Archive process initiated. Please do not disconnect the USB until sync is complete.");
        }
    }

    function triggerAction(action) {
        if(confirm(`CRITICAL ACTION: Are you sure you want to trigger: ${action}?`)) {
            alert(`Signal sent. ${action} in progress.`);
        }
    }

    function saveGlobalSettings() {
        const btn = event.currentTarget;
        const originalContent = btn.innerHTML;
        
        btn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i>Pushing Config...';
        btn.disabled = true;

        setTimeout(() => {
            btn.innerHTML = '<i class="fa fa-check-circle me-2"></i>Hardware Synced Successfully';
            btn.classList.replace('btn-warm-dark', 'btn-success');
            
            setTimeout(() => {
                btn.innerHTML = originalContent;
                btn.classList.replace('btn-success', 'btn-warm-dark');
                btn.disabled = false;
            }, 3000);
        }, 2000);
    }
</script>
}