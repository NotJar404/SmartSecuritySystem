@model WebApp.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/analytics.css" />

<!-- LIBRARIES (local — offline-safe for Pi deployment) -->
<script src="~/lib/js/chart.umd.min.js"></script>
<script src="~/lib/js/jspdf.umd.min.js"></script>
<script src="~/lib/js/html2canvas.min.js"></script>

<div class="dashboard-container">

    <!-- HEADER -->
    <header class="cmd-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Analytics & Security Alerts</h2>
            <small class="text-muted">System performance insights and historical incident tracking.</small>
        </div>

        <div class="header-actions">
            <button class="btn-export btn-pdf" onclick="openExportPDFModal()">
                <i class="fa fa-file-pdf"></i> Export PDF
            </button>
        </div>
    </header>

    <!-- STATS -->
    <section class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fa fa-exclamation-triangle"></i></div>
            <div class="stat-content">
                <span>Active Alerts</span>
                <h3 id="statAlerts">@Model.ActiveIncidentCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa fa-id-badge"></i></div>
            <div class="stat-content">
                <span>Access Logs</span>
                <h3 id="statAccess">@Model.AccessWeekly.Sum()</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green"><i class="fa fa-running"></i></div>
            <div class="stat-content">
                <span>Detections</span>
                <h3 id="statDetections">@Model.TodayDetectionCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fa fa-user-shield"></i></div>
            <div class="stat-content">
                <span>Personnel</span>
                <h3 id="statPersonnel">@Model.ActivePersonnelCount</h3>
            </div>
        </div>
    </section>

    <!-- FILTER PANEL -->
    <section class="panel filter-panel">
        <form method="get" action="/Admin/Analytics">
            <div class="filter-header d-flex justify-content-between align-items-center">
                <div class="filter-title d-flex">
                    <div class="filter-icon me-2"><i class="fa fa-filter"></i></div>
                    <div>
                        <h5 class="mb-0">Report Filters</h5>
                        <small>Customize your report criteria</small>
                    </div>
                </div>
                <button type="submit" class="btn">Apply Filter</button>
            </div>

            <div class="filter-grid">
                <div class="filter-field">
                    <label>Start Date</label>
                    <input type="date" name="startDate" id="startDate" class="filter-input" value="@ViewBag.StartDate" />
                </div>

                <div class="filter-field">
                    <label>End Date</label>
                    <input type="date" name="endDate" id="endDate" class="filter-input" value="@ViewBag.EndDate" />
                </div>

                <div class="filter-field">
                    <label>Room/Location</label>
                    <select name="locationFilter" id="locationFilter" class="filter-input">
                        <option value="">All Rooms</option>
                        @if (ViewBag.AvailableRooms != null)
                        {
                            @foreach (var room in ViewBag.AvailableRooms)
                            {
                                if (ViewBag.LocationFilter == room.RoomName)
                                {
                                    <option value="@room.RoomName" selected>@room.RoomName</option>
                                }
                                else
                                {
                                    <option value="@room.RoomName">@room.RoomName</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="filter-field">
                    <label>Event Type</label>
                    <select name="eventFilter" id="eventFilter" class="filter-input">
                        @{
                            string eventFilter = ViewBag.EventFilter as string ?? "";
                        }
                        @if (string.IsNullOrEmpty(eventFilter))
                        {
                            <option value="" selected>All Events</option>
                        }
                        else
                        {
                            <option value="">All Events</option>
                        }
                        
                        @if (eventFilter == "Alert")
                        {
                            <option value="Alert" selected>Alert</option>
                        }
                        else
                        {
                            <option value="Alert">Alert</option>
                        }
                        
                        @if (eventFilter == "Access")
                        {
                            <option value="Access" selected>Access</option>
                        }
                        else
                        {
                            <option value="Access">Access</option>
                        }
                    </select>
                </div>
            </div>
        </form>
    </section>

    <!-- CHARTS -->
    <div class="charts-grid">
        <div class="panel">
            <div class="panel-header">
                <h5>Alert Trends by Type</h5>
                <small>Alerts grouped by type — Intrusion, UnauthorizedAccess, etc.</small>
            </div>
            <div class="chart-wrapper" style="position:relative; height:300px;">
                <canvas id="alertTypeChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <h5>Access Security Posture</h5>
                <small>Access results breakdown: Authorized, Suspicious, Unauthorized</small>
            </div>
            <div class="chart-wrapper" style="position:relative; height:300px;">
                <canvas id="accessResultChart"></canvas>
            </div>
        </div>
    </div>

    <div class="charts-grid mt-4">
        <div class="panel">
            <div class="panel-header">
                <h5>Detection Type Distribution</h5>
                <small>Detections by type — Person, Face, Motion, etc.</small>
            </div>
            <div class="chart-wrapper" style="position:relative; height:300px;">
                <canvas id="detectionTypeChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <h5>Facility Occupancy by Room</h5>
                <small>Total occupancy count per room</small>
            </div>
            <div class="chart-wrapper" style="position:relative; height:300px;">
                <canvas id="occupancyRoomChart"></canvas>
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-header">
            <h5>Active Intervention Queue</h5>
            <small>Current unresolved alerts requiring attention</small>
        </div>
        <div class="status-list-container">
            @if (Model.ActiveInterventions != null && Model.ActiveInterventions.Any())
            {
                foreach (var alert in Model.ActiveInterventions)
                {
                    var isCritical = alert.Severity == WebApp.Models.SeverityLevel.CRITICAL;
                    var isWarning = alert.Severity == WebApp.Models.SeverityLevel.WARNING;
                    var dotClass = isCritical ? "red" : isWarning ? "yellow" : "green";

                    <div class="status-item">
                        <span class="status-dot-indicator @dotClass"></span>
                        <div class="status-info">
                            <p class="mb-0"><strong>@alert.Type - Room @alert.RoomId</strong></p>
                            <small class="text-muted">Status: @alert.Status | @alert.Timestamp.ToString("g")</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted small text-center mt-3">No active interventions queued.</p>
            }
        </div>
    </div>
    
    <!-- REPORTING SECTION -->
    <section class="panel mt-4 mb-5">
        <div class="panel-header">
            <h5>Automated Reporting Schedule</h5>
            <small>Receive analytics directly to your inbox</small>
        </div>

        <div class="row g-3" style="display:grid; grid-template-columns: 1fr 1fr auto; gap: 16px; align-items: end;">
            <div>
                <label style="font-size:13px; font-weight:600; color:var(--text-main); display:block; margin-bottom:6px;">Administrator Email</label>
                <input type="email" id="scheduleEmail" class="filter-input" style="width:100%;" placeholder="Enter administrator email..." />
            </div>

            <div>
                <label style="font-size:13px; font-weight:600; color:var(--text-main); display:block; margin-bottom:6px;">Report Frequency</label>
                <select id="scheduleFrequency" class="filter-input" style="width:100%;">
                    <option value="daily">Daily Digest</option>
                    <option value="weekly">Weekly Summary</option>
                    <option value="critical">Critical Only</option>
                </select>
            </div>

            <div>
                <button class="btn-export" onclick="scheduleReport()" style="width:100%; justify-content:center;">
                    <i class="fa fa-paper-plane"></i> Schedule Report
                </button>
            </div>
        </div>

        <div id="scheduleStatus" style="margin-top:14px; display:none;"
             class="panel" style="padding:12px 16px; background:rgba(45,122,86,0.08); border:1px solid rgba(45,122,86,0.25); border-radius:var(--radius);">
            <small style="color:var(--status-active);"><i class="fa fa-check-circle me-2"></i> <span id="scheduleStatusText"></span></small>
        </div>
    </section>

</div>

<!-- ================= MODALS ================= -->

<!-- EXPORT PDF MODAL (STANDARDIZED) -->
<div id="exportPDFModal" class="modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="modalTitle" class="mb-0">Export Analytics Report</h5>
                <button type="button" class="close" onclick="closeExportModal()" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                
                <!-- Date Range -->
                <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" id="exportStartDate" class="form-control" />
                </div>

                <div class="form-group">
                    <label>End Date</label>
                    <input type="date" id="exportEndDate" class="form-control" />
                </div>

                <!-- Filters -->
                <div class="form-group">
                    <label>Location</label>
                    <select id="exportLocation" class="form-control">
                        <option value="">All Rooms</option>
                        @if (ViewBag.AvailableRooms != null)
                        {
                            @foreach (var room in ViewBag.AvailableRooms)
                            {
                                <option value="@room.RoomName">@room.RoomName</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Event Type</label>
                    <select id="exportEventType" class="form-control">
                        <option value="">All Events</option>
                        <option>Alert</option>
                        <option>Access</option>
                    </select>
                </div>

                <!-- Paper Size -->
                <div class="form-group">
                    <label>Paper Size</label>
                    <select id="paperSize" class="form-control">
                        <option value="a4">A4</option>
                        <option value="letter">Letter (8.5" x 11")</option>
                        <option value="landscape">A4 Landscape</option>
                    </select>
                </div>

                <!-- Include Sections -->
                <div class="form-group">
                    <label>Include in Report</label>
                    <div class="checkbox-group">
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeCharts" checked />
                            <label for="includeCharts">Charts & Graphs</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeSummary" checked />
                            <label for="includeSummary">Summary Statistics</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeLogs" />
                            <label for="includeLogs">Activity Logs</label>
                        </div>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" onclick="closeExportModal()">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="generateExportPDF()">Export PDF</button>
            </div>

        </div>
    </div>
</div>

<!-- ================= SCRIPT ================= -->

<script>
const { jsPDF } = window.jspdf;

// ENSURE THIS IS ANALYTICS PAGE ONLY
const isAnalyticsPage = window.location.pathname.includes('/Admin/Analytics');

if (!isAnalyticsPage) {
    console.warn('Analytics script loaded on wrong page');
} else {
    console.log('✓ Analytics page initialized');
}
function openExportPDFModal(){
    const modal = document.getElementById("exportPDFModal");
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeExportModal(){
    const modal = document.getElementById("exportPDFModal");
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

// Close on backdrop click
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('exportPDFModal');
    if (modal) {
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closeExportModal();
            }
        });
    }
});

// =============================================
// HELPER: Load image as Base64 for jsPDF
// =============================================
function loadImageAsBase64(url) {
    return new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = function() {
            const canvas = document.createElement('canvas');
            canvas.width = img.naturalWidth;
            canvas.height = img.naturalHeight;
            canvas.getContext('2d').drawImage(img, 0, 0);
            resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = function() { resolve(null); };
        img.src = url;
    });
}

// =============================================
// QCU LETTERHEAD PDF EXPORT WITH jsPDF + LOGOS
// =============================================
async function generateExportPDF(){
    const startDate = document.getElementById('exportStartDate').value || 'N/A';
    const endDate = document.getElementById('exportEndDate').value || 'N/A';
    const location = document.getElementById('exportLocation').value || 'All Rooms';
    const eventType = document.getElementById('exportEventType').value || 'All Events';
    const paperSize = document.getElementById('paperSize').value;
    const includeCharts = document.getElementById('includeCharts').checked;
    const includeSummary = document.getElementById('includeSummary').checked;
    const includeLogs = document.getElementById('includeLogs').checked;

    // Load logo images as Base64
    const [qcuLogo, ccistLogo] = await Promise.all([
        loadImageAsBase64('/images/qcu-logo.png'),
        loadImageAsBase64('/images/ccist-logo.png')
    ]);

    const isLandscape = paperSize === 'landscape';
    const pdf = new jsPDF({
        orientation: isLandscape ? 'l' : 'p',
        unit: 'mm',
        format: paperSize === 'letter' ? 'letter' : 'a4'
    });

    const pageWidth = pdf.internal.pageSize.getWidth();
    const centerX = pageWidth / 2;
    let y = 12;

    // ========== LETTERHEAD WITH LOGOS ==========
    if (qcuLogo) {
        try { pdf.addImage(qcuLogo, 'PNG', 25, y - 4, 18, 18); } catch(e) {}
    }
    if (ccistLogo) {
        try { pdf.addImage(ccistLogo, 'PNG', pageWidth - 43, y - 4, 18, 18); } catch(e) {}
    }

    pdf.setFontSize(13);
    pdf.setFont('helvetica', 'bold');
    pdf.text('QUEZON CITY UNIVERSITY', centerX, y, { align: 'center' });
    y += 5;
    pdf.setFontSize(9);
    pdf.setFont('helvetica', 'normal');
    pdf.text('COLLEGE OF COMPUTER SCIENCE AND INFORMATION TECHNOLOGY', centerX, y, { align: 'center' });
    y += 4;
    pdf.setFontSize(8);
    pdf.text('San Bartolome  |  San Francisco  |  Batasan Hills', centerX, y, { align: 'center' });
    y += 5;

    // Decorative double line
    pdf.setDrawColor(180, 130, 80);
    pdf.setLineWidth(0.8);
    pdf.line(20, y, pageWidth - 20, y);
    pdf.setLineWidth(0.3);
    pdf.line(20, y + 1.5, pageWidth - 20, y + 1.5);
    y += 8;

    // ========== REPORT TITLE ==========
    pdf.setFontSize(15);
    pdf.setFont('helvetica', 'bold');
    pdf.text('ANALYTICS SECURITY REPORT', centerX, y, { align: 'center' });
    y += 7;

    // Metadata
    pdf.setFontSize(9);
    pdf.setFont('helvetica', 'normal');
    const genDate = new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
    pdf.text(`Generated: ${genDate}`, 25, y);
    y += 4;
    pdf.text(`Date Range: ${startDate} to ${endDate}`, 25, y);
    y += 4;
    pdf.text(`Location: ${location}   |   Event Type: ${eventType}`, 25, y);
    y += 8;

    // ========== SUMMARY STATISTICS BOX ==========
    if (includeSummary) {
        pdf.setFillColor(250, 245, 238);
        pdf.setDrawColor(200, 160, 110);
        pdf.roundedRect(20, y, pageWidth - 40, 28, 2, 2, 'FD');

        pdf.setFontSize(10);
        pdf.setFont('helvetica', 'bold');
        pdf.text('SUMMARY STATISTICS', 25, y + 6);

        pdf.setFontSize(9);
        pdf.setFont('helvetica', 'normal');
        const aAlerts = document.getElementById('statAlerts')?.textContent || '0';
        const aAccess = document.getElementById('statAccess')?.textContent || '0';
        const aDet = document.getElementById('statDetections')?.textContent || '0';
        const aPerso = '@Model.ActivePersonnelCount';

        const col1 = 28, col2 = centerX + 5;
        pdf.text(`Active Alerts: ${aAlerts}`, col1, y + 13);
        pdf.text(`Access Logs: ${aAccess}`, col2, y + 13);
        pdf.text(`Detections: ${aDet}`, col1, y + 19);
        pdf.text(`Personnel: ${aPerso}`, col2, y + 19);
        y += 34;
    }

    // ========== CHARTS (2x2 GRID) ==========
    if (includeCharts) {
        pdf.setFontSize(11);
        pdf.setFont('helvetica', 'bold');
        pdf.text('CHARTS & ANALYTICS', 25, y);
        y += 6;

        const chartIds = ['alertTypeChart', 'accessResultChart', 'detectionTypeChart', 'occupancyRoomChart'];
        const chartImgs = chartIds.map(id => {
            const c = document.getElementById(id);
            return c ? c.toDataURL('image/png') : null;
        }).filter(Boolean);

        const chartW = (pageWidth - 60) / 2;
        const chartH = 75;
        for (let i = 0; i < chartImgs.length; i++) {
            const col = (i % 2);
            const row = Math.floor(i / 2);
            const cx = 22 + col * (chartW + 10);
            const cy = y + row * (chartH + 8);

            if (cy + chartH > pdf.internal.pageSize.getHeight() - 15) {
                pdf.addPage();
                y = 15;
            }
            pdf.addImage(chartImgs[i], 'PNG', cx, cy, chartW, chartH);
        }
        y += Math.ceil(chartImgs.length / 2) * (chartH + 8) + 5;
    }

    // ========== ALERT BREAKDOWN TABLE ==========
    if (y > pdf.internal.pageSize.getHeight() - 60) { pdf.addPage(); y = 15; }

    pdf.setFontSize(11);
    pdf.setFont('helvetica', 'bold');
    pdf.text('ALERT BREAKDOWN', 25, y);
    y += 6;

    // Table header row
    pdf.setFillColor(60, 50, 40);
    pdf.rect(22, y, pageWidth - 44, 7, 'F');
    pdf.setTextColor(255);
    pdf.setFontSize(8);
    pdf.setFont('helvetica', 'bold');
    pdf.text('Type', 28, y + 5);
    pdf.text('Count', 90, y + 5);
    pdf.text('Severity', 140, y + 5);
    y += 7;
    pdf.setTextColor(0);

    // Table rows from alertsByType data
    pdf.setFont('helvetica', 'normal');
    const alertTypeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertsByType ?? new Dictionary<string, int>()));
    const alertTypeKeys = Object.keys(alertTypeData);

    if (alertTypeKeys.length === 0) {
        pdf.setFillColor(248, 248, 248);
        pdf.rect(22, y, pageWidth - 44, 7, 'F');
        pdf.text('No alerts in selected date range', 28, y + 5);
        y += 7;
    } else {
        alertTypeKeys.forEach((type, idx) => {
            const fill = idx % 2 === 0 ? [248, 245, 240] : [255, 255, 255];
            pdf.setFillColor(...fill);
            pdf.rect(22, y, pageWidth - 44, 6, 'F');
            pdf.text(type, 28, y + 4.5);
            pdf.text(String(alertTypeData[type]), 90, y + 4.5);
            const sev = (type.includes('Intrusion') || type.includes('Forced')) ? 'CRITICAL' :
                        (type.includes('Unauthorized') || type.includes('Suspicious')) ? 'WARNING' : 'INFO';
            pdf.text(sev, 140, y + 4.5);
            y += 6;
        });
    }
    y += 6;

    // ========== ACTIVE INTERVENTION QUEUE ==========
    if (y > pdf.internal.pageSize.getHeight() - 50) { pdf.addPage(); y = 15; }

    pdf.setFontSize(11);
    pdf.setFont('helvetica', 'bold');
    pdf.text('ACTIVE INTERVENTION QUEUE', 25, y);
    y += 6;

    const interventionItems = document.querySelectorAll('.status-item');
    if (interventionItems.length === 0) {
        pdf.setFontSize(8);
        pdf.setFont('helvetica', 'normal');
        pdf.text('No active interventions queued.', 28, y + 4);
    } else {
        // Header
        pdf.setFillColor(60, 50, 40);
        pdf.rect(22, y, pageWidth - 44, 7, 'F');
        pdf.setTextColor(255);
        pdf.setFontSize(8);
        pdf.setFont('helvetica', 'bold');
        pdf.text('Alert', 28, y + 5);
        pdf.text('Status / Time', 120, y + 5);
        y += 7;
        pdf.setTextColor(0);
        pdf.setFont('helvetica', 'normal');

        let iRow = 0;
        interventionItems.forEach(item => {
            if (iRow >= 15) return;
            const title = item.querySelector('.status-info p')?.textContent?.trim() || 'N/A';
            const status = item.querySelector('.status-info small')?.textContent?.trim() || '';
            const fill = iRow % 2 === 0 ? [248, 245, 240] : [255, 255, 255];
            pdf.setFillColor(...fill);
            pdf.rect(22, y, pageWidth - 44, 6, 'F');
            pdf.text(title.substring(0, 50), 28, y + 4.5);
            pdf.text(status.substring(0, 40), 120, y + 4.5);
            y += 6;
            iRow++;
        });
    }

    // ========== FOOTER ==========
    const totalPages = pdf.internal.getNumberOfPages();
    for (let p = 1; p <= totalPages; p++) {
        pdf.setPage(p);
        const ph = pdf.internal.pageSize.getHeight();
        pdf.setFontSize(7);
        pdf.setFont('helvetica', 'italic');
        pdf.setTextColor(150);
        pdf.text('SecureVision AI-Assisted Smart Security System  —  Quezon City University', centerX, ph - 8, { align: 'center' });
        pdf.text(`Page ${p} of ${totalPages}`, pageWidth - 25, ph - 8);
        pdf.setTextColor(0);
    }

    // Save PDF
    const fileName = `QCU_Analytics_${new Date().toISOString().split('T')[0]}.pdf`;
    pdf.save(fileName);
    closeExportModal();
}

// =============================================
// CHART CREATION (ANALYTICS PAGE ONLY)
// =============================================
if (isAnalyticsPage) {
const alertsByType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertsByType ?? new Dictionary<string, int>()));
const alertTrendsByDayAndType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertTrendsByDayAndType ?? new Dictionary<string, Dictionary<string, int>>()));
const accessByResult = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AccessByResult ?? new Dictionary<string, int>()));
const detectionsByType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DetectionsByType ?? new Dictionary<string, int>()));
const occupancyRoomLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyRoomLabels ?? new List<string>()));
const occupancyRoomCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyRoomCounts ?? new List<int>()));

// COLOR SCHEMES
const colorPalette = [
    '#ef4444', '#f97316', '#eab308', '#22c55e', '#06b6d4', '#3b82f6', '#8b5cf6', '#ec4899'
];

// 1. ALERT TRENDS BY DAY AND TYPE (Stacked Bar Chart)
const alertTypeCtx = document.getElementById('alertTypeChart');
if (alertTypeCtx && Object.keys(alertTrendsByDayAndType).length > 0) {
    // Get all unique alert types
    const allAlertTypes = new Set();
    Object.values(alertTrendsByDayAndType).forEach(dayData => {
        Object.keys(dayData).forEach(type => allAlertTypes.add(type));
    });
    const alertTypes = Array.from(allAlertTypes);
    
    // Create datasets for each alert type
    const dayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const datasets = alertTypes.map((type, index) => ({
        label: type,
        data: dayLabels.map(day => alertTrendsByDayAndType[day]?.[type] || 0),
        backgroundColor: colorPalette[index % colorPalette.length],
        borderColor: colorPalette[index % colorPalette.length],
        borderWidth: 1
    }));

    new Chart(alertTypeCtx, {
        type: 'bar',
        data: {
            labels: dayLabels,
            datasets: datasets
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    stacked: true,
