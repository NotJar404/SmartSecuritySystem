@model WebApp.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/analytics.css" />

<!-- LIBRARIES -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<div class="dashboard-container">

    <!-- HEADER -->
    <header class="cmd-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Analytics & Security Alerts</h2>
            <small class="text-muted">System performance insights and historical incident tracking.</small>
        </div>

        <div class="header-actions">
            <button class="btn-export btn-pdf" onclick="openExportPDFModal()">
                <i class="fa fa-file-pdf"></i> Export PDF
            </button>
        </div>
    </header>

    <!-- STATS -->
    <section class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fa fa-exclamation-triangle"></i></div>
            <div class="stat-content">
                <span>Active Alerts</span>
                <h3 id="statAlerts">@Model.ActiveIncidentCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa fa-id-badge"></i></div>
            <div class="stat-content">
                <span>Access Logs</span>
                <h3 id="statAccess">@Model.AccessWeekly.Sum()</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green"><i class="fa fa-running"></i></div>
            <div class="stat-content">
                <span>Detections</span>
                <h3 id="statDetections">@Model.TodayDetectionCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fa fa-user-shield"></i></div>
            <div class="stat-content">
                <span>Personnel</span>
                <h3>@Model.ActivePersonnelCount</h3>
            </div>
        </div>
    </section>

    <!-- FILTER PANEL -->
    <section class="panel filter-panel">
        <form method="get" action="/Admin/Analytics">
            <div class="filter-header d-flex justify-content-between align-items-center">
                <div class="filter-title d-flex">
                    <div class="filter-icon me-2"><i class="fa fa-filter"></i></div>
                    <div>
                        <h5 class="mb-0">Report Filters</h5>
                        <small>Customize your report criteria</small>
                    </div>
                </div>
                <button type="submit" class="btn">Apply Filter</button>
            </div>

            <div class="filter-grid">
                <div class="filter-field">
                    <label>Start Date</label>
                    <input type="date" name="startDate" id="startDate" class="filter-input" value="@ViewBag.StartDate" />
                </div>

                <div class="filter-field">
                    <label>End Date</label>
                    <input type="date" name="endDate" id="endDate" class="filter-input" value="@ViewBag.EndDate" />
                </div>

                <div class="filter-field">
                    <label>Room/Location</label>
                    <select name="locationFilter" id="locationFilter" class="filter-input">
                        <option value="">All Rooms</option>
                        <option value="Lobby" selected="@(ViewBag.LocationFilter == "Lobby")">Lobby</option>
                        <option value="Server Room A" selected="@(ViewBag.LocationFilter == "Server Room A")">Server Room A</option>
                    </select>
                </div>

                <div class="filter-field">
                    <label>Event Type</label>
                    <select name="eventFilter" id="eventFilter" class="filter-input">
                        <option value="">All Events</option>
                        <option value="Alert" selected="@(ViewBag.EventFilter == "Alert")">Alert</option>
                        <option value="Access" selected="@(ViewBag.EventFilter == "Access")">Access</option>
                    </select>
                </div>
            </div>
        </form>
    </section>

    <!-- CHARTS -->
    <div class="charts-grid">
        <div class="panel">
            <div class="panel-header">
                <h5>Alert Trends</h5>
                <small>Weekly incident frequency</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="alertChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <h5>Access Activity</h5>
                <small>Authorized entry patterns</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="accessChart"></canvas>
            </div>
        </div>
    </div>

    <div class="charts-grid mt-4">
        <div class="panel">
            <div class="panel-header">
                <h5>Detection Density</h5>
                <small>Motion and sensor triggers</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="motionChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <h5>Facility Occupancy</h5>
                <small>Zone distribution</small>
            </div>
            <div class="chart-wrapper">
                <canvas id="occupancyChart"></canvas>
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-header">
            <h5>Active Intervention Queue</h5>
            <small>Current unresolved alerts requiring attention</small>
        </div>
        <div class="status-list-container">
            @if (Model.ActiveInterventions != null && Model.ActiveInterventions.Any())
            {
                foreach (var alert in Model.ActiveInterventions)
                {
                    var isCritical = alert.Severity == WebApp.Models.SeverityLevel.CRITICAL;
                    var isWarning = alert.Severity == WebApp.Models.SeverityLevel.WARNING;
                    var dotClass = isCritical ? "red" : isWarning ? "yellow" : "green";

                    <div class="status-item">
                        <span class="status-dot-indicator @dotClass"></span>
                        <div class="status-info">
                            <p class="mb-0"><strong>@alert.Type - Room @alert.RoomId</strong></p>
                            <small class="text-muted">Status: @alert.Status | @alert.Timestamp.ToString("g")</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted small text-center mt-3">No active interventions queued.</p>
            }
        </div>
    </div>
    
    <!-- REPORTING SECTION (KEPT EXACTLY) -->
    <section class="panel mt-4 mb-5">
        <div class="panel-header">
            <h5>Automated Reporting Schedule</h5>
            <small>Receive analytics directly to your inbox</small>
        </div>

        <div class="row g-3">
            <div class="col-md-5">
                <label>Administrator Email</label>
                <input type="email" class="form-control warm-input" placeholder="Enter administrator email..." />
            </div>

            <div class="col-md-3">
                <label>Report Frequency</label>
                <select class="form-select warm-input">
                    <option>Daily Digest</option>
                    <option>Weekly Summary</option>
                    <option>Critical Only</option>
                </select>
            </div>

            <div class="col-md-4">
                <label>&nbsp;</label>
                <button class="btn btn-outline-dark">Schedule Report Delivery</button>
            </div>
        </div>
    </section>

</div>

<!-- ================= MODALS ================= -->

<!-- EXPORT PDF MODAL (STANDARDIZED) -->
<div id="exportPDFModal" class="modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 id="modalTitle" class="mb-0">Export Analytics Report</h5>
                <button type="button" class="close" onclick="closeExportModal()" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                
                <!-- Date Range -->
                <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" id="exportStartDate" class="form-control" />
                </div>

                <div class="form-group">
                    <label>End Date</label>
                    <input type="date" id="exportEndDate" class="form-control" />
                </div>

                <!-- Filters -->
                <div class="form-group">
                    <label>Location</label>
                    <select id="exportLocation" class="form-control">
                        <option value="">All Rooms</option>
                        <option>Lobby</option>
                        <option>Server Room A</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Event Type</label>
                    <select id="exportEventType" class="form-control">
                        <option value="">All Events</option>
                        <option>Alert</option>
                        <option>Access</option>
                    </select>
                </div>

                <!-- Paper Size -->
                <div class="form-group">
                    <label>Paper Size</label>
                    <select id="paperSize" class="form-control">
                        <option value="a4">A4</option>
                        <option value="letter">Letter (8.5" x 11")</option>
                        <option value="landscape">A4 Landscape</option>
                    </select>
                </div>

                <!-- Include Sections -->
                <div class="form-group">
                    <label>Include in Report</label>
                    <div class="checkbox-group">
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeCharts" checked />
                            <label for="includeCharts">Charts & Graphs</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeSummary" checked />
                            <label for="includeSummary">Summary Statistics</label>
                        </div>
                        <div class="checkbox-item">
                            <input type="checkbox" id="includeLogs" />
                            <label for="includeLogs">Activity Logs</label>
                        </div>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" onclick="closeExportModal()">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="generateExportPDF()">Export PDF</button>
            </div>

        </div>
    </div>
</div>

<!-- ================= SCRIPT ================= -->

<script>
const { jsPDF } = window.jspdf;

// EXPORT MODAL
function openExportPDFModal(){
    const modal = document.getElementById("exportPDFModal");
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeExportModal(){
    const modal = document.getElementById("exportPDFModal");
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

// Close on backdrop click
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('exportPDFModal');
    if (modal) {
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closeExportModal();
            }
        });
    }
});



// EXPORT PDF WITH FILTERS
async function generateExportPDF(){
    const startDate = document.getElementById('exportStartDate').value;
    const endDate = document.getElementById('exportEndDate').value;
    const location = document.getElementById('exportLocation').value;
    const eventType = document.getElementById('exportEventType').value;
    const paperSize = document.getElementById('paperSize').value;
    const includeCharts = document.getElementById('includeCharts').checked;
    const includeSummary = document.getElementById('includeSummary').checked;
    const includeLogs = document.getElementById('includeLogs').checked;

    const canvas = await html2canvas(document.querySelector(".dashboard-container"), {scale:2});
    const img = canvas.toDataURL("image/png");

    const pdf = new jsPDF({
        orientation: paperSize.includes('landscape') ? 'l' : 'p',
        unit: 'mm',
        format: paperSize === 'letter' ? 'letter' : 'a4'
    });

    // Title & Metadata
    pdf.setFontSize(16);
    pdf.text("Analytics Report", 15, 15);
    
    pdf.setFontSize(10);
    if (startDate) pdf.text(`From: ${startDate}`, 15, 22);
    if (endDate) pdf.text(`To: ${endDate}`, 15, 28);
    if (location) pdf.text(`Location: ${location}`, 15, 34);
    if (eventType) pdf.text(`Event Type: ${eventType}`, 15, 40);

    // Add image
    pdf.addImage(img,'PNG',10,50,190,140);
    
    pdf.save(`analytics_${new Date().toISOString().split('T')[0]}.pdf`);
    closeExportModal();
}

// CHARTS
const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Labels ?? new List<string>()));

function createChart(id,type,data,color){
    new Chart(document.getElementById(id),{
        type:type,
        data:{
            labels:labels,
            datasets:[{
                data:data,
                borderColor:color,
                backgroundColor:color+"20",
                fill:true,
                tension:0.4
            }]
        },
        options:{responsive:true,maintainAspectRatio:false}
    });
}

createChart("alertChart","line",@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertWeekly)),"#ef4444");
createChart("accessChart","bar",@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AccessWeekly)),"#3b82f6");
createChart("motionChart","line",@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MotionWeekly)),"#a855f7");
createChart("occupancyChart","bar",@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyWeekly)),"#D4A373");
</script>