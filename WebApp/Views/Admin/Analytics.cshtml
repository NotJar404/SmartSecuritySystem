@model WebApp.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Analytics & Reports";
    Layout = "_Layout";
}

<div class="dashboard-container analytics">

    <!-- ===================== -->
    <!-- HEADER -->
    <!-- ===================== -->
    <div class="section analytics-header">
        <div class="section-header">
            <div>
                <h3 style="margin:0;">Analytics & Reports</h3>
                <p style="margin:2px 0 0; font-size:12px; color:#9ca3af;">
                    Security system insights and operational monitoring
                </p>
            </div>
        </div>
    </div>

    <!-- ===================== -->
    <!-- STATS -->
    <!-- ===================== -->
    <div class="stats analytics-stats">

        <div class="stat-card">
            <div class="stat-icon red"><i class="fa fa-exclamation-triangle"></i></div>
            <div>
                <h2>@Model.ActiveIncidentCount</h2>
                <p>Active Alerts</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa fa-door-open"></i></div>
            <div>
                <h2>@Model.AccessWeekly.Sum()</h2>
                <p>Access Logs</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green"><i class="fa fa-video"></i></div>
            <div>
                <h2>@Model.TodayDetectionCount</h2>
                <p>Detections</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fa fa-users"></i></div>
            <div>
                <h2>@Model.ActivePersonnelCount</h2>
                <p>Personnel</p>
            </div>
        </div>

    </div>

    <!-- ===================== -->
    <!-- FILTERS (FIXED LAYOUT) -->
    <!-- ===================== -->
    <div class="section">

        <div class="section-header">
            <h3>Report Filters</h3>
        </div>

        <div class="filter-grid">

            <div>
                <label class="filter-label">Start Date</label>
                <input type="date" class="filter-input" />
            </div>

            <div>
                <label class="filter-label">End Date</label>
                <input type="date" class="filter-input" />
            </div>

            <div>
                <label class="filter-label">Location</label>
                <select class="filter-select">
                    <option>All Rooms</option>
                </select>
            </div>

            <div>
                <label class="filter-label">Event Type</label>
                <select class="filter-select">
                    <option>All Events</option>
                </select>
            </div>

        </div>

        <div style="margin-top:10px; display:flex; gap:8px;">
            <button class="btn-action-analytics btn-pdf">Export PDF</button>
            <button class="btn-action-analytics btn-csv">Export CSV</button>
            <button class="btn-action-analytics btn-print">Print</button>
        </div>

    </div>

    <!-- ===================== -->
    <!-- CHARTS (FIXED HEIGHT CONTROL) -->
    <!-- ===================== -->
    <div class="analytics-charts">

        <div class="panel">
            <h4>Alert Trends</h4>
            <div class="chart-container">
                <canvas id="alertChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <h4>Access Activity</h4>
            <div class="chart-container">
                <canvas id="accessChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <h4>Detection Activity</h4>
            <div class="chart-container">
                <canvas id="motionChart"></canvas>
            </div>
        </div>

        <div class="panel">
            <h4>Room Occupancy</h4>
            <div class="chart-container">
                <canvas id="occupancyChart"></canvas>
            </div>
        </div>

    </div>

    <!-- ===================== -->
    <!-- SCHEDULE REPORTS -->
    <!-- ===================== -->
    <div class="section">

        <div class="section-header">
            <h3>Schedule Automated Reports</h3>
        </div>

        <p style="margin-top:-6px; font-size:12px; color:#9ca3af;">
            Receive reports automatically via email
        </p>

        <div class="filter-grid">

            <div style="grid-column: span 2;">
                <label class="filter-label">Email Address</label>
                <input type="email" class="filter-input" placeholder="admin@security.com" />
            </div>

            <div>
                <label class="filter-label">Frequency</label>
                <select class="filter-select">
                    <option>Weekly</option>
                    <option>Monthly</option>
                    <option>Daily</option>
                </select>
            </div>

            <div style="display:flex; align-items:end;">
                <button class="btn-action-analytics btn-pdf" style="width:100%;">
                    Schedule
                </button>
            </div>

        </div>

    </div>

    <!-- ===================== -->
    <!-- RECENT ALERTS -->
    <!-- ===================== -->
    <div class="section">

        <div class="section-header">
            <h3>Recent Alerts</h3>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Event</th>
                    <th>Location</th>
                    <th style="text-align:right;">Severity</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td colspan="5" style="color:#9ca3af;">
                        Connected to database — alerts will appear here
                    </td>
                </tr>
            </tbody>
        </table>

    </div>

</div>

<!-- ===================== -->
<!-- CHART JS -->
<!-- ===================== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Labels ?? new List<string>()));

    function createChart(id, type, data, color) {
        const ctx = document.getElementById(id);
        if (!ctx) return;

        new Chart(ctx, {
            type: type,
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    borderColor: color,
                    backgroundColor: color + "33",
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true },
                    x: { grid: { display: false } }
                }
            }
        });
    }

    createChart("alertChart", "line",
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlertWeekly)),
        "#ef4444");

    createChart("accessChart", "bar",
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AccessWeekly)),
        "#3b82f6");

    createChart("motionChart", "bar",
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MotionWeekly)),
        "#a855f7");

    createChart("occupancyChart", "bar",
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupancyWeekly)),
        "#22c55e");
</script>