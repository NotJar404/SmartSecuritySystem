// =============================================
// AUTOMATED REPORTING SCHEDULE
// =============================================
function scheduleReport() {
    const email = document.getElementById('scheduleEmail').value.trim();
    const freq = document.getElementById('scheduleFrequency');
    const freqLabel = freq.options[freq.selectedIndex].text;

    if (!email) {
        if (typeof showToast === 'function') showToast('Please enter an email address.', 'error');
        else alert('Please enter an administrator email address.');
        return;
    }

    const emailRegex = new RegExp('^[^\\s@@]+@@[^\\s@@]+\\.[^\\s@@]+$');
    if (!emailRegex.test(email)) {
        if (typeof showToast === 'function') showToast('Please enter a valid email address.', 'error');
        return;
    }

    const btn = document.querySelector('[onclick="scheduleReport()"]');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Scheduling...'; }

    fetch('/Admin/ScheduleReport', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, frequency: freqLabel })
    })
    .then(r => r.json())
    .then(data => {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-paper-plane"></i> Schedule Report'; }

        const statusEl = document.getElementById('scheduleStatus');
        const statusText = document.getElementById('scheduleStatusText');
        if (statusEl && statusText) {
            statusEl.style.display = 'block';
            statusText.textContent = data.message || (freqLabel + ' report scheduled for ' + email);
        }

        if (typeof showToast === 'function') showToast(data.message || 'Report scheduled', data.success ? 'success' : 'error');
    })
    .catch(err => {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-paper-plane"></i> Schedule Report'; }
        if (typeof showToast === 'function') showToast('Failed to schedule report: ' + err.message, 'error');
    });
}

// =============================================
// REAL-TIME STAT CARD POLLING (30s)
// =============================================
function refreshAnalyticsStats() {
    fetch('/Admin/AnalyticsData')
    .then(r => r.json())
    .then(data => {
        const sa = document.getElementById('statAlerts');
        const sl = document.getElementById('statAccess');
        const sd = document.getElementById('statDetections');
        const sp = document.getElementById('statPersonnel');
        if (sa) sa.textContent = data.activeAlerts;
        if (sl) sl.textContent = data.accessLogs;
        if (sd) sd.textContent = data.detections;
        if (sp) sp.textContent = data.personnel;
    })
    .catch(() => {});
}

setInterval(refreshAnalyticsStats, 30000);
</script>