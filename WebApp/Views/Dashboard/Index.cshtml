@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-container">

    <!-- ===================== -->
    <!-- STATS -->
    <!-- ===================== -->
    <div class="stats">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa fa-video"></i></div>
            <h2>1 / 1</h2>
            <p>Active Cameras</p>
            <span class="stat-change positive">+0%</span>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fa fa-bullseye"></i></div>
            <h2>23</h2>
            <p>Detections Today</p>
            <span class="stat-change positive">+12%</span>
        </div>

        <div class="stat-card">
            <div class="stat-icon red"><i class="fa fa-bell"></i></div>
            <h2>2</h2>
            <p>Active Alerts</p>
            <span class="stat-change negative">-50%</span>
        </div>

        <div class="stat-card">
            <div class="stat-icon green"><i class="fa fa-id-card"></i></div>
            <h2>4</h2>
            <p>Access Requests</p>
            <span class="stat-change neutral">Pending</span>
        </div>
    </div>

    <!-- ===================== -->
    <!-- QUICK ACTIONS -->
    <!-- ===================== -->
    <div class="panel">
        <h3>Quick Actions</h3>
        <div class="quick-actions">
            <div class="qa-card">
                <div class="qa-icon blue"><i class="fa fa-video"></i></div>
                <div>
                    <h4>Live Monitoring</h4>
                    <p>View all camera feeds in real-time</p>
                </div>
            </div>
            <div class="qa-card">
                <div class="qa-icon purple"><i class="fa fa-id-card"></i></div>
                <div>
                    <h4>Access Monitoring <span class="badge red">4 Pending</span></h4>
                    <p>Review RFID access requests</p>
                </div>
            </div>
            <div class="qa-card">
                <div class="qa-icon orange"><i class="fa fa-bell"></i></div>
                <div>
                    <h4>Security Alerts <span class="badge red">2 Active</span></h4>
                    <p>Check active security alerts</p>
                </div>
            </div>
            <div class="qa-card">
                <div class="qa-icon green"><i class="fa fa-file-alt"></i></div>
                <div>
                    <h4>Activity Logs</h4>
                    <p>View security event logs</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ===================== -->
    <!-- LOWER GRID -->
    <!-- ===================== -->
    <div class="grid-2">

        <!-- RECENT EVENTS -->
        <div class="panel">
            <div class="panel-header">
                <h3>Recent Events</h3>
                <a href="#">View All</a>
            </div>
            <div class="event-item">
                <div class="event-icon blue"><i class="fa fa-eye"></i></div>
                <div>
                    <h4>Motion Detected</h4>
                    <p>Main Entrance • 14:32:15</p>
                </div>
            </div>
            <div class="event-item">
                <div class="event-icon orange"><i class="fa fa-user"></i></div>
                <div>
                    <h4>Person Detected</h4>
                    <p>Backyard • 14:28:43</p>
                </div>
            </div>
        </div>

        <!-- CAMERA STATUS -->
        <div class="panel">
            <div class="panel-header">
                <h3>Camera Status</h3>
                <a href="#">View Live</a>
            </div>
            <div class="camera-item">
                <div>
                    <span class="status-dot online"></span>
                    Main Entrance Camera
                    <p>Front Door</p>
                </div>
                <span class="status-badge">online</span>
            </div>
            <div class="camera-item">
                <div>
                    <span class="status-dot online"></span>
                    Backyard Camera
                    <p>Garden Area</p>
                </div>
                <span class="status-badge">online</span>
            </div>
        </div>

    </div>

</div>