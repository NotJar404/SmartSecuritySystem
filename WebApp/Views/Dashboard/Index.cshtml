@using System.Linq
@model WebApp.Models.DashboardViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";
}

<link rel="stylesheet" href="~/css/dashboard.css" />
<link rel="stylesheet" href="~/css/camera.css" />

<div class="dashboard-container">

    <!-- ===================== -->
    <!-- HEADER + ACTIONS -->
    <!-- ===================== -->
    <header class="cmd-header d-flex justify-content-between align-items-center mb-3">

        <div>
            <h2 class="mb-0">Security Command Center</h2>
            <small class="text-muted">Real-time monitoring & access control</small>
        </div>

        <div class="emergency-cluster">
            <button class="btn-lockdown" onclick="triggerLockdown()">
                <i class="fas fa-lock"></i> LOCKDOWN
            </button>

            <button class="btn-emergency" onclick="triggerEmergency()">
                <i class="fas fa-phone-alt"></i> EMERGENCY
            </button>
        </div>

    </header>

    <!-- ===================== -->
    <!-- STATS ROW -->
    <!-- ===================== -->
    <section class="stats-row mb-4">

        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-video"></i></div>
            <div>
                <span>Active Cameras</span>
                <h3>@Model.ActiveCameraCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fas fa-bullseye"></i></div>
            <div>
                <span>Detections Today</span>
                <h3>@Model.TodayDetectionCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon red"><i class="fas fa-exclamation-triangle"></i></div>
            <div>
                <span>Active Alerts</span>
                <h3>@Model.ActiveAlertCount</h3>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-id-card"></i></div>
            <div>
                <span>Access Logs</span>
                <h3>@Model.PendingAccessCount</h3>
            </div>
        </div>

    </section>

    <!-- ===================== -->
    <!-- CCTV FILMSTRIP -->
    <!-- ===================== -->
    <section class="cctv-filmstrip-section mb-4">

        <div class="panel-header-row">
            <h5>Live Surveillance</h5>
            <div class="d-flex align-items-center" style="gap:12px;">
                <span class="live-badge">● LIVE</span>
                <a href="/Cameras/Index" class="view-more-link">View All <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="horizontal-camera-slider">

            @if (Model.Cameras?.Any() == true)
            {
                foreach (var cam in Model.Cameras)
                {
                    <div class="grid-card dash-cam-card"
                         onclick="window.location.href='/Cameras/Index?selectedId=@cam.Id'"
                         style="cursor:pointer; min-width:280px; flex-shrink:0;">

                        <div class="grid-header">
                            <span class="grid-title">@cam.Name</span>
                            <span class="live-badge">● LIVE</span>
                        </div>

                        <div class="grid-body">
                            <i class="fa fa-camera"></i>
                            <video class="cctv-video grid-preview" muted autoplay playsinline
                                   data-src="@cam.StreamUrl"></video>
                        </div>

                        <div class="grid-meta">
                            <div class="meta-item" title="Face Recognition">
                                <i class="fas fa-user-check"></i>
                                <span class="face-status active">Active</span>
                            </div>
                            <div class="meta-item" title="Status">
                                <span class="cam-status-dot online"></span>
                                <span>Online</span>
                            </div>
                        </div>

                        <div class="grid-footer">
                            <span>@cam.Location</span>
                            <span>@cam.Room?.RoomName</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    No cameras available
                </div>
            }

        </div>

    </section>

    <!-- ===================== -->
    <!-- ALERTS + LOGS (BOTTOM) -->
    <!-- ===================== -->
    <section class="data-grid">

        <!-- ALERTS -->
        <div class="panel panel-alerts">

            <div class="panel-header">
                <h5>Security Alerts</h5>
                <a href="/Alerts/Index" class="view-more-link">View More <i class="fas fa-arrow-right"></i></a>
            </div>

            <div class="alerts-container-dashboard">

                @if (Model.RecentAlerts?.Any() == true)
                {
                    foreach (var item in Model.RecentAlerts.Take(6))
                    {
                        var isCritical = item.Severity == WebApp.Models.SeverityLevel.CRITICAL;
                        var isWarning = item.Severity == WebApp.Models.SeverityLevel.WARNING;
                        var cardClass = "alert-card-dash";
                        cardClass += isCritical ? " critical" : isWarning ? " warning" : " info";

                        <div class="@cardClass">

                            <div class="alert-icon">
                                @(isCritical ? "🚨" : isWarning ? "⚠️" : "ℹ️")
                            </div>

                            <div class="alert-content">
                                <div class="alert-title">@item.Type</div>
                                <div class="alert-description">Room @item.RoomId</div>
                                <div class="alert-time">@item.Timestamp.ToString("HH:mm:ss")</div>
                            </div>

                            <div class="alert-actions-dash">
                                @if (item.Status == WebApp.Models.AlertStatus.New)
                                {
                                    <form method="post" action="/Alerts/Acknowledge" style="display:inline;" id="ackDash-@item.AlertId">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.AlertId" />
                                        <button type="button" class="btn-alert-secondary"
                                                onclick="event.stopPropagation(); SecureConfirm.show({ title:'Acknowledge Alert', icon:'fas fa-check-circle', fields:[{label:'Type',value:'@item.Type'},{label:'Action',value:'Mark as acknowledged'}], onConfirm:function(){document.getElementById('ackDash-@item.AlertId').submit();} });">Acknowledge</button>
                                    </form>
                                }
                                
                                @if (item.Status != WebApp.Models.AlertStatus.Resolved && item.Status != WebApp.Models.AlertStatus.New)
                                {
                                    <form method="post" action="/Alerts/Resolve" style="display:inline;" id="resDash-@item.AlertId">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.AlertId" />
                                        <button type="button" class="btn-alert-secondary" style="background-color: #28a745; color: white;"
                                                onclick="event.stopPropagation(); SecureConfirm.show({ title:'Resolve Alert', icon:'fas fa-check-double', fields:[{label:'Type',value:'@item.Type'}], onConfirm:function(){document.getElementById('resDash-@item.AlertId').submit();} });">Resolve</button>
                                    </form>
                                }

                                @if (isCritical && item.Status != WebApp.Models.AlertStatus.Resolved && item.Status != WebApp.Models.AlertStatus.Escalated)
                                {
                                    <form method="post" action="/Alerts/Escalate" style="display:inline;" id="escDash-@item.AlertId">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.AlertId" />
                                        <button type="button" class="btn-alert-secondary" style="background-color: #dc3545; color: white;"
                                                onclick="event.stopPropagation(); SecureConfirm.show({ title:'Escalate Alert', icon:'fas fa-exclamation-triangle', isDelete:true, fields:[{label:'Type',value:'@item.Type'}], onConfirm:function(){document.getElementById('escDash-@item.AlertId').submit();} });">Escalate</button>
                                    </form>
                                }

                                <a href="/Alerts/Index" class="btn-alert-primary">Details</a>
                            </div>

                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">No alerts</div>
                }

            </div>

        </div>

        <!-- ACCESS LOGS -->
        <div class="panel panel-logs">

            <div class="panel-header">
                <h5>Access Monitoring</h5>
                <a href="/Access/Index" class="view-more-link">View More <i class="fas fa-arrow-right"></i></a>
            </div>

            <div class="log-scroll-dashboard">

                @if (Model.RecentAccessLogs?.Any() == true)
                {
                    foreach (var log in Model.RecentAccessLogs.Take(6))
                    {
                        var statusClass = log.IsAuthorized ? "success" : "danger";
                        var initials = !string.IsNullOrEmpty(log.FullName) 
                            ? new string(log.FullName.Split(' ').Select(n => n[0]).ToArray()) 
                            : "??";
                        
                        <div class="log-card-dash @statusClass">

                            <div class="log-avatar-box">
                                <span class="avatar-initial">@initials</span>
                            </div>

                            <div class="log-info">
                                <div class="log-name">@log.FullName</div>
                                <div class="log-details">
                                    <span class="log-room">@log.Room</span>
                                    <span class="log-time">@log.Timestamp.ToString("hh:mm tt")</span>
                                </div>
                            </div>

                            <div class="log-status">
                                <span class="status-badge @statusClass">
                                    @(log.IsAuthorized ? "AUTHORIZED" : "DENIED")
                                </span>
                            </div>

                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">No logs</div>
                }

            </div>

        </div>

    </section>

</div>

<!-- ===================== -->
<!-- VIDEO STREAM LOGIC -->
<!-- ===================== -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>

<script>
window.addEventListener("DOMContentLoaded", async function () {

    const videos = document.querySelectorAll(".cctv-video");
    let webcamStream = null;

    async function getWebcam() {
        if (webcamStream) return webcamStream;

        try {
            webcamStream = await navigator.mediaDevices.getUserMedia({
                video: true,
                audio: false
            });
            return webcamStream;
        } catch {
            return null;
        }
    }

    for (const video of videos) {

        const url = video.getAttribute("data-src");

        if (url && url.trim() !== "") {

            if (url.includes(".m3u8") && window.Hls) {
                const hls = new Hls();
                hls.loadSource(url);
                hls.attachMedia(video);
            } else {
                video.src = url;
            }

            video.play().catch(() => {});

        } else {

            const stream = await getWebcam();

            if (stream) {
                video.srcObject = stream;
                video.play().catch(() => {});
            }
        }
    }

});

function triggerLockdown() {
    SecureConfirm.show({
        title: 'INITIATE FULL LOCKDOWN?',
        icon: 'fas fa-lock',
        isDelete: true,
        confirmText: 'LOCKDOWN NOW',
        confirmClass: 'btn-danger',
        fields: [
            { label: 'Action', value: 'Lock all doors and restrict access' },
            { label: 'Impact', value: 'All entry points will be secured' },
            { label: 'Severity', value: 'CRITICAL' }
        ],
        onConfirm: function() {
            console.log('Lockdown activated');
            alert('Lockdown protocol initiated.');
        }
    });
}

function triggerEmergency() {
    SecureConfirm.show({
        title: 'EMERGENCY ALERT',
        icon: 'fas fa-phone-alt',
        isDelete: true,
        confirmText: 'SEND ALERT',
        confirmClass: 'btn-danger',
        fields: [
            { label: 'Action', value: 'Notify all security personnel' },
            { label: 'Response', value: 'Emergency services will be contacted' }
        ],
        onConfirm: function() {
            console.log('Emergency triggered');
            alert('Emergency alert dispatched.');
        }
    });
}
</script>