@model WebApp.Models.DashboardViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-container">

    <!-- ===================== -->
    <!-- STATS -->
    <!-- ===================== -->
    <div class="stats">

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon blue"><i class="fa fa-video fa-fw"></i></div>
                <span class="stat-label">Active Cameras</span>
            </div>

            <h2>@Model.ActiveCameraCount / @Model.TotalCameraCount</h2>
            <p>Active Cameras</p>

            <span class="stat-change neutral">Live</span>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon yellow"><i class="fa fa-bullseye fa-fw"></i></div>
                <span class="stat-label">Detections Today</span>
            </div>

            <h2>@Model.TodayDetectionCount</h2>
            <p>Detections Today</p>

            <span class="stat-change positive">Updated</span>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon red"><i class="fa fa-bell fa-fw"></i></div>
                <span class="stat-label">Active Alerts</span>
            </div>

            <h2>@Model.ActiveAlertCount</h2>
            <p>Active Alerts</p>

            <span class="stat-change negative">Attention</span>
        </div>

        <div class="stat-card">
            <div class="stat-top">
                <div class="stat-icon green"><i class="fa fa-id-card fa-fw"></i></div>
                <span class="stat-label">Access Requests</span>
            </div>

            <h2>@Model.PendingAccessCount</h2>
            <p>Access Requests</p>

            <span class="stat-change neutral">Pending</span>
        </div>

    </div>

    <!-- ===================== -->
    <!-- QUICK ACTIONS -->
    <!-- ===================== -->
    <div class="panel">
        <h3>Quick Actions</h3>

        <div class="quick-actions">

            <div class="qa-card">
                <div class="qa-left">
                    <div class="qa-icon blue"><i class="fa fa-video"></i></div>
                    <div>
                        <h4>Live Monitoring</h4>
                        <p>View all camera feeds in real-time</p>
                    </div>
                </div>
                <div class="qa-arrow">
                    <i class="fa fa-chevron-right"></i>
                </div>
            </div>

            <div class="qa-card">
                <div class="qa-left">
                    <div class="qa-icon purple"><i class="fa fa-id-card"></i></div>
                    <div>
                        <h4>
                            Access Monitoring
                            <span class="badge red">@Model.PendingAccessCount Pending</span>
                        </h4>
                        <p>Review RFID access requests</p>
                    </div>
                </div>
                <div class="qa-arrow">
                    <i class="fa fa-chevron-right"></i>
                </div>
            </div>

            <div class="qa-card">
                <div class="qa-left">
                    <div class="qa-icon orange"><i class="fa fa-bell"></i></div>
                    <div>
                        <h4>
                            Security Alerts
                            <span class="badge red">@Model.ActiveAlertCount Active</span>
                        </h4>
                        <p>Check active security alerts</p>
                    </div>
                </div>
                <div class="qa-arrow">
                    <i class="fa fa-chevron-right"></i>
                </div>
            </div>

            <div class="qa-card">
                <div class="qa-left">
                    <div class="qa-icon green"><i class="fa fa-file-alt"></i></div>
                    <div>
                        <h4>Activity Logs</h4>
                        <p>View security event logs</p>
                    </div>
                </div>
                <div class="qa-arrow">
                    <i class="fa fa-chevron-right"></i>
                </div>
            </div>

        </div>
    </div>

    <!-- ===================== -->
    <!-- LOWER GRID -->
    <!-- ===================== -->
    <div class="grid-2">

        <!-- RECENT EVENTS -->
        <div class="panel">
            <div class="panel-header">
                <h3>Recent Events</h3>
                <a href="#">View All</a>
            </div>

            @if (Model.RecentEvents != null && Model.RecentEvents.Any())
            {
                @foreach (var item in Model.RecentEvents)
                {
                    <div class="event-item">
                        <div class="event-icon blue">
                            <i class="fa fa-eye"></i>
                        </div>
                        <div>
                            <h4>
                                @(item.DetectionType switch
                                {
                                    "motion" => "Motion Detected",
                                    "human" => "Person Detected",
                                    "intrusion" => "Intrusion Alert",
                                    "face" => "Face Detected",
                                    _ => item.DetectionType
                                })
                            </h4>
                            <p>
                                @(
                                    item.Camera != null
                                        ? (item.Camera.RoomName ?? item.Camera.Location)
                                        : $"Camera ID: {item.CameraId}"
                                )
                                • @item.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <p>No recent events.</p>
            }
        </div>

        <!-- CAMERA STATUS -->
        <div class="panel">
            <div class="panel-header">
                <h3>Camera Status</h3>
                <a href="#">View Live</a>
            </div>

            @if (Model.Cameras != null && Model.Cameras.Any())
            {
                @foreach (var cam in Model.Cameras)
                {
                    <div class="camera-item">
                        <div>
                            <span class="dot @(cam.Status == "active" ? "online" : "offline")"></span>
                            <div>
                                <strong>@cam.Name</strong>
                                <p>@(cam.RoomName ?? cam.Location)</p>
                            </div>
                        </div>
                        <span class="status-badge">@cam.Status</span>
                    </div>
                }
            }
            else
            {
                <p>No cameras found.</p>
            }
        </div>

    </div>

</div>