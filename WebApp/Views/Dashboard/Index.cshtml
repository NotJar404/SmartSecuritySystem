@using System.Linq
@model WebApp.Models.DashboardViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Security Dashboard";
}

<div class="dashboard-container" role="main">
    <!-- ===================== -->
    <!-- STATS (NO SCROLL) -->
    <!-- ===================== -->
    <section class="stats" aria-label="System Statistics">

        <div class="stat-card">
            <div class="stat-icon blue"><i class="fa fa-video"></i></div>
            <div class="stat-card-content">
                <span class="stat-label">Cameras</span>
                <h2>@Model.ActiveCameraCount</h2>
                <p class="stat-meta">Active</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fa fa-bullseye"></i></div>
            <div class="stat-card-content">
                <span class="stat-label">Detections</span>
                <h2>@Model.TodayDetectionCount</h2>
                <p class="stat-meta">Today</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon red"><i class="fa fa-triangle-exclamation"></i></div>
            <div class="stat-card-content">
                <span class="stat-label">Alerts</span>
                <h2>@Model.ActiveAlertCount</h2>
                <p class="stat-meta">Active</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green"><i class="fa fa-id-card"></i></div>
            <div class="stat-card-content">
                <span class="stat-label">Access</span>
                <h2>@Model.PendingAccessCount</h2>
                <p class="stat-meta">Recent</p>
            </div>
        </div>

    </section>

    <!-- ===================== -->
    <!-- MAIN GRID -->
    <!-- ===================== -->
    <div class="dashboard-grid">

        <!-- ===================== -->
        <!-- LEFT: CCTV (SCROLL ZONE #1) -->
        <!-- ===================== -->
        <section class="grid-left">

            <div class="panel camera-panel">

                <div class="panel-header">
                    <div>
                        <h3>Live CCTV Wall</h3>
                        <p class="panel-subtitle">Real-time camera feeds</p>
                    </div>

                    <a asp-controller="Cameras"
                       asp-action="Index"
                       class="panel-action">
                        Manage Cameras
                    </a>
                </div>

                <!-- 🔥 SCROLLABLE CCTV AREA -->
                <div class="scroll-cctv">

                    <div class="camera-grid cctv-grid">

                        @if (Model.Cameras?.Any() == true)
                        {
                            foreach (var cam in Model.Cameras)
                            {
                                var url = cam.StreamUrl ?? "";
                                var name = cam.Name ?? "Camera";

                                <div class="camera-tile">

                                    <video class="cctv-video"
                                           muted
                                           autoplay
                                           playsinline
                                           preload="auto"
                                           data-src="@url">
                                    </video>

                                    <div class="camera-overlay">
                                        <span class="cam-label">@name</span>
                                        <span class="live-dot">● LIVE</span>
                                    </div>

                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <p>No cameras available</p>
                            </div>
                        }

                    </div>

                </div>

            </div>

        </section>

        <!-- ===================== -->
        <!-- RIGHT SIDE -->
        <!-- ===================== -->
        <aside class="grid-right">

            <!-- ===================== -->
            <!-- ACCESS (SCROLL ZONE #2) -->
            <!-- ===================== -->
            <div class="panel">

                <div class="panel-header">
                    <div>
                        <h3>Access Monitoring</h3>
                        <p class="panel-subtitle">Recent entry activity</p>
                    </div>
                </div>

                <div class="scroll-zone">

                    @if (Model.RecentAccessLogs?.Any() == true)
                    {
                        foreach (var log in Model.RecentAccessLogs)
                        {
                            <div class="event-item">

                                <div class="event-icon @(log.IsAuthorized ? "blue" : "red")">
                                    <i class="fa @(log.IsAuthorized ? "fa-check" : "fa-xmark")"></i>
                                </div>

                                <div class="event-content">
                                    <h4>@log.FullName</h4>
                                    <p>@log.Room • @log.Timestamp.ToLocalTime().ToString("hh:mm tt")</p>
                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">No access logs</div>
                    }

                </div>

            </div>

            <!-- ===================== -->
            <!-- ALERTS (SCROLL ZONE #3) -->
            <!-- ===================== -->
            <div class="panel">

                <div class="panel-header">
                    <div>
                        <h3>Security Alerts</h3>
                        <p class="panel-subtitle">Detected events</p>
                    </div>
                </div>

                <div class="scroll-zone">

                    @if (Model.RecentEvents?.Any() == true)
                    {
                        foreach (var item in Model.RecentEvents)
                        {
                            <div class="alert-card">

                                <h4>
                                    @(item.DetectionType switch
                                    {
                                        "motion" => "Motion Detected",
                                        "human" => "Person Detected",
                                        "intrusion" => "Intrusion Alert",
                                        "face" => "Face Recognized",
                                        _ => item.DetectionType
                                    })
                        </h4>

                                <p>
                                    @item.Camera?.RoomName •
                                    @item.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                                </p>

                            </div>
                                        }
                    }
                    else
                    {
                        <div class="empty-state">No alerts</div>
                    }

                </div>

            </div>

        </aside>

    </div>
</div>

<!-- ===================== -->
<!-- CCTV AUTO PLAYER -->
<!-- ===================== -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>

<script>

    window.addEventListener("DOMContentLoaded", async function () {

        const videos = document.querySelectorAll(".cctv-video");

        let webcamStream = null;

        async function getWebcam() {
            if (webcamStream) return webcamStream;

            try {
                webcamStream = await navigator.mediaDevices.getUserMedia({
                    video: true,
                    audio: false
                });

                return webcamStream;
            }
            catch (err) {
                console.log("Webcam access denied:", err);
                return null;
            }
        }

        for (const video of videos) {

            const url = video.getAttribute("data-src");

            video.muted = true;
            video.playsInline = true;
            video.autoplay = true;

            if (url && url.trim() !== "") {

                if (url.includes(".m3u8") && window.Hls) {

                    const hls = new Hls();
                    hls.loadSource(url);
                    hls.attachMedia(video);

                } else {
                    video.src = url;
                }

                video.load();

                video.play().catch(err => {
                    console.log("Stream failed:", url, err);
                });

            } else {

                const stream = await getWebcam();

                if (stream) {
                    video.srcObject = stream;

                    video.play().catch(err => {
                        console.log("Webcam play failed:", err);
                    });
                }
            }
        }

    });
</script>