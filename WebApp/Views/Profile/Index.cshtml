@model WebApp.Models.Profile

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Profile";
}
<link rel="stylesheet" href="~/css/profile.css" />

<div class="profile-dashboard">
    <div class="dashboard-header">
        <div class="header-text">
            <h1 class="page-main-title">User Account Settings</h1>
            <p class="system-timestamp">@DateTime.Now.ToString("dddd, MMMM dd, yyyy") | Active Session</p>
        </div>
    </div>

    <div class="profile-main-grid">
        
        <div class="grid-column">
            <section class="system-card identity-card taller-card">
                <div class="card-content-wrapper">
                    <h2 class="card-title"><i class="fa fa-user-circle"></i> Profile Information</h2>
                    <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" class="tight-form">
                        <div class="avatar-section">
                            <div class="avatar-ring">
                                <img src="@(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/images/default-profile.png" : Model.ProfileImagePath)"
                                     class="profile-image-circle" id="profilePreview" />
                                <label for="fileInput" class="edit-overlay"><i class="fa fa-pen"></i></label>
                            </div>
                            <input type="file" id="fileInput" name="ProfileImage" hidden onchange="previewImage(this)" />
                        </div>

                        <div class="field-stack">
                            <div class="field-group">
                                <label>Full Name</label>
                                <input asp-for="FullName" class="system-input" placeholder="Enter display name" />
                            </div>
                            <div class="field-group">
                                <label>Username</label>
                                <input asp-for="Username" class="system-input readonly" readonly />
                            </div>
                            <div class="field-group">
                                <label>Email Address</label>
                                <input asp-for="Email" class="system-input" placeholder="name@example.com" />
                            </div>
                        </div>
                        <button type="submit" class="btn-accent-save">Save Changes</button>
                    </form>
                </div>

                <div class="card-footer-grid">
                    <div class="id-block">
                        <span class="id-label"><i class="fa fa-fingerprint"></i> Personnel ID</span>
                        <span class="id-value">#@Model.Id</span>
                    </div>
                    <div class="id-block">
                        <span class="id-label"><i class="fa fa-shield-halved"></i> Access Role</span>
                        <span class="id-value role-badge">@Model.Role</span>
                    </div>
                </div>
            </section>
        </div>

        <div class="grid-column wide">
            <section class="system-card security-card">
                <h2 class="card-title"><i class="fa fa-key"></i> Credential Management</h2>
                <p class="text-muted-sm">Update your system access password. Rules will update in real-time.</p>
                
                <form asp-action="ChangePassword" method="post" class="password-grid">
                    <div class="pass-inputs">
                        <div class="field-group">
                            <label>Current Password</label>
                            <input type="password" name="CurrentPassword" class="system-input" required />
                        </div>
                        <div class="field-group">
                            <label>New Password</label>
                            <input type="password" id="newPass" name="NewPassword" class="system-input" required />
                        </div>
                        <div class="field-group">
                            <label>Confirm Password</label>
                            <input type="password" name="ConfirmPassword" class="system-input" required />
                        </div>
                    </div>

                    <div class="pass-rules-box">
                        <span class="rules-header">Security Requirements</span>
                        <ul class="rule-checklist" id="ruleList">
                            <li id="rule-len" class="rule"><i class="fa fa-circle"></i> 8+ Characters</li>
                            <li id="rule-up" class="rule"><i class="fa fa-circle"></i> One Uppercase</li>
                            <li id="rule-num" class="rule"><i class="fa fa-circle"></i> One Number</li>
                            <li id="rule-spec" class="rule"><i class="fa fa-circle"></i> Special Char</li>
                        </ul>
                    </div>

                    <button type="submit" id="btnUpdate" class="btn-secure-action" disabled>Update Credentials</button>
                </form>
            </section>

            <div class="bottom-flex">
                <section class="system-card status-card">
                    <h2 class="card-title-sm"><i class="fa fa-shield-check"></i> Account Integrity</h2>
                    <div class="info-display-list">
                        <div class="integrity-row">
                            <span class="info-label">Current Status</span> 
                            <span class="status-active-pill">@Model.Status</span>
                        </div>
                        <div class="integrity-row">
                            <span class="info-label">Last Login</span> 
                            <strong class="info-val">@Model.LastLogin</strong>
                        </div>
                    </div>
                </section>

                <section class="system-card session-card">
                    <h2 class="card-title-sm"><i class="fa fa-network-wired"></i> Current Session</h2>
                    <div class="info-display-list">
                        <div class="integrity-row">
                            <span class="info-label">IP Address</span> 
                            <code class="ip-display">@Context.Connection.RemoteIpAddress</code>
                        </div>
                        <button class="btn-logout-session">
                            <i class="fa fa-right-from-bracket"></i> Terminate Session
                        </button>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

<script>
    const newPass = document.getElementById('newPass');
    const updateBtn = document.getElementById('btnUpdate');

    newPass.addEventListener('input', () => {
        const val = newPass.value;
        const requirements = {
            'rule-len': val.length >= 8,
            'rule-up': /[A-Z]/.test(val),
            'rule-num': /[0-9]/.test(val),
            'rule-spec': /[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(val)
        };

        let passedCount = 0;
        for (const [id, passed] of Object.entries(requirements)) {
            const el = document.getElementById(id);
            if (passed) { el.classList.add('valid'); passedCount++; }
            else { el.classList.remove('valid'); }
        }
        updateBtn.disabled = passedCount < 4;
    });

    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('profilePreview').src = e.target.result;
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>