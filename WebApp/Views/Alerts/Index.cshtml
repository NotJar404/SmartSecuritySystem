@model List<WebApp.Models.Alert>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Alerts";
    var filter = ViewBag.Filter as string ?? "All";
}
<link rel="stylesheet" href="~/css/alert.css" />

<h1 class="page-title">Alerts</h1>
<p class="subtitle">@Model.Count(a => a.Status == WebApp.Models.AlertStatus.Active) active alerts</p>

<!-- FILTER BUTTONS -->
<div class="alert-filters">
    <a asp-action="Index" asp-route-filter="All"
       class="filter-btn @(filter=="All"?"active":"")">
        All (@Model.Count)
    </a>

    <a asp-action="Index" asp-route-filter="Active"
       class="filter-btn @(filter=="Active"?"active":"")">
        Active (@Model.Count(a => a.Status == WebApp.Models.AlertStatus.Active))
    </a>

    <a asp-action="Index" asp-route-filter="Acknowledged"
       class="filter-btn @(filter=="Acknowledged"?"active":"")">
        Acknowledged (@Model.Count(a => a.Status == WebApp.Models.AlertStatus.Acknowledged))
    </a>

    <a asp-action="Index" asp-route-filter="Resolved"
       class="filter-btn @(filter=="Resolved"?"active":"")">
        Resolved (@Model.Count(a => a.Status == WebApp.Models.AlertStatus.Resolved))
    </a>
</div>

<!-- ALERT LIST -->
<div class="alerts-container">

@foreach (var alert in Model)
{
    var isCritical = alert.Severity == WebApp.Models.SeverityLevel.CRITICAL;
    var isResolved = alert.Status == WebApp.Models.AlertStatus.Resolved;

    <div class="alert-card @(isCritical ? "critical" : "warning") @(isResolved ? "resolved" : "")"
         onclick="openModal(
            '@alert.Id',
            '@alert.Title',
            '@alert.Description',
            '@alert.Location',
            '@alert.Severity',
            '@alert.CreatedAt.ToString("g")',
            '@alert.Status'
         )">

        <!-- ICON -->
        <div class="alert-icon">⚠</div>

        <!-- CONTENT -->
        <div class="alert-content">
            <div class="alert-header">
                <h3>@alert.Title</h3>

                <span class="badge @(isCritical ? "red" : "yellow")">
                    @alert.Severity.ToString()
                </span>

                <span class="badge">
                    @alert.Status.ToString()
                </span>
            </div>

            <p>@alert.Description</p>

            <div class="alert-meta">
                📍 @alert.Location
                • ⏱ @alert.MinutesAgo m ago
                • @alert.CreatedAt.ToString("g")
            </div>
        </div>

        <!-- QUICK RESOLVE BUTTON -->
        <div class="alert-actions">
            @if (!isResolved)
            {
                <form method="post" asp-action="Resolve" onclick="event.stopPropagation();">
                    <input type="hidden" name="id" value="@alert.Id" />
                    <button type="submit">Resolve</button>
                </form>
            }

            <button onclick="event.stopPropagation();">✕</button>
        </div>

    </div>
}

</div>

<!-- MODAL -->
<div id="alertModal">
    <div>
        <span onclick="closeModal()" style="cursor:pointer;">&times;</span>

        <h2 id="modalTitle"></h2>

        <!-- ALERT INFORMATION SECTION -->
        <div class="section">
            <div class="info-row">
                <span class="info-label">Status:</span>
                <span id="modalStatus"></span>
            </div>
            <div class="info-row">
                <span class="info-label">Severity:</span>
                <span id="modalSeverity"></span>
            </div>
            <div class="info-row">
                <span class="info-label">Location:</span>
                <span id="modalLocation"></span>
            </div>
            <div class="info-row">
                <span class="info-label">Time:</span>
                <span id="modalTime"></span>
            </div>
        </div>

        <!-- DESCRIPTION SECTION -->
        <div class="section">
            <h4 class="section-title">Description</h4>
            <p id="modalDescription"></p>
        </div>

        <!-- SNAPSHOT SECTION -->
        <div class="section">
            <h4 class="section-title">Snapshot</h4>
            <img src="/images/sample.jpg" alt="snapshot" width="100%" />
        </div>

        <!-- ACTION BUTTONS SECTION -->
        <div class="section section-actions">
            <form method="post" asp-action="Acknowledge">
                <input type="hidden" name="id" class="modalAlertId" />
                <button type="submit" class="btn-acknowledge">Acknowledge</button>
            </form>

            <form method="post" asp-action="Resolve">
                <input type="hidden" name="id" class="modalAlertId" />
                <button type="submit" class="btn-resolve">Resolve</button>
            </form>

            <form method="post" asp-action="Escalate">
                <input type="hidden" name="id" class="modalAlertId" />
                <button type="submit" class="btn-escalate">Escalate</button>
            </form>

            <button onclick="viewLive()" class="btn-live">View Live</button>
        </div>
    </div>
</div>

<!-- SCRIPT -->
<script>
function openModal(id, title, desc, location, severity, time, status) {
    var modal = document.getElementById("alertModal");
    modal.classList.add("active");

    // Set all hidden inputs
    document.querySelectorAll(".modalAlertId").forEach(input => {
        input.value = id;
    });

    document.getElementById("modalTitle").innerText = title;
    document.getElementById("modalDescription").innerText = desc;
    document.getElementById("modalLocation").innerText = location;
    document.getElementById("modalSeverity").innerText = severity;
    document.getElementById("modalTime").innerText = time;
    document.getElementById("modalStatus").innerText = status;
}

function closeModal() {
    var modal = document.getElementById("alertModal");
    modal.classList.remove("active");
}

function viewLive() {
    window.location.href = '/Cameras';
}

// Close modal when clicking outside
document.getElementById("alertModal").addEventListener("click", function(e) {
    if (e.target === this) {
        closeModal();
    }
});
</script>
</script>
</script>