@using WebApp.Models
@using System.Text.Json
@model List<Alert>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Alerts";
    var filter = (ViewBag.Filter as string ?? "all").ToLower();
}
<link rel="stylesheet" href="~/css/alert.css" />

<h1 class="page-title">Alerts</h1>

<p class="subtitle">
    @Model.Count(a => a.Status != AlertStatus.Resolved) active alerts
</p>

<!-- FILTER BUTTONS -->
<div class="alert-filters">

    <a asp-action="Index" asp-route-filter="all"
       class="filter-btn @(filter == "all" ? "active" : "")">
        All (@Model.Count)
    </a>

    <a asp-action="Index" asp-route-filter="new"
       class="filter-btn @(filter == "new" ? "active" : "")">
        New (@Model.Count(a => a.Status == AlertStatus.New))
    </a>

    <a asp-action="Index" asp-route-filter="acknowledged"
       class="filter-btn @(filter == "acknowledged" ? "active" : "")">
        Acknowledged (@Model.Count(a => a.Status == AlertStatus.Acknowledged))
    </a>

    <a asp-action="Index" asp-route-filter="resolved"
       class="filter-btn @(filter == "resolved" ? "active" : "")">
        Resolved (@Model.Count(a => a.Status == AlertStatus.Resolved))
    </a>

</div>

<!-- ALERT LIST -->
<div class="alerts-container">

@foreach (var alert in Model)
{
    var isCritical = alert.Severity == SeverityLevel.CRITICAL;
    var isResolved = alert.Status == AlertStatus.Resolved;

    <div class="alert-card @(isCritical ? "critical" : "warning") @(isResolved ? "resolved" : "")"
         onclick='openModal(
            @JsonSerializer.Serialize(alert.AlertId),
            @JsonSerializer.Serialize(alert.Type ?? ""),
            @JsonSerializer.Serialize(alert.Description ?? ""),
            @JsonSerializer.Serialize(alert.RoomId?.ToString() ?? ""),
            @JsonSerializer.Serialize(alert.Severity.ToString()),
            @JsonSerializer.Serialize(alert.Timestamp.ToString("g")),
            @JsonSerializer.Serialize(alert.Status.ToString())
         )'>

        <div class="alert-icon">⚠</div>

        <div class="alert-content">
            <div class="alert-header">
                <h3>@alert.Type</h3>

                <span class="badge @(isCritical ? "red" : "yellow")">
                    @alert.Severity
                </span>

                <span class="badge">
                    @alert.Status
                </span>
            </div>

            <p>@alert.Description</p>

            <div class="alert-meta">
                Room: @alert.RoomId
                • ⏱ @alert.MinutesAgo m ago
                • @alert.Timestamp.ToString("g")
            </div>
        </div>

        <div class="alert-actions">

            @if (!isResolved)
            {
                <form method="post" asp-action="Resolve" onclick="event.stopPropagation();">
                    <input type="hidden" name="id" value="@alert.AlertId" />
                    <button type="submit">Resolve</button>
                </form>
            }

            <button onclick="event.stopPropagation();">✕</button>

        </div>
    </div>
}

</div>

<!-- MODAL -->
<div id="alertModal">
    <div>
        <span onclick="closeModal()" style="cursor:pointer;">&times;</span>

        <h2 id="modalTitle"></h2>

        <div class="section">
            <p><b>Status:</b> <span id="modalStatus"></span></p>
            <p><b>Severity:</b> <span id="modalSeverity"></span></p>
            <p><b>Room:</b> <span id="modalLocation"></span></p>
            <p><b>Time:</b> <span id="modalTime"></span></p>
        </div>

        <div class="section">
            <h4>Description</h4>
            <p id="modalDescription"></p>
        </div>

        <div class="section section-actions">

            <form method="post" asp-action="Acknowledge">
                <input type="hidden" name="id" class="modalAlertId" />
                <button type="submit">Acknowledge</button>
            </form>

            <form method="post" asp-action="Resolve">
                <input type="hidden" name="id" class="modalAlertId" />
                <button type="submit">Resolve</button>
            </form>

            <form method="post" asp-action="Escalate">
                <input type="hidden" name="id" class="modalAlertId" />
                <button type="submit">Escalate</button>
            </form>

        </div>
    </div>
</div>

<script>
function openModal(id, type, desc, room, severity, time, status) {
    document.getElementById("alertModal").classList.add("active");

    document.querySelectorAll(".modalAlertId").forEach(x => x.value = id);

    document.getElementById("modalTitle").innerText = type;
    document.getElementById("modalDescription").innerText = desc;
    document.getElementById("modalLocation").innerText = room;
    document.getElementById("modalSeverity").innerText = severity;
    document.getElementById("modalTime").innerText = time;
    document.getElementById("modalStatus").innerText = status;
}

function closeModal() {
    document.getElementById("alertModal").classList.remove("active");
}

document.getElementById("alertModal").addEventListener("click", function (e) {
    if (e.target === document.getElementById("alertModal")) {
        closeModal();
    }
});
</script>