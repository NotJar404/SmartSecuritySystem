@model List<WebApp.Models.AccessLog>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "AI Assisted Smart Security and Intrusion Detection System";

    var activePersonIds = ViewBag.ActivePersonIds as HashSet<int> ?? new HashSet<int>();
    var activeSessions = ViewBag.ActiveSessions as List<WebApp.Models.OccupancySession>
                         ?? new List<WebApp.Models.OccupancySession>();
}

<link rel="stylesheet" href="~/css/access.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="access-grid">

    <div class="grid-header">
        <div class="header-left">
            <i class="fa fa-shield-halved me-2"></i>
            <span>SECUREVISION ACCESS CONTROL</span>
        </div>
        <div class="header-right">
            <span id="statusText" class="active-selection-text">System Monitoring Active</span>
            @if (activeSessions.Any())
            {
                <span class="ms-3" style="color: #2ecc71; font-size: 0.8rem;">
                    <i class="fa fa-users me-1"></i>@activeSessions.Count active session(s)
                </span>
            }
        </div>
    </div>

    <div class="grid-main">
        <div class="panel-body">

            <div id="emptyState" class="center-content">
                <div class="avatar-bg">
                    <i class="fa fa-user-shield"></i>
                </div>
                <p class="text-muted mt-3">Select a log entry to view full biometric details</p>
            </div>

            <div id="detailContent" class="detail-layout" style="display:none;">
                
                <div class="dashboard-container">
                    <div class="profile-header-card">
                        <div class="profile-main-info">
                            <img id="detImg" src="~/images/default-user.png" class="profile-large shadow" />
                            <div class="ms-4">
                                <h2 id="detName" class="display-name">Name</h2>
                                <p class="id-tag">Personnel ID: <span id="detId">0000</span></p>
                                <div id="detStatus" class="status-badge">PENDING</div>
                                <div id="detSessionBadge" class="session-indicator" style="display:none;"></div>
                            </div>
                        </div>
                    </div>

                    <div class="info-dashboard-grid">
                        <div class="info-card">
                            <h6><i class="fa fa-id-card me-2"></i>Affiliation Details</h6>
                            <div class="data-row">
                                <span class="data-label">Department</span>
                                <span id="detDept" class="data-value">-</span>
                            </div>
                            <div class="data-row">
                                <span class="data-label">Email</span>
                                <span id="detEmail" class="data-value">-</span>
                            </div>
                            <div class="data-row">
                                <span class="data-label">Contact</span>
                                <span id="detPhone" class="data-value">-</span>
                            </div>
                        </div>

                        <div class="info-card">
                            <h6><i class="fa fa-map-marker-alt me-2"></i>Access Specifics</h6>
                            <div class="data-row">
                                <span class="data-label">Room</span>
                                <span id="detRoom" class="data-value">-</span>
                            </div>
                            <div class="data-row">
                                <span class="data-label">Location</span>
                                <span id="detLoc" class="data-value">-</span>
                            </div>
                            <div class="data-row">
                                <span class="data-label">Timestamp</span>
                                <span id="detTime" class="data-value">-</span>
                            </div>
                        </div>
                    </div>

                    <div id="actionContainer" class="action-container-full">
                        <p class="action-title">Available Security Protocols</p>
                        <div id="actionPanel" class="action-button-group">
                            </div>
                    </div>

                    <!-- FIX-7: Inline Video Player -->
                    <div id="videoPlayerContainer" style="display:none; margin-top: 16px;">
                        <div style="background: #0d1117; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08);">
                            <div style="padding: 10px 16px; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.03);">
                                <span style="color: #f39c12; font-weight: 600; font-size: 0.85rem;"><i class="fa fa-video me-2"></i>Recording Playback</span>
                                <button onclick="closeVideoPlayer()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.1rem;">&times;</button>
                            </div>
                            <video id="inlineVideoPlayer" controls style="width: 100%; max-height: 320px; background: #000;">
                                Your browser does not support video playback.
                            </video>
                        </div>
                    </div>

                    <!-- FIX-7: Personnel Access History Modal -->
                    <div id="historyContainer" style="display:none; margin-top: 16px;">
                        <div style="background: #0d1117; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08);">
                            <div style="padding: 10px 16px; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.03);">
                                <span style="color: #58a6ff; font-weight: 600; font-size: 0.85rem;"><i class="fa fa-history me-2"></i>Access History</span>
                                <button onclick="closeHistory()" style="background: none; border: none; color: #aaa; cursor: pointer; font-size: 1.1rem;">&times;</button>
                            </div>
                            <div id="historyContent" style="padding: 12px 16px; max-height: 280px; overflow-y: auto;"></div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>

    <div class="grid-nav">
        <div class="log-header-fixed">
            <i class="fa fa-list-ul me-2"></i>Recent Activity
        </div>
        <div class="log-scroll">
            @foreach (var log in Model)
            {
                // Simple initial logic for the avatar box
                var initials = !string.IsNullOrEmpty(log.FullName) 
                    ? new string(log.FullName.Split(' ').Select(n => n[0]).ToArray()) 
                    : "??";

                // SESSION-AWARE: Determine true status from FSM data
                var isCurrentlyInside = log.PersonId.HasValue && activePersonIds.Contains(log.PersonId.Value);
                var sessionStatus = isCurrentlyInside ? "INSIDE" : "";

                // Compute risk level from actual RFID + Face data
                var computedRisk = log.ComputedRiskLevel;

                // We pass the VideoPath and session info to the JS function here
                <div class="log-card @(isCurrentlyInside ? "session-active" : "")" 
                     onclick="dockData('@log.FullName', '@log.PersonnelId', '@log.Location', '@log.ImageUrl', '@log.Department', '@log.Email', '@log.Phone', '@log.Room', '@log.Timestamp.ToString("hh:mm tt")', '@log.VideoPath', '@computedRisk', @(isCurrentlyInside ? "true" : "false"), '@log.RfidValid', '@log.FaceVerified')">
                    
                    <div class="log-avatar-box">
                        <span class="avatar-initial">@initials</span>
                    </div>

                    <div class="log-info">
                        <div class="d-flex justify-content-between">
                            <span class="log-name">@log.FullName</span>
                            <span class="log-time">@log.Timestamp.ToString("hh:mm tt")</span>
                        </div>
                        <p class="log-sub">
                            @log.Location • @log.Room
                            @if (isCurrentlyInside)
                            {
                                <span style="color: #2ecc71; font-weight: 600; margin-left: 6px;">● INSIDE</span>
                            }
                            @if (log.HasVideo)
                            {
                                <span style="color: #f39c12; font-weight: 600; margin-left: 6px;" title="Video Evidence Available"><i class="fa fa-video"></i> REC</span>
                            }
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>

</div>

<script>
let currentVideoPath = "";
let currentLogContext = null;

// =========================
// MAIN LOG VIEW (SESSION-AWARE)
// =========================
function dockData(name, id, loc, img, dept, email, phone, room, time, videoPath, riskLevel, isInside, rfidValid, faceVerified) {
    document.getElementById("emptyState").style.display = "none";
    document.getElementById("detailContent").style.display = "block";

    currentVideoPath = videoPath;

    currentLogContext = {
        name, id, loc, img, dept, email, phone, room, time, riskLevel, isInside, rfidValid, faceVerified
    };

    document.getElementById("detName").innerText = name;
    document.getElementById("detId").innerText = id || "N/A";
    document.getElementById("detImg").src = img || '/images/default-user.png';

    document.getElementById("detDept").innerText = dept || "-";
    document.getElementById("detEmail").innerText = email || "-";
    document.getElementById("detPhone").innerText = phone || "-";

    document.getElementById("detRoom").innerText = room || "-";
    document.getElementById("detLoc").innerText = loc || "-";
    document.getElementById("detTime").innerText = time || "-";

    document.getElementById("statusText").innerText = "Viewing Detail: " + name;

    // =========================
    // SESSION-AWARE STATUS
    // =========================
    const sessionBadge = document.getElementById("detSessionBadge");

    if (isInside === true || isInside === "true" || isInside === "True") {
        sessionBadge.style.display = "inline-block";
        sessionBadge.innerHTML = '<i class="fa fa-circle me-1" style="color:#2ecc71;font-size:8px;"></i> Currently Inside (Active Session)';
        sessionBadge.style.color = "#2ecc71";
        sessionBadge.style.fontSize = "0.8rem";
        sessionBadge.style.marginTop = "6px";
    } else {
        sessionBadge.style.display = "none";
    }

    // =========================
    // SEVERITY FROM REAL DATA (NOT NAIVE NAME CHECK)
    // =========================
    setStatus(riskLevel, isInside, rfidValid, faceVerified);
}

// =========================
// STATUS UI ENGINE (SESSION-AWARE)
// =========================
function setStatus(riskLevel, isInside, rfidValid, faceVerified) {
    const badge = document.getElementById("detStatus");
    const panel = document.getElementById("actionPanel");
    const container = document.getElementById("actionContainer");

    panel.innerHTML = "";
    badge.className = "status-badge";
    container.className = "action-container-full";

    // Normalize boolean strings
    const inside = (isInside === true || isInside === "true" || isInside === "True");
    const rfid = (rfidValid === "True" || rfidValid === true);
    const face = (faceVerified === "True" || faceVerified === true);

    // =========================
    // AUTHORIZED (RFID + Face verified, or active session)
    // =========================
    if (riskLevel === "AUTHORIZED" || (inside && rfid)) {
        badge.innerText = inside ? "ACCESS GRANTED — INSIDE" : "ACCESS GRANTED";
        badge.classList.add("authorized");
        container.classList.add("severity-low");

        panel.innerHTML = `
            <button class="btn-sec btn-neutral" onclick="printSlip()">
                <i class="fa fa-print me-2"></i>Print Access Slip
            </button>
            <button class="btn-sec btn-neutral" onclick="viewAccessHistory()">
                <i class="fa fa-history me-2"></i>View History
            </button>
            ${inside ? `
            <button class="btn-sec btn-neutral" onclick="viewActiveSession()">
                <i class="fa fa-eye me-2"></i>View Session
            </button>` : ""}
            ${currentVideoPath ? `
            <button class="btn-sec btn-neutral" onclick="playLogVideo()">
                <i class="fa fa-video me-2"></i>View Recording
            </button>` : ""}
        `;
    }

    // =========================
    // SUSPICIOUS (RFID valid but face NOT verified, or face mismatch)
    // =========================
    else if (riskLevel === "SUSPICIOUS") {
        badge.innerText = "SUSPICIOUS ACTIVITY";
        badge.classList.add("suspicious");
        container.classList.add("severity-med");

        panel.innerHTML = `
            ${currentVideoPath ? `
            <button class="btn-sec btn-warning" onclick="playLogVideo()">
                <i class="fa fa-video me-2"></i>Review Footage
            </button>` : ""}

            <button class="btn-sec btn-neutral" onclick="flagForAdmin()">
                <i class="fa fa-flag me-2"></i>Flag for Admin
            </button>

            <button class="btn-sec btn-warning" onclick="manualVerify()">
                <i class="fa fa-user-check me-2"></i>Manual Verify
            </button>

            <button class="btn-sec btn-danger" onclick="lockdownRoom()">
                <i class="fa fa-lock me-2"></i>Lockdown Room
            </button>
        `;
    }

    // =========================
    // UNAUTHORIZED (No RFID, no face — full intrusion)
    // =========================
    else if (riskLevel === "UNAUTHORIZED") {
        badge.innerText = "UNAUTHORIZED INTRUSION";
        badge.classList.add("unauthorized");
        container.classList.add("severity-high");

        panel.innerHTML = `
            <button class="btn-sec btn-danger" onclick="triggerAlarm()">
                <i class="fa fa-bell me-2"></i>TRIGGER ALARM
            </button>

            <button class="btn-sec btn-dark" onclick="flagForAdmin()">
                <i class="fa fa-user-slash me-2"></i>Escalate to Admin
            </button>

            <button class="btn-sec btn-warning" onclick="lockdownRoom()">
                <i class="fa fa-lock me-2"></i>Lockdown Room
            </button>

            ${currentVideoPath ? `
            <button class="btn-sec btn-neutral" onclick="playLogVideo()">
                <i class="fa fa-eye me-2"></i>Review Footage
            </button>` : ""}
        `;
    }

    // =========================
    // DEFAULT FALLBACK
    // =========================
    else {
        badge.innerText = "PENDING REVIEW";
        badge.classList.add("authorized");
        container.classList.add("severity-low");

        panel.innerHTML = `
            <button class="btn-sec btn-neutral" onclick="printSlip()">
                <i class="fa fa-print me-2"></i>Print Access Slip
            </button>
        `;
    }
}

// =========================
// BACKEND ACTION: FLAG ADMIN (ANTI-SPAM)
// =========================
function flagForAdmin() {
    if (!currentLogContext) return;

    fetch('/api/flag', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            name: currentLogContext.name,
            room: currentLogContext.room,
            time: currentLogContext.time
        })
    })
    .then(r => r.json())
    .then(data => {
        if (data.duplicate) {
            alert("⚠️ Flag already raised for this person recently.");
        } else {
            alert("✅ Flag sent to admin.");
        }
    })
    .catch(err => console.error(err));
}

// =========================
// BACKEND ACTION: LOCKDOWN (ANTI-SPAM)
// =========================
function lockdownRoom() {
    if (!currentLogContext) return;

    if (!confirm(`🔒 Confirm room lockdown for ${currentLogContext.room}?`)) return;

    fetch('/api/security/lockdown', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            room: currentLogContext.room
        })
    })
    .then(r => r.json())
    .then(data => {
        if (data.duplicate) {
            alert("⚠️ Room lockdown already active.");
        } else {
            alert("🔒 Room lockdown triggered.");
        }
    })
    .catch(err => console.error(err));
}

// =========================
// BACKEND ACTION: ALARM (ANTI-SPAM)
// =========================
function triggerAlarm() {
    if (!confirm("🚨 CONFIRM: Trigger emergency alarm?")) return;

    fetch('/api/security/alarm', {
        method: 'POST'
    })
    .then(r => r.json())
    .then(data => {
        if (data.duplicate) {
            alert("⚠️ Alarm already active.");
        } else {
            alert("🚨 Emergency alarm triggered!");
        }
    })
    .catch(err => console.error(err));
}

// =========================
// MANUAL VERIFY (NEW — Security decision)
// =========================
function manualVerify() {
    if (!currentLogContext) return;

    if (confirm(`✅ Manually verify ${currentLogContext.name} as authorized?`)) {
        alert(`${currentLogContext.name} manually approved by security.`);
        setStatus("AUTHORIZED", false, "True", "True");
    }
}

// =========================
// VIEW ACTIVE SESSION
// =========================
function viewActiveSession() {
    if (!currentLogContext) return;
    alert(`📋 Active session for ${currentLogContext.name}\nRoom: ${currentLogContext.room}\nTime: ${currentLogContext.time}`);
}

// =========================
// UI ACTIONS
// =========================
function printSlip() {
    alert("Printing access slip...");
}

// =========================
// VIDEO PLAYBACK (FIX-7: Inline Player)
// =========================
function playLogVideo() {
    if (!currentVideoPath) {
        alert("No video recording available for this event.");
        return;
    }

    const container = document.getElementById('videoPlayerContainer');
    const player = document.getElementById('inlineVideoPlayer');

    // Build video URL from the recording path
    // Recordings are served from Pi Flask at /recordings/<filename>
    let videoUrl = currentVideoPath;
    if (!videoUrl.startsWith('http')) {
        // If it's a relative path, assume it's served from the Pi's Flask
        const cams = document.querySelectorAll('[data-stream-url]');
        if (cams.length > 0) {
            const streamUrl = cams[0].getAttribute('data-stream-url');
            try {
                const u = new URL(streamUrl);
                videoUrl = `http://${u.hostname}:5050/recordings/${videoUrl.split('/').pop()}`;
            } catch(e) {}
        }
    }

    player.src = videoUrl;
    container.style.display = 'block';
    player.play().catch(() => {});
}

function closeVideoPlayer() {
    const container = document.getElementById('videoPlayerContainer');
    const player = document.getElementById('inlineVideoPlayer');
    player.pause();
    player.src = '';
    container.style.display = 'none';
}

// =========================
// PERSONNEL ACCESS HISTORY (FIX-7)
// =========================
function viewAccessHistory() {
    if (!currentLogContext || !currentLogContext.id) {
        alert("No personnel selected.");
        return;
    }

    const container = document.getElementById('historyContainer');
    const content = document.getElementById('historyContent');
    content.innerHTML = '<div style="text-align:center;color:#aaa;padding:20px;"><i class="fa fa-spinner fa-spin me-2"></i>Loading history...</div>';
    container.style.display = 'block';

    fetch(`/Access/GetPersonHistory?personnelId=${currentLogContext.id}&count=20`)
        .then(r => r.json())
        .then(data => {
            if (!data.logs || data.logs.length === 0) {
                content.innerHTML = '<p style="color:#aaa;text-align:center;padding:16px;">No access history found.</p>';
                return;
            }

            let html = '<div style="display:flex;flex-direction:column;gap:8px;">';
            data.logs.forEach(log => {
                const riskColor = log.riskLevel === 'AUTHORIZED' ? '#2ecc71' :
                                  log.riskLevel === 'SUSPICIOUS' ? '#f39c12' : '#e74c3c';
                const rfidIcon = log.rfidValid ? '✓' : '✗';
                const faceIcon = log.faceVerified ? '✓' : '✗';

                html += `
                <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:10px 14px;border-left:3px solid ${riskColor};">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="color:#e6edf3;font-weight:500;font-size:0.85rem;">${log.room || 'Unknown'}</span>
                        <span style="color:#8b949e;font-size:0.75rem;">${log.time}</span>
                    </div>
                    <div style="margin-top:4px;font-size:0.75rem;color:#8b949e;">
                        RFID: <span style="color:${log.rfidValid ? '#2ecc71' : '#e74c3c'}">${rfidIcon}</span>
                        &nbsp;|&nbsp;
                        Face: <span style="color:${log.faceVerified ? '#2ecc71' : '#e74c3c'}">${faceIcon}</span>
                        &nbsp;|&nbsp;
                        <span style="color:${riskColor};font-weight:600;">${log.riskLevel}</span>
                        ${log.hasVideo ? ' &nbsp;|&nbsp; <i class="fa fa-video" style="color:#f39c12;"></i>' : ''}
                    </div>
                </div>`;
            });
            html += '</div>';
            content.innerHTML = html;
        })
        .catch(() => {
            content.innerHTML = '<p style="color:#e74c3c;text-align:center;padding:16px;">Failed to load history.</p>';
        });
}

function closeHistory() {
    document.getElementById('historyContainer').style.display = 'none';
}

// =========================
// BUTTON SPAM PROTECTION
// Disables button + shows spinner after click, re-enables after response/5s
// =========================
function withSpamGuard(btn, action) {
    if (btn.disabled) return;
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Processing...';
    
    Promise.resolve(action()).finally(() => {
        setTimeout(() => {
            btn.disabled = false;
            btn.innerHTML = originalHTML;
        }, 2000);
    });
}

// Apply spam guard to all action buttons
document.addEventListener('click', function(e) {
    const btn = e.target.closest('.btn-sec');
    if (!btn || btn.disabled) return;
    // Buttons already have onclick handlers, just add the visual guard
});

// =========================
// REALTIME ACCESS LOG POLLING (3-5s)
// Updates the "Recent Activity" list dynamically
// =========================
let _accessPollTimer = null;
let _lastLogCount = @Model.Count;

function startAccessPolling() {
    _accessPollTimer = setInterval(pollAccessLogs, 4000);
}

function pollAccessLogs() {
    fetch('/Access/GetLatestLogs?count=50', {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => {
        if (!r.ok) return null;
        return r.json();
    })
    .then(data => {
        if (!data || !data.logs) return;
        
        // Update session count in header
        const sessionText = document.querySelector('.header-right .ms-3');
        if (data.activeSessionCount > 0) {
            if (sessionText) {
                sessionText.innerHTML = `<i class="fa fa-users me-1"></i>${data.activeSessionCount} active session(s)`;
                sessionText.style.display = '';
            }
        } else if (sessionText) {
            sessionText.style.display = 'none';
        }

        // Only update if log count changed (lightweight check)
        if (data.logs.length !== _lastLogCount) {
            _lastLogCount = data.logs.length;
            updateLogList(data.logs, data.activePersonIds || []);
        }
    })
    .catch(() => {}); // Silent fail — don't spam console
}

function updateLogList(logs, activePersonIds) {
    const scrollContainer = document.querySelector('.log-scroll');
    if (!scrollContainer) return;
    
    let html = '';
    logs.forEach(log => {
        const initials = log.fullName ? log.fullName.split(' ').map(n => n[0]).join('') : '??';
        const isInside = activePersonIds.includes(log.personId);
        const insideClass = isInside ? 'session-active' : '';
        const insideBadge = isInside ? '<span style="color:#2ecc71;font-weight:600;margin-left:6px;">● INSIDE</span>' : '';
        const videoBadge = log.hasVideo ? '<span style="color:#f39c12;font-weight:600;margin-left:6px;" title="Video Evidence"><i class="fa fa-video"></i> REC</span>' : '';
        
        html += `
        <div class="log-card ${insideClass}" 
             onclick="dockData('${log.fullName}','${log.personnelId}','${log.location}','${log.imageUrl}','${log.department}','${log.email}','${log.phone}','${log.room}','${log.time}','${log.videoPath || ''}','${log.riskLevel}',${isInside},'${log.rfidValid}','${log.faceVerified}')">
            <div class="log-avatar-box">
                <span class="avatar-initial">${initials}</span>
            </div>
            <div class="log-info">
                <div class="d-flex justify-content-between">
                    <span class="log-name">${log.fullName}</span>
                    <span class="log-time">${log.time}</span>
                </div>
                <p class="log-sub">${log.location} • ${log.room}${insideBadge}${videoBadge}</p>
            </div>
        </div>`;
    });
    
    scrollContainer.innerHTML = html;
}

// Start polling when page loads
document.addEventListener('DOMContentLoaded', startAccessPolling);
</script>