@model List<WebApp.Models.AccessLog>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Access Control";
}

<link rel="stylesheet" href="~/css/access.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="access-grid">

    <!-- HEADER -->
    <div class="grid-header">
        <i class="fa fa-shield-halved"></i>
        <span>SECUREVISION ACCESS CONTROL</span>
        <span id="statusText" class="status-text">No selection</span>
    </div>

    <!-- MAIN CONTENT (LEFT SIDE) -->
    <div class="grid-main">

        <div class="panel-body">

            <div id="emptyState" class="center-content">
                <div class="avatar-bg">
                    <i class="fa fa-user"></i>
                </div>
            </div>

            <div id="detailContent" class="detail-layout" style="display:none;">

                <div class="profile-section">
                    <img id="detImg" src="~/images/default-user.png" class="profile-large" />
                    <h2 id="detName">Name</h2>
                    <p id="detId">ID</p>
                </div>

                <div class="info-grid">

                    <div class="info-block full">
                        <label>Department</label>
                        <div id="detDept" class="field-box">-</div>
                    </div>

                    <div class="info-block">
                        <label>Contact</label>
                        <div id="detEmail" class="field-box">-</div>
                        <div id="detPhone" class="field-box mt-2">-</div>
                    </div>

                    <div class="info-block">
                        <label>Access</label>
                        <div class="field-box">ROOM: <span id="detRoom">-</span></div>
                        <div class="field-box">LOCATION: <span id="detLoc">-</span></div>
                        <div class="field-box">TIME: <span id="detTime">-</span></div>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <!-- RIGHT SIDE NAV (ACCESS LOGS) -->
    <div class="grid-nav">

        <div class="log-scroll">

            <p class="helper-text">Recent Access Logs</p>

            @foreach (var log in Model)
            {
                <div class="log-card"
                     onclick="dockData(
                            '@log.FullName',
                            '@log.StudentId',
                            '@log.Location',
                            '@log.ImageUrl',
                            '@log.Department',
                            '@log.Email',
                            '@log.Phone',
                            '@log.Room',
                            '@log.Timestamp.ToString("hh:mm tt")'
                         )">

                    <div class="log-avatar-box">
                        <img src="@log.ImageUrl" onerror="this.style.display='none'" />
                        <i class="fa fa-user"></i>
                    </div>

                    <div class="log-info">
                        <h4>@log.FullName</h4>
                        <p>@log.Timestamp.ToString("hh:mm tt")</p>
                    </div>

                </div>
            }

        </div>
    </div>

</div>

<script>
    function dockData(name, id, loc, img, dept, email, phone, room, time) {

        document.getElementById("emptyState").style.display = "none";
        document.getElementById("detailContent").style.display = "block";

        document.getElementById("detName").innerText = name;
        document.getElementById("detId").innerText = id;
        document.getElementById("detImg").src = img || '/images/default-user.png';

        document.getElementById("detDept").innerText = dept || "-";
        document.getElementById("detEmail").innerText = email || "-";
        document.getElementById("detPhone").innerText = phone || "-";

        document.getElementById("detRoom").innerText = room || "-";
        document.getElementById("detLoc").innerText = loc || "-";
        document.getElementById("detTime").innerText = time || "-";

        document.getElementById("statusText").innerText = name;
    }
</script>