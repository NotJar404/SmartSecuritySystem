# ============================================================================
# Smart Security System — Environment Configuration
# Copy this file to .env and edit values for your deployment
# ============================================================================

# ============================================================================
# ARCHITECTURE A — Hybrid (Laptop Dashboard + RPi Hardware)
# Laptop runs: PostgreSQL + ASP.NET + Browser
# RPi runs:    main.py + Flask (5050) + Hardware + Camera
# ============================================================================

# --- On the Raspberry Pi (.env in IotController/) ---
# ASPNET_URL=http://192.168.1.100:5145
# ASPNETCORE_HTTP_PORT=5145
# DB_HOST=192.168.1.100

# --- On the Laptop (appsettings.json) ---
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=SmartSecurityDB;Username=postgres;Password=1234

# ============================================================================
# ARCHITECTURE B — Standalone (Everything on RPi, DB on Laptop or RPi)
# RPi runs:    main.py + Flask (5050) + ASP.NET (5000) + Hardware + Camera
# Laptop:      PostgreSQL only (or also on RPi)
# ============================================================================

# --- On the Raspberry Pi (.env in IotController/) ---
ASPNET_URL=http://localhost:5000
ASPNETCORE_HTTP_PORT=5000

# --- Database ---
# If PostgreSQL on the same Pi:
DB_HOST=localhost
# If PostgreSQL on laptop:
# DB_HOST=192.168.1.100

# --- PostgreSQL ---
DB_PORT=5432
DB_NAME=SmartSecurityDB
DB_USER=postgres
DB_PASS=1234

# --- SMTP (for email notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SSL=true
SMTP_EMAIL=your-email@gmail.com
SMTP_NAME=SecureVision Security System
SMTP_PASSWORD=your-app-password

# --- Room Config (per-door Pi) ---
ROOM_ID=1
CAMERA_ID=1
MAX_STAY_MINUTES=20
ROOM_MAX_CAPACITY=10
OPERATING_HOURS_START=6
OPERATING_HOURS_END=22

# --- API Reliability ---
ENABLE_API_RETRY=true
